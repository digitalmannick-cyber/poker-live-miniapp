<view class="app-bg"></view>
<view class="container">
  <view wx:if="{{pageReady && !allSessions.length}}" class="card quick-empty-card">
    <view class="section-kicker">Quick Record</view>
    <view class="section-title">先创建一个进行中的场次</view>
    <view class="muted quick-empty-desc">记牌页现在是主入口。进入后会默认连接当前进行中的场次；如果还没有场次，先去创建一场。</view>
    <button class="primary-btn quick-empty-btn" bindtap="goCreateSession">去创建场次</button>
    <button class="secondary-btn quick-empty-btn" bindtap="goSessionList">查看全部场次</button>
  </view>

  <block wx:if="{{pageReady && allSessions.length}}">
    <view class="card quick-hero-card">
      <view class="quick-topline">
        <view class="quick-topline-copy">
          <view class="section-kicker">Fast Record</view>
          <view class="quick-page-title">单页快速录入</view>
          <view class="muted quick-page-desc">先选两张手牌，再补输赢和关键字段；需要时再展开补充详情。</view>
        </view>
      </view>
      <view class="quick-session-bar onboarding-target-record-session" bindtap="openSessionSelector">
        <view class="quick-session-main">
          <view class="quick-session-label">当前场次</view>
          <view class="quick-session-name">{{session.title}}</view>
          <view class="small muted">{{sessionMetaText || '当前 Session'}}</view>
        </view>
        <view class="quick-session-side">
          <view class="quick-session-chip">{{sessionBlindDisplay || '--'}}</view>
          <view class="small muted">点此切换</view>
        </view>
      </view>
    </view>

    <view class="card quick-flow-card onboarding-target-record">
      <view class="quick-flow-head">
        <view>
          <view class="section-kicker">Main Entry</view>
          <view class="section-title quick-flow-title">核心录入</view>
        </view>
        <view class="quick-step-badge">{{heroCardsVisual.length >= 2 ? '手牌已完成' : '先选两张牌'}}</view>
      </view>

      <view class="quick-card-layout">
        <view class="quick-hand-card onboarding-target-record-hand">
          <view class="quick-card-head">
            <view class="quick-card-title">手牌选择</view>
            <view class="badge-outline">{{heroCardsVisual.length >= 2 ? '已选 2 张' : '未选择'}}</view>
          </view>
          <view class="quick-hand-trigger {{heroCardsVisual.length ? '' : 'empty'}}" bindtap="openHeroPicker">
            <view wx:if="{{heroCardsVisual.length}}" class="quick-hand-display cards-inline tight">
              <view
                wx:for="{{heroCardsVisual}}"
                wx:for-item="card"
                wx:key="index"
                class="quick-picked-card mini-card mini-card-{{card.suitClass}}"
              >
                <text class="quick-picked-rank">{{card.rank}}</text>
                <text class="quick-picked-suit">{{card.suitSymbol}}</text>
              </view>
            </view>
            <view wx:else class="quick-hand-empty">点击弹出手牌选择器</view>
          </view>
          <view class="quick-hand-caption">{{heroCardsVisual.length >= 2 ? '需要修改手牌时，直接点上面的区域重新选择。' : '先选两张 Hero 手牌，选满 2 张会自动收起。'}}</view>
        </view>

        <view class="quick-profit-card onboarding-target-record-profit">
          <view class="quick-card-head">
            <view class="quick-card-title">输赢录入</view>
            <view class="badge-outline">{{form.currentProfit !== '' ? '可保存' : '待补输赢'}}</view>
          </view>
          <view>
            <view class="label">输或赢</view>
            <view class="picker compact-input profit-trigger {{form.currentProfit ? 'filled' : ''}}" bindtap="openProfitEditor">
              {{form.currentProfit || '点此录入'}}
            </view>
          </view>
        </view>
      </view>

      <view class="quick-helper-row">
        <view class="quick-helper-text">{{heroCardsVisual.length >= 2 ? '手牌已经选好，补完输赢就可以直接保存。' : '先完成手牌选择，再补输赢即可快速记录。'}}</view>
        <button class="secondary-btn quick-save-btn onboarding-target-record-save" bindtap="saveHand" loading="{{savingHand}}" disabled="{{savingHand}}">{{savingHand ? '保存中' : '记录手牌'}}</button>
      </view>
    </view>

    <view class="record-advanced-card">
      <view class="record-advanced-summary" bindtap="toggleAdvanced">
        <view>
          <view class="record-advanced-title">补充详情</view>
          <view class="small muted">需要时再展开，补充牌局流程、标签和备注等附加信息。</view>
        </view>
        <view class="badge-outline advanced-toggle-badge">{{advancedOpen ? '收起' : '展开'}}</view>
      </view>

      <view wx:if="{{advancedOpen}}" class="record-advanced-body">
        <view class="card advanced-card edit-detail-card edit-detail-main">
          <view class="section-title">基础信息</view>
          <view class="unified-field-grid">
            <view class="unified-field-card">
              <view class="label">日期</view>
              <view class="unified-field-action">编辑</view>
              <picker mode="date" value="{{form.playedDate}}" bindchange="onInput" data-key="playedDate">
                <view class="unified-field-value preset-trigger">{{form.playedDate || '请选择日期'}}</view>
              </picker>
            </view>
            <view class="unified-field-card">
              <view class="label">级别</view>
              <view class="unified-field-action">选择</view>
              <view class="unified-field-value preset-trigger" bindtap="openLevelSelector">{{form.stakeLevel || '请选择级别'}}</view>
            </view>
            <view class="unified-field-card">
              <view class="label">人数</view>
              <view class="unified-field-action">编辑</view>
              <input class="input compact-input unified-field-value" type="number" value="{{form.playerCount}}" data-key="playerCount" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
            </view>
            <view class="unified-field-card">
              <view class="label">是否 Straddle</view>
              <view class="unified-field-action">勾选</view>
              <checkbox-group class="detail-checkbox-group" bindchange="onStraddleCheckboxChange">
                <label class="detail-checkbox">
                  <checkbox value="1" checked="{{form.hasStraddle}}" color="#00d1ff" />
                  <text>{{form.hasStraddle ? '是' : '否'}}</text>
                </label>
              </checkbox-group>
            </view>
            <view class="unified-field-card">
              <view class="label">Hero 位置</view>
              <view class="unified-field-action">选择</view>
              <view class="unified-field-value preset-trigger" bindtap="openPositionSelector">{{form.heroPosition || '请选择位置'}}</view>
            </view>
            <view class="unified-field-card">
              <view class="label">对手位置</view>
              <view class="unified-field-action">选择</view>
              <view class="unified-field-value preset-trigger" bindtap="openVillainPositionSelector">{{form.villainPosition || '请选择对手位置'}}</view>
            </view>
            <view class="unified-field-card">
              <view class="label">对手类型</view>
              <view class="unified-field-action">选择</view>
              <view class="unified-field-value preset-trigger" bindtap="openOpponentTypeSelector">{{form.opponentType || '请选择对手类型'}}</view>
            </view>
            <view class="unified-field-card">
              <view class="label">有效筹码</view>
              <view class="unified-field-action">编辑</view>
              <input class="input compact-input unified-field-value" type="number" placeholder="" value="{{form.effectiveStack}}" data-key="effectiveStack" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
            </view>
            <view class="unified-field-card">
              <view class="label">当前底池</view>
              <view class="unified-field-action">编辑</view>
              <input class="input compact-input unified-field-value" type="number" placeholder="" value="{{form.potSize}}" data-key="potSize" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
            </view>
            <view class="unified-field-card">
              <view class="label">本手输赢</view>
              <view class="unified-field-action">编辑</view>
              <input class="input compact-input unified-field-value" type="number" value="{{form.currentProfit}}" data-key="currentProfit" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
            </view>
            <view class="unified-field-card">
              <view class="label">River 前 All-in</view>
              <view class="unified-field-action">勾选</view>
              <switch checked="{{form.isAllIn}}" color="#00d1ff" bindchange="toggleAllIn" />
            </view>
            <view wx:if="{{form.isAllIn}}" class="unified-field-card">
              <view class="label">All-in EV</view>
              <view class="unified-field-action">编辑</view>
              <input class="input compact-input unified-field-value" type="digit" value="{{form.allInEv}}" data-key="allInEv" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
            </view>
            <view class="unified-field-card">
              <view class="label">对手昵称</view>
              <view class="unified-field-action">编辑</view>
              <input class="input compact-input unified-field-value" value="{{form.opponentName}}" data-key="opponentName" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
            </view>
            <view class="unified-field-card">
              <view class="label">对手手牌</view>
              <view class="unified-field-action">编辑</view>
              <view class="hero-editor-trigger compact-card-trigger" bindtap="openShowdownPicker">
                <view wx:if="{{showdownCardsVisual.length}}" class="cards-inline tight">
                  <view class="mini-card mini-card-{{card.suitClass}}" wx:for="{{showdownCardsVisual}}" wx:for-item="card" wx:key="index">
                    <text class="mini-card-rank">{{card.rank}}</text>
                    <text class="mini-card-suit">{{card.suitSymbol}}</text>
                  </view>
                </view>
                <text wx:elif="{{showdownText}}" class="rank-only-card-text">{{showdownText}}</text>
                <text wx:else class="board-empty-text"></text>
              </view>
            </view>
          </view>
          <view class="label edit-detail-label">Hero 手牌</view>
          <view class="hero-editor-trigger edit-hero-trigger" bindtap="openHeroPicker">
            <view wx:if="{{heroCardsVisual.length}}" class="cards-inline tight">
              <view class="mini-card mini-card-{{card.suitClass}}" wx:for="{{heroCardsVisual}}" wx:for-item="card" wx:key="index">
                <text class="mini-card-rank">{{card.rank}}</text>
                <text class="mini-card-suit">{{card.suitSymbol}}</text>
              </view>
            </view>
            <text wx:else class="board-empty-text">点击选择 Hero 手牌</text>
          </view>
        </view>

        <view class="card advanced-card edit-detail-card edit-detail-streets">
          <view class="section-title">牌局流程</view>
          <view class="label edit-detail-section-label">逐街识别</view>
          <view class="street-stack">
            <view class="street-block">
              <view class="street-title">翻前</view>
              <view class="grid-2 compact-grid">
                <view>
                  <view class="label">动作线</view>
                  <input class="input compact-input" value="{{form.preflopActionLine}}" data-key="preflopActionLine" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
                <view>
                  <view class="label">底池</view>
                  <input class="input compact-input" type="number" value="{{form.preflopPot}}" data-key="preflopPot" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
              </view>
              <view class="preflop-allin-row">
                <view>
                  <view class="preflop-allin-title">翻前双方已全下</view>
                  <view class="preflop-allin-desc">开启后只补 Flop / Turn / River 公共牌，不再录入翻后行动。</view>
                </view>
                <switch checked="{{form.preflopAllIn}}" color="#00d1ff" bindchange="togglePreflopAllIn" />
              </view>
            </view>
            <view class="street-block {{form.preflopAllIn ? 'board-only-street' : ''}}">
              <view class="street-title">翻牌</view>
              <view class="street-flow-grid">
                <view>
                  <view class="label">公牌</view>
                  <view class="board-editor-trigger compact-board-trigger" bindtap="openBoardPicker" data-key="flop">
                    <view wx:if="{{boardEditorVisual[0].cards.length}}" class="cards-inline tight street-board-inline">
                      <view
                        wx:for="{{boardEditorVisual[0].cards}}"
                        wx:for-item="card"
                        wx:key="index"
                        class="mini-card mini-card-{{card.suitClass}}"
                      >
                        <text class="mini-card-rank">{{card.rank}}</text>
                        <text class="mini-card-suit">{{card.suitSymbol}}</text>
                      </view>
                    </view>
                    <text wx:else class="board-empty-text">{{boardEditorVisual[0].emptyText}}</text>
                  </view>
                </view>
                <view wx:if="{{!form.preflopAllIn}}">
                  <view class="label">动作线</view>
                  <input class="input compact-input" value="{{form.flopActionLine}}" data-key="flopActionLine" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
                <view wx:if="{{!form.preflopAllIn}}">
                  <view class="label">底池</view>
                  <input class="input compact-input" type="number" value="{{form.flopPot}}" data-key="flopPot" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
              </view>
            </view>
            <view class="street-block {{form.preflopAllIn ? 'board-only-street' : ''}}">
              <view class="street-title">转牌</view>
              <view class="street-flow-grid">
                <view>
                  <view class="label">公牌</view>
                  <view class="board-editor-trigger compact-board-trigger" bindtap="openBoardPicker" data-key="turn">
                    <view wx:if="{{boardEditorVisual[1].cards.length}}" class="cards-inline tight street-board-inline">
                      <view
                        wx:for="{{boardEditorVisual[1].cards}}"
                        wx:for-item="card"
                        wx:key="index"
                        class="mini-card mini-card-{{card.suitClass}}"
                      >
                        <text class="mini-card-rank">{{card.rank}}</text>
                        <text class="mini-card-suit">{{card.suitSymbol}}</text>
                      </view>
                    </view>
                    <text wx:else class="board-empty-text">{{boardEditorVisual[1].emptyText}}</text>
                  </view>
                </view>
                <view wx:if="{{!form.preflopAllIn}}">
                  <view class="label">动作线</view>
                  <input class="input compact-input" value="{{form.turnActionLine}}" data-key="turnActionLine" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
                <view wx:if="{{!form.preflopAllIn}}">
                  <view class="label">底池</view>
                  <input class="input compact-input" type="number" value="{{form.turnPot}}" data-key="turnPot" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
              </view>
            </view>
            <view class="street-block {{form.preflopAllIn ? 'board-only-street' : ''}}">
              <view class="street-title">河牌</view>
              <view class="street-flow-grid">
                <view>
                  <view class="label">公牌</view>
                  <view class="board-editor-trigger compact-board-trigger" bindtap="openBoardPicker" data-key="river">
                    <view wx:if="{{boardEditorVisual[2].cards.length}}" class="cards-inline tight street-board-inline">
                      <view
                        wx:for="{{boardEditorVisual[2].cards}}"
                        wx:for-item="card"
                        wx:key="index"
                        class="mini-card mini-card-{{card.suitClass}}"
                      >
                        <text class="mini-card-rank">{{card.rank}}</text>
                        <text class="mini-card-suit">{{card.suitSymbol}}</text>
                      </view>
                    </view>
                    <text wx:else class="board-empty-text">{{boardEditorVisual[2].emptyText}}</text>
                  </view>
                </view>
                <view wx:if="{{!form.preflopAllIn}}">
                  <view class="label">动作线</view>
                  <input class="input compact-input" value="{{form.riverActionLine}}" data-key="riverActionLine" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
                <view wx:if="{{!form.preflopAllIn}}">
                  <view class="label">底池</view>
                  <input class="input compact-input" type="number" value="{{form.riverPot}}" data-key="riverPot" bindinput="onInput" bindblur="commitInputValue" bindconfirm="commitInputValue" />
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="card advanced-card edit-detail-card edit-detail-analysis">
          <view class="section-title">复盘分析</view>
          <view class="label">行动总结</view>
          <textarea class="textarea analysis-textarea" placeholder="" value="{{form.streetSummary}}" data-key="streetSummary" bindinput="onInput" bindblur="commitInputValue"></textarea>
          <view class="label">心路历程</view>
          <textarea class="textarea analysis-textarea" value="{{form.notes}}" data-key="notes" bindinput="onInput" bindblur="commitInputValue"></textarea>
          <view class="label">Hero 疑问点、待确认、需研究</view>
          <textarea class="textarea analysis-textarea hero-question-textarea" maxlength="160" value="{{form.heroQuestion}}" data-key="heroQuestion" bindinput="onInput" bindblur="commitInputValue"></textarea>
          <view class="label">标签</view>
          <view class="edit-tag-list">
            <view
              wx:for="{{tagOptions}}"
              wx:key="key"
              class="edit-tag-chip {{item.active ? 'active' : ''}}"
              data-label="{{item.label}}"
              bindtap="toggleTag"
            >{{item.label}}</view>
          </view>
        </view>

      </view>
    </view>
  </block>

  <view wx:if="{{heroPickerVisible}}" class="hero-picker-modal">
    <view class="hero-picker-mask" bindtap="closeHeroPicker"></view>
    <view class="hero-picker-panel" catchtap="noop">
      <view class="hero-picker-head">
        <view>
          <view class="hero-picker-title">Hero 手牌选牌</view>
          <view class="small muted">这里选择 2 张 Hero 手牌，点满 2 张会自动收起。</view>
        </view>
        <button class="picker-close-btn" bindtap="closeHeroPicker">关闭</button>
      </view>
      <view class="hero-picked-preview">
        <view class="badge-outline">{{heroCardsVisual.length >= 2 ? '已选 2 张' : '待选择'}}</view>
        <view class="hero-picked-center cards-inline tight">
          <view
            wx:for="{{heroCardsVisual}}"
            wx:for-item="card"
            wx:key="index"
            class="quick-picked-card mini-card mini-card-{{card.suitClass}}"
          >
            <text class="quick-picked-rank">{{card.rank}}</text>
            <text class="quick-picked-suit">{{card.suitSymbol}}</text>
          </view>
        </view>
      </view>
      <view class="hero-picker-deck">
        <view wx:for="{{heroPickerDeck}}" wx:for-item="suitRow" wx:key="key" class="hero-picker-row">
          <view
            wx:for="{{suitRow.cards}}"
            wx:for-item="card"
            wx:key="token"
            class="hero-picker-card hero-picker-card-{{card.suitClass}} {{card.selected ? 'selected' : ''}} {{card.disabled ? 'disabled' : ''}}"
            data-token="{{card.token}}"
            data-disabled="{{card.disabled ? 1 : ''}}"
            bindtap="pickHeroCard"
          >
            <text class="hero-picker-rank">{{card.rank}}</text>
            <text class="hero-picker-suit">{{card.suitSymbol}}</text>
          </view>
        </view>
      </view>
      <view class="hero-picker-tools">
        <button class="secondary-btn picker-tool-main" data-action="backspace" bindtap="handleHeroPickerTool">退一张</button>
        <button class="danger-btn picker-tool-main" data-action="clear" bindtap="handleHeroPickerTool">清空</button>
      </view>
    </view>
  </view>

  <view wx:if="{{boardPickerVisible}}" class="hero-picker-modal">
    <view class="hero-picker-mask" bindtap="closeBoardPicker"></view>
    <view class="hero-picker-panel" catchtap="noop">
      <view class="hero-picker-head">
        <view>
          <view class="hero-picker-title">{{boardPickerTitle}}</view>
          <view class="small muted">按牌面点选公牌，Hero 已选手牌和其他街公牌会自动置灰。</view>
        </view>
        <button class="picker-close-btn" bindtap="closeBoardPicker">关闭</button>
      </view>
      <view class="hero-picked-preview">
        <view class="badge-outline">{{boardPickerHint}}</view>
        <view class="hero-picked-center cards-inline tight">
          <view
            wx:for="{{boardPickerPreview}}"
            wx:for-item="card"
            wx:key="index"
            class="quick-picked-card mini-card mini-card-{{card.suitClass}}"
          >
            <text class="quick-picked-rank">{{card.rank}}</text>
            <text class="quick-picked-suit">{{card.suitSymbol}}</text>
          </view>
        </view>
      </view>
      <view class="hero-picker-deck">
        <view wx:for="{{boardPickerDeck}}" wx:for-item="suitRow" wx:key="key" class="hero-picker-row">
          <view
            wx:for="{{suitRow.cards}}"
            wx:for-item="card"
            wx:key="token"
            class="hero-picker-card hero-picker-card-{{card.suitClass}} {{card.selected ? 'selected' : ''}} {{card.disabled ? 'disabled' : ''}}"
            data-token="{{card.token}}"
            data-disabled="{{card.disabled ? 1 : ''}}"
            bindtap="pickBoardCard"
          >
            <text class="hero-picker-rank">{{card.rank}}</text>
            <text class="hero-picker-suit">{{card.suitSymbol}}</text>
          </view>
        </view>
      </view>
      <view class="hero-picker-tools">
        <button class="secondary-btn picker-tool-main" data-action="backspace" bindtap="handleBoardPickerTool">退一张</button>
        <button class="danger-btn picker-tool-main" data-action="clear" bindtap="handleBoardPickerTool">清空</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showdownPickerVisible}}" class="hero-picker-modal">
    <view class="hero-picker-mask" bindtap="closeShowdownPicker"></view>
    <view class="hero-picker-panel" catchtap="noop">
      <view class="hero-picker-head">
        <view>
          <view class="hero-picker-title">对手手牌</view>
          <view class="small muted">选择 2 张对手摊牌手牌，已占用的 Hero 手牌和公牌会自动置灰。</view>
        </view>
        <button class="picker-close-btn" bindtap="closeShowdownPicker">关闭</button>
      </view>
      <view class="hero-picked-preview">
        <view class="badge-outline">{{showdownCardsVisual.length >= 2 ? '已选 2 张' : '待选择'}}</view>
        <view class="hero-picked-center cards-inline tight">
          <view
            wx:for="{{showdownCardsVisual}}"
            wx:for-item="card"
            wx:key="index"
            class="quick-picked-card mini-card mini-card-{{card.suitClass}}"
          >
            <text class="quick-picked-rank">{{card.rank}}</text>
            <text class="quick-picked-suit">{{card.suitSymbol}}</text>
          </view>
        </view>
      </view>
      <view class="hero-picker-deck">
        <view wx:for="{{showdownPickerDeck}}" wx:for-item="suitRow" wx:key="key" class="hero-picker-row">
          <view
            wx:for="{{suitRow.cards}}"
            wx:for-item="card"
            wx:key="token"
            class="hero-picker-card hero-picker-card-{{card.suitClass}} {{card.selected ? 'selected' : ''}} {{card.disabled ? 'disabled' : ''}}"
            data-token="{{card.token}}"
            data-disabled="{{card.disabled ? 1 : ''}}"
            bindtap="pickShowdownCard"
          >
            <text class="hero-picker-rank">{{card.rank}}</text>
            <text class="hero-picker-suit">{{card.suitSymbol}}</text>
          </view>
        </view>
      </view>
      <view class="hero-picker-tools">
        <button class="secondary-btn picker-tool-main" data-action="backspace" bindtap="handleShowdownPickerTool">退一张</button>
        <button class="danger-btn picker-tool-main" data-action="clear" bindtap="handleShowdownPickerTool">清空</button>
      </view>
    </view>
  </view>

  <view wx:if="{{profitEditorVisible}}" class="hero-picker-modal">
    <view class="hero-picker-mask" bindtap="closeProfitEditor"></view>
    <view class="profit-editor-panel" catchtap="noop">
      <view class="hero-picker-head">
        <view>
          <view class="hero-picker-title">输赢录入</view>
          <view class="small muted">先选加号或减号，再点数字带入输入框。</view>
        </view>
        <button class="picker-close-btn" bindtap="closeProfitEditor">关闭</button>
      </view>

      <view class="profit-editor-preview">
        <view class="profit-editor-sign-row">
          <view class="profit-sign-chip {{profitEditorSign === '+' ? 'active' : ''}}" data-sign="+" bindtap="pickProfitSign">+</view>
          <view class="profit-sign-chip {{profitEditorSign === '-' ? 'active' : ''}}" data-sign="-" bindtap="pickProfitSign">-</view>
        </view>
        <view class="profit-editor-value {{profitEditorSign === '-' ? 'negative' : 'positive'}}">
          {{profitEditorDigits ? (profitEditorSign + profitEditorDigits) : (profitEditorSign + '0')}}
        </view>
      </view>

      <view class="profit-keypad">
        <view class="profit-keypad-row">
          <view class="profit-key" data-digit="1" bindtap="appendProfitDigit">1</view>
          <view class="profit-key" data-digit="2" bindtap="appendProfitDigit">2</view>
          <view class="profit-key" data-digit="3" bindtap="appendProfitDigit">3</view>
        </view>
        <view class="profit-keypad-row">
          <view class="profit-key" data-digit="4" bindtap="appendProfitDigit">4</view>
          <view class="profit-key" data-digit="5" bindtap="appendProfitDigit">5</view>
          <view class="profit-key" data-digit="6" bindtap="appendProfitDigit">6</view>
        </view>
        <view class="profit-keypad-row">
          <view class="profit-key" data-digit="7" bindtap="appendProfitDigit">7</view>
          <view class="profit-key" data-digit="8" bindtap="appendProfitDigit">8</view>
          <view class="profit-key" data-digit="9" bindtap="appendProfitDigit">9</view>
        </view>
        <view class="profit-keypad-row">
          <view class="profit-key profit-key-tool" data-action="clear" bindtap="handleProfitEditorTool">清空</view>
          <view class="profit-key" data-digit="0" bindtap="appendProfitDigit">0</view>
          <view class="profit-key profit-key-tool" data-action="backspace" bindtap="handleProfitEditorTool">退格</view>
        </view>
      </view>

      <view class="hero-picker-tools">
        <button class="secondary-btn picker-tool-main" bindtap="closeProfitEditor">取消</button>
        <button class="secondary-btn picker-tool-main profit-more-btn" bindtap="openMoreInfoFromProfit">更多信息</button>
        <button class="primary-btn picker-tool-main" bindtap="quickSaveFromProfit">快速记录</button>
      </view>
    </view>
  </view>

  <view wx:if="{{selectorVisible}}" class="hero-picker-modal">
    <view class="hero-picker-mask" bindtap="closeSelector"></view>
    <view class="selector-sheet" catchtap="noop">
      <view class="hero-picker-head">
        <view>
          <view class="hero-picker-title">{{selectorTitle}}</view>
          <view class="small muted">直接点选你在“我的”里预设好的选项。</view>
        </view>
        <button class="picker-close-btn" bindtap="closeSelector">关闭</button>
      </view>
      <scroll-view scroll-y="true" class="selector-option-list">
        <view
          wx:for="{{selectorOptions}}"
          wx:key="value"
          class="selector-option {{item.selected ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="selectPresetOption"
        >
          <view class="selector-option-label">{{item.label}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
<onboarding-guide visible="{{onboardingGuideVisible}}" step="{{onboardingGuideStep}}" bindnext="onOnboardingNext" bindskip="onOnboardingSkip" />
<agent-chat wx:if="{{agentChatReady}}" />
