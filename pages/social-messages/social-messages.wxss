@import '../../app.wxss';

.social-messages-shell { padding-bottom: calc(48rpx + env(safe-area-inset-bottom)); }
.social-messages-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24rpx; margin: 18rpx 0 26rpx; }
.social-messages-kicker { color: rgba(255,255,255,.42); font-size: 21rpx; font-weight: 900; letter-spacing: 4rpx; }
.social-messages-title { margin-top: 8rpx; color: #fff; font-size: 52rpx; line-height: 1; font-weight: 1000; }
.social-messages-summary { margin-top: 14rpx; color: #00d1ff; font-size: 24rpx; font-weight: 800; }
.mark-all, .state-action, .more-button, .more-retry { margin: 0; border: 0; color: #fff; font-size: 24rpx; font-weight: 900; }
.mark-all { min-width: 152rpx; min-height: 80rpx; padding: 0 24rpx; border-radius: 18rpx; background: #e60012; }
.mark-all[disabled] { color: rgba(255,255,255,.34); background: rgba(255,255,255,.07); }
.offline-banner { margin-bottom: 18rpx; padding: 16rpx 20rpx; border-radius: 16rpx; color: #ffd166; font-size: 23rpx; background: rgba(255,209,102,.08); border: 1rpx solid rgba(255,209,102,.22); }
.messages-state { min-height: 360rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20rpx; text-align: center; color: rgba(255,255,255,.52); }
.messages-state-title { color: #fff; font-size: 29rpx; font-weight: 900; }
.messages-state-text { max-width: 520rpx; font-size: 24rpx; line-height: 1.6; }
.state-action { min-width: 150rpx; min-height: 80rpx; padding: 0 26rpx; border-radius: 18rpx; background: rgba(255,255,255,.10); }
.message-list { display: flex; flex-direction: column; gap: 16rpx; }
.message-card { position: relative; display: flex; gap: 18rpx; min-width: 0; padding: 22rpx; overflow: hidden; border-radius: 22rpx; background: rgba(17,21,31,.92); border: 1rpx solid rgba(255,255,255,.10); }
.message-card.is-unread { border-color: rgba(0,209,255,.25); }
.message-card.is-read { opacity: .76; }
.message-card.is-unavailable { filter: saturate(.5); }
.unread-marker { position: absolute; left: 0; top: 24rpx; width: 6rpx; height: 42rpx; border-radius: 0 8rpx 8rpx 0; background: #00d1ff; }
.sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; opacity: 0; }
.message-avatar { flex: 0 0 76rpx; width: 76rpx; height: 76rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 20rpx; color: #fff; font-size: 27rpx; font-weight: 1000; background: #252b38; border: 1rpx solid rgba(255,255,255,.15); }
.message-avatar image { width: 100%; height: 100%; }
.message-main { flex: 1; min-width: 0; }
.message-title-row { display: flex; align-items: baseline; justify-content: space-between; gap: 14rpx; }
.message-title { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #fff; font-size: 28rpx; font-weight: 950; }
.message-time { flex: 0 0 auto; color: rgba(255,255,255,.34); font-size: 20rpx; }
.message-summary { margin-top: 9rpx; display: -webkit-box; overflow: hidden; color: rgba(255,255,255,.60); font-size: 24rpx; line-height: 1.45; -webkit-box-orient: vertical; -webkit-line-clamp: 2; word-break: break-all; }
.message-unavailable, .request-result { margin-top: 14rpx; color: rgba(255,255,255,.46); font-size: 23rpx; font-weight: 800; }
.request-actions { display: flex; justify-content: flex-end; gap: 14rpx; margin-top: 18rpx; }
.request-action { min-width: 126rpx; min-height: 80rpx; margin: 0; padding: 0 24rpx; border-radius: 17rpx; color: #fff; font-size: 24rpx; font-weight: 950; }
.request-action.accept { background: #e60012; border: 0; }
.request-action.reject { background: rgba(255,255,255,.07); border: 1rpx solid rgba(255,255,255,.15); }
.request-action[disabled] { opacity: .48; }
.load-more { min-height: 100rpx; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,.40); font-size: 22rpx; }
.more-button, .more-retry { min-height: 80rpx; padding: 0 28rpx; border-radius: 17rpx; background: rgba(255,255,255,.07); }
.more-retry { color: #00d1ff; }
.list-end { padding: 28rpx 0; }
