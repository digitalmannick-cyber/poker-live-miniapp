.session-launch-splash {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 2147483000;
  overflow: hidden;
  background: #030305;
  animation: sessionLaunchExit 240ms ease-in 2710ms forwards;
}

.session-launch-hero {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform-origin: 50% 54%;
  will-change: transform, opacity, filter;
  animation: sessionLaunchHeroFloat 2950ms ease-in-out both;
}

.session-launch-glow,
.session-launch-vignette {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.session-launch-glow {
  z-index: 2;
  opacity: 0.45;
  background:
    radial-gradient(ellipse at 36% 54%, transparent 30%, rgba(240, 0, 47, 0.08) 44%, transparent 60%),
    linear-gradient(110deg, transparent 53%, rgba(240, 0, 47, 0.12) 58%, transparent 65%);
  animation: sessionLaunchGlow 900ms ease-in-out 240ms 3 alternate;
}

.session-launch-vignette {
  z-index: 3;
  background:
    linear-gradient(180deg, rgba(0,0,0,0.10), transparent 38%, rgba(0,0,0,0.60)),
    radial-gradient(ellipse at center, transparent 48%, rgba(0,0,0,0.52) 100%);
}

.session-launch-brand {
  position: absolute;
  z-index: 5;
  left: 0;
  right: 0;
  bottom: calc(72rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  text-shadow: 0 8rpx 30rpx #000000;
  animation: sessionLaunchBrandEnter 560ms cubic-bezier(0.18, 0.88, 0.24, 1) 320ms both;
}

.session-launch-name {
  position: relative;
  padding: 8rpx 28rpx 12rpx;
  color: #ffffff;
  font-size: 68rpx;
  font-weight: 950;
  letter-spacing: 10rpx;
  line-height: 1;
  transform: skewX(-8deg);
  border-bottom: 12rpx solid #f0002f;
}

.session-launch-tagline {
  margin-top: 14rpx;
  color: rgba(255,255,255,0.68);
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}

.session-launch-cut {
  position: absolute;
  z-index: 8;
  left: -190%;
  bottom: -8%;
  width: 180%;
  height: 36%;
  background: #f0002f;
  transform: rotate(-11deg) skewX(-18deg);
  box-shadow: 0 -12rpx 0 #f5f3ef;
  animation: sessionLaunchCutAcross 520ms cubic-bezier(0.66, 0, 0.28, 1) 2430ms both;
}

@keyframes sessionLaunchHeroFloat {
  0% { opacity: 0; transform: translate3d(2.5%, 12rpx, 0) scale(1.035); filter: brightness(0.62); }
  12% { opacity: 1; filter: brightness(1); }
  40% { transform: translate3d(2.5%, -5rpx, 0) scale(1.01); }
  75% { transform: translate3d(2.5%, 4rpx, 0) scale(1.004); }
  100% { opacity: 1; transform: translate3d(2.5%, 1rpx, 0) scale(1); filter: brightness(1); }
}

@keyframes sessionLaunchGlow {
  from { opacity: 0.45; }
  to { opacity: 1; }
}

@keyframes sessionLaunchBrandEnter {
  from { opacity: 0; transform: translate3d(-36rpx, 10rpx, 0) skewX(-4deg); }
  to { opacity: 1; transform: translate3d(0, 0, 0); }
}

@keyframes sessionLaunchCutAcross {
  from { left: -190%; }
  64% { left: -12%; }
  to { left: 120%; }
}

@keyframes sessionLaunchExit {
  0%, 72% { opacity: 1; visibility: visible; }
  100% { opacity: 0; visibility: hidden; }
}
