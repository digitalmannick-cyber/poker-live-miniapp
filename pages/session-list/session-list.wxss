@import '../../app.wxss';
@import "../../components/ai-reminder-editor/ai-reminder-editor.wxss";

.session-shell.has-active {
  padding-top: 20rpx;
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
}

.session-live {
  position: relative;
  min-height: auto;
  padding: 8rpx 0 8rpx;
  overflow: hidden;
}

.session-live::before {
  content: '';
  position: absolute;
  right: -112rpx;
  top: 88rpx;
  width: 300rpx;
  height: 70rpx;
  background: rgba(230, 0, 18, 0.26);
  transform: rotate(-16deg);
  pointer-events: none;
}

.session-live-top {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 92rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.session-live-title {
  color: #ffffff;
  font-size: 44rpx;
  line-height: 1.12;
  font-weight: 950;
  text-align: center;
}

.session-live-back,
.session-live-more {
  width: 70rpx;
  height: 70rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.16);
  transform: skewX(-6deg);
}

.session-live-back {
  border-radius: 999rpx;
  font-size: 46rpx;
  transform: none;
}

.session-live-more.edit {
  width: 92rpx;
  font-size: 24rpx;
  letter-spacing: 0;
}

.session-live.history-edit .session-live-more.edit {
  min-width: 108rpx;
  color: #111111;
  background: #ffffff;
  border-color: rgba(255,255,255,0.8);
}

.session-live-hero {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 16rpx 0 26rpx;
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.12), transparent 42%),
    repeating-linear-gradient(135deg, rgba(255,255,255,0.025) 0 1rpx, transparent 1rpx 18rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.session-live-kicker {
  color: rgba(255,255,255,0.58);
  font-size: 22rpx;
  line-height: 1.1;
  font-weight: 1000;
  letter-spacing: 6rpx;
}

.session-live-duration {
  color: #ffffff;
  margin-top: 10rpx;
  font-size: 86rpx;
  line-height: 0.98;
  font-weight: 1000;
  letter-spacing: 0;
}

.session-live-meter {
  width: 430rpx;
  max-width: 72vw;
  height: 4rpx;
  margin: 22rpx auto 14rpx;
  background: linear-gradient(90deg, transparent, rgba(230, 0, 18, 0.9), transparent);
  box-shadow: 0 0 18rpx rgba(230, 0, 18, 0.5);
}

.session-history-editor {
  width: calc(100% - 36rpx);
  margin: 8rpx auto 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255,255,255,0.12);
  background: rgba(7, 8, 10, 0.52);
  text-align: left;
}

.session-history-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.session-history-label {
  margin: 0 0 8rpx;
  color: rgba(255,255,255,0.58);
  font-size: 21rpx;
  line-height: 1.15;
  font-weight: 900;
}

.session-history-select {
  min-height: 62rpx;
  padding: 0 18rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  color: rgba(255,255,255,0.92);
  background: rgba(255,255,255,0.055);
  border: 2rpx solid rgba(255,255,255,0.14);
  font-size: 25rpx;
  line-height: 1.1;
  font-weight: 950;
}

.session-history-segment {
  min-height: 62rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.session-history-segment-item {
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.76);
  background: rgba(255,255,255,0.055);
  border: 2rpx solid rgba(255,255,255,0.14);
  font-size: 24rpx;
  font-weight: 950;
}

.session-history-segment-item.active {
  color: #ffd429;
  border-color: rgba(255,212,41,0.62);
  background: rgba(230,0,18,0.42);
}

.session-live-meta {
  margin-top: 16rpx;
  display: grid;
  justify-items: center;
  gap: 8rpx;
}

.session-live-status {
  min-height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 950;
}

.session-live-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #e60012;
  box-shadow: 0 0 12rpx rgba(230, 0, 18, 0.72);
  animation: sessionLivePulse 1.15s ease-in-out infinite;
}

.session-live-status.paused {
  color: rgba(255,255,255,0.52);
}

@keyframes sessionLivePulse {
  0%, 100% {
    opacity: 0.28;
    transform: scale(0.82);
  }
  50% {
    opacity: 1;
    transform: scale(1.12);
  }
}

.session-live-bankroll {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  max-width: calc(100vw - 96rpx);
  color: rgba(255,255,255,0.58);
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 850;
  white-space: nowrap;
}

.session-live-bankroll-divider {
  color: rgba(255,255,255,0.28);
}

.session-live-profit {
  margin-top: 12rpx;
  color: #18dc91;
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 1000;
}

.session-live-profit.negative {
  color: #ff6775;
}

.session-live-chip {
  margin-left: 12rpx;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 212, 41, 0.56);
  color: #ffd429;
  font-size: 22rpx;
  vertical-align: middle;
}

.session-live-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin: 0 18rpx 28rpx;
}

.session-live-action {
  min-height: 76rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 950;
  background: linear-gradient(135deg, rgba(255,255,255,0.075), rgba(255,255,255,0.025));
  border: 2rpx solid rgba(255,255,255,0.14);
  transform: skewX(-4deg);
}

.session-live-action.cashout {
  color: rgba(255,255,255,0.9);
  border-color: rgba(255,255,255,0.16);
  background: linear-gradient(135deg, rgba(255,255,255,0.07), rgba(6, 7, 10, 0.86));
}

.session-live-tools {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  margin: 8rpx 8rpx 30rpx;
}

.session-tool {
  display: grid;
  grid-template-rows: 96rpx 34rpx;
  justify-items: center;
  align-items: center;
  row-gap: 4rpx;
  min-width: 0;
  color: rgba(255,255,255,0.62);
  font-size: 24rpx;
  line-height: 1;
  font-weight: 850;
}

.session-tool-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 1000;
  background: transparent;
  border: 0;
  transform: none;
}

.session-tool-img {
  width: 92rpx;
  height: 92rpx;
  display: block;
}

.session-tool-label {
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
}

.session-tool.buyin .session-tool-icon {
  border-color: transparent;
  background: transparent;
}

.session-tool.comment .session-tool-icon {
  border-color: transparent;
  background: transparent;
}

.session-tool.quick .session-tool-icon {
  border-color: transparent;
  background: transparent;
}

.session-tool.full .session-tool-icon {
  border-color: transparent;
  background: transparent;
}

.session-tool.ai-reminder .session-tool-icon {
  border-color: transparent;
  background: transparent;
}

.session-tool.primary .session-tool-icon {
  border-color: rgba(255, 212, 41, 0.76);
  background: linear-gradient(135deg, #e60012, #111111);
  box-shadow: 0 0 0 4rpx rgba(255, 212, 41, 0.12);
}

.session-timeline-group {
  margin-top: 30rpx;
}

.session-live-date {
  margin: 0 0 16rpx;
  padding-left: 18rpx;
  border-left: 8rpx solid #e60012;
  color: rgba(255,255,255,0.76);
  font-size: 32rpx;
  line-height: 1.18;
  font-weight: 1000;
}

.session-live-event {
  position: relative;
  display: grid;
  grid-template-columns: 56rpx 76rpx minmax(0, 1fr) auto;
  column-gap: 12rpx;
  align-items: center;
  min-height: 86rpx;
  padding: 4rpx 0 12rpx;
}

.session-live-event.editable {
  border-radius: 14rpx;
}

.session-live-event.editable:active {
  background: rgba(255,255,255,0.045);
}

.session-event-node {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70rpx;
}

.session-event-node::after {
  content: '';
  position: absolute;
  top: 54rpx;
  bottom: -24rpx;
  left: 50%;
  width: 5rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.54), rgba(230,0,18,0.72) 48%, rgba(0,209,255,0.20));
  box-shadow: 0 0 12rpx rgba(230,0,18,0.42);
}

.session-live-event.last .session-event-node::after {
  display: none;
}

.session-live-event-icon {
  position: relative;
  z-index: 1;
  width: 48rpx;
  height: 48rpx;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 1000;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.session-live-event-icon.hot {
  width: 52rpx;
  height: 52rpx;
}

.session-event-icon-img {
  width: 46rpx;
  height: 46rpx;
  display: block;
}

.session-live-event-icon.buyin {
  background: transparent;
  border-color: transparent;
}

.session-live-event-icon.comment {
  background: transparent;
  border-color: transparent;
}

.session-live-event-icon.quick {
  background: transparent;
  border-color: transparent;
}

.session-live-event-icon.full {
  background: transparent;
  border-color: transparent;
}

.session-live-event-icon.ai-reminder {
  background: transparent;
  border-color: transparent;
}

.session-live-event-title {
  color: rgba(255,255,255,0.92);
  font-size: 27rpx;
  line-height: 1.1;
  font-weight: 1000;
}

.session-event-title-row {
  min-height: 54rpx;
  display: flex;
  align-items: center;
}

.session-event-hand-row {
  min-height: 58rpx;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 12rpx;
  align-items: center;
}

.session-live-event-title.hand-position {
  min-width: 0;
  white-space: nowrap;
}

.session-live-event-amount,
.session-live-event-link {
  color: #ffffff;
  font-size: 25rpx;
  line-height: 1.1;
  font-weight: 1000;
  white-space: nowrap;
}

.session-live-event-time {
  color: rgba(255,255,255,0.58);
  font-size: 25rpx;
  line-height: 1;
  font-weight: 1000;
  min-height: 54rpx;
  display: flex;
  align-items: center;
}

.session-live-event-main {
  display: flex;
  align-items: center;
  align-self: center;
  min-width: 0;
  min-height: 58rpx;
}

.session-live-event-amount.positive {
  color: #18dc91;
}

.session-live-event-amount.negative {
  color: #ff6775;
}

.session-live-event > .session-live-event-amount {
  justify-self: end;
  align-self: center;
  text-align: right;
}

.session-reminder-card {
  width: 100%;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  background:
    linear-gradient(135deg, rgba(255, 31, 45, 0.18), transparent 62%),
    rgba(12, 14, 18, 0.92);
  box-shadow: 0 12rpx 34rpx rgba(0,0,0,0.34);
  box-sizing: border-box;
}

.session-reminder-card.yellow {
  background:
    linear-gradient(135deg, rgba(255, 212, 41, 0.18), transparent 62%),
    rgba(12, 14, 18, 0.92);
}

.session-reminder-card-label {
  color: rgba(255,255,255,0.58);
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: 0;
}

.session-reminder-card-headline {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.28;
  font-weight: 1000;
}

.session-reminder-card-advice {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.72);
  font-size: 22rpx;
  line-height: 1.42;
  font-weight: 800;
}

.session-reminder-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 12rpx;
}

.session-reminder-metric {
  padding: 8rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.68);
  font-size: 19rpx;
  line-height: 1.2;
  font-weight: 800;
}

.session-reminder-metric text {
  display: block;
}

.session-reminder-metric text + text {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 1000;
}

.session-reminder-ack {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 188rpx;
  height: 54rpx;
  margin-top: 14rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ff1f2d, #c30011);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 1000;
}

.session-live-event-link {
  color: #ffd429;
}

.session-event-cards {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 0;
}

.session-event-cards.large {
  justify-content: center;
  margin: 0;
}

.session-create-layer {
  position: fixed;
  inset: 0;
  z-index: 24000;
}

.session-create-mask {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.66);
  backdrop-filter: blur(8rpx);
}

.session-create-sheet,
.session-action-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 88vh;
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 34rpx calc(34rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.2), transparent 240rpx),
    rgba(9, 10, 12, 0.99);
  border-top: 2rpx solid rgba(255,255,255,0.14);
  box-shadow: 0 -26rpx 100rpx rgba(0,0,0,0.72);
  box-sizing: border-box;
}

.session-action-sheet {
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
}

.session-create-handle {
  width: 140rpx;
  height: 10rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.2);
}

.session-create-title {
  margin-bottom: 30rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.12;
  font-weight: 1000;
}

.session-create-form {
  display: grid;
  gap: 24rpx;
}

.session-create-choice-grid {
  display: grid;
  gap: 18rpx;
}

.session-create-choice {
  padding: 28rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.055);
}

.session-create-choice.primary {
  border-color: rgba(255, 212, 41, 0.5);
  background: linear-gradient(135deg, rgba(230,0,18,0.62), rgba(255,255,255,0.04));
}

.session-create-choice-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 1000;
}

.session-create-choice-sub {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.56);
  font-size: 24rpx;
  line-height: 1.35;
}

.session-create-label {
  margin-bottom: 12rpx;
  color: rgba(255,255,255,0.88);
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 950;
}

.session-create-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.session-time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.session-create-input-wrap,
.session-create-select {
  min-height: 82rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  background: rgba(0,0,0,0.34);
  border: 2rpx solid rgba(255,255,255,0.15);
}

.session-create-prefix {
  padding-left: 22rpx;
  color: rgba(255,255,255,0.52);
  font-size: 34rpx;
  font-weight: 1000;
}

.session-create-input {
  flex: 1;
  min-width: 0;
  height: 82rpx;
  padding: 0 22rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 1000;
}

.session-create-input.standalone {
  width: 100%;
  min-height: 82rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: rgba(0,0,0,0.34);
  border: 2rpx solid rgba(255,255,255,0.15);
}

.session-create-select {
  justify-content: space-between;
  padding: 0 22rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.06);
}

.session-create-select::after {
  content: '⌄';
  color: rgba(255,255,255,0.46);
  font-size: 32rpx;
  font-weight: 950;
}

.session-create-segment-item,
.session-action-option {
  min-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 10rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.84);
  font-size: 26rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.13);
  transform: skewX(-4deg);
  box-sizing: border-box;
}

.session-create-segment-item.active,
.session-action-option.primary {
  color: #ffd429;
  background: rgba(230, 0, 18, 0.28);
  border-color: rgba(255, 212, 41, 0.76);
}

.session-create-segment {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.session-create-segment-item {
  width: 100%;
  padding: 0 10rpx;
}

.session-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.session-buyin-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.session-buyin-option {
  min-height: 96rpx;
  border-radius: 10rpx;
  display: grid;
  place-items: center;
  gap: 6rpx;
  color: rgba(255,255,255,0.88);
  font-size: 24rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.14);
  transform: skewX(-4deg);
}

.session-buyin-option.active {
  color: #ffd429;
  background: rgba(230, 0, 18, 0.3);
  border-color: rgba(255, 212, 41, 0.76);
}

.session-comment-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin: 18rpx 0;
}

.session-comment-option {
  min-height: 64rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.82);
  font-size: 24rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.12);
}

.session-comment-hint {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.42);
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 800;
}

.session-table-change-form {
  display: grid;
  gap: 18rpx;
  margin-top: 18rpx;
}

.session-table-change-summary {
  min-height: 54rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  color: rgba(255,255,255,0.78);
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.35;
  background: rgba(0, 209, 255, 0.08);
