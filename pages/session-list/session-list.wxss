  overflow: hidden;
}

.session-summary-p5-mark {
  position: absolute;
  right: -52rpx;
  top: 0;
  width: 250rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #e60012 0%, #ff1b2d 100%);
  transform: skewX(-28deg);
  box-shadow: -18rpx 20rpx 0 rgba(255,255,255,0.08);
}

.session-summary-modal::before {
