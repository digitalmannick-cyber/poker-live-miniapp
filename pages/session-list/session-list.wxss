  grid-template-rows: auto minmax(0, 1fr);
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.26) 0, rgba(230, 0, 18, 0.08) 270rpx, transparent 271rpx),
    linear-gradient(180deg, rgba(28, 29, 38, 0.99), rgba(8, 9, 15, 0.99));
  border-top: 2rpx solid rgba(255,255,255,0.18);
  box-shadow: 0 -24rpx 90rpx rgba(0,0,0,0.58);
