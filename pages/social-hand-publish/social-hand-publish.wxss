@import '../../app.wxss';

.publish-page { padding-top: 30rpx; }
.publish-state-card, .publish-preview-card, .scope-card { position: relative; overflow: hidden; border: 1rpx solid rgba(255,255,255,.14); border-radius: 28rpx; background: linear-gradient(155deg, rgba(27,29,38,.98), rgba(8,9,13,.99)); box-sizing: border-box; }
.publish-state-card { min-height: 360rpx; padding: 48rpx 38rpx; }
.state-slash { position: absolute; top: -36rpx; right: -90rpx; width: 330rpx; height: 100rpx; background: #e60012; transform: rotate(-18deg); opacity: .88; }
.state-title { position: relative; color: #fff; font-size: 40rpx; font-weight: 1000; }
.state-copy { position: relative; margin-top: 18rpx; color: rgba(255,255,255,.62); font-size: 25rpx; line-height: 1.65; }
.state-action { display: flex; align-items: center; justify-content: center; min-height: 84rpx; margin-top: 34rpx; border-radius: 16rpx; color: #fff; background: linear-gradient(135deg, #e60012, #ff3746); font-size: 28rpx; font-weight: 1000; }
.state-action.secondary { border: 1rpx solid rgba(255,255,255,.16); background: rgba(255,255,255,.07); }
.success-card { text-align: center; }
.success-mark { display: flex; align-items: center; justify-content: center; width: 88rpx; height: 88rpx; margin: 0 auto 26rpx; border-radius: 50%; color: #090a0d; background: #00d1ff; font-size: 48rpx; font-weight: 1000; box-shadow: 0 0 38rpx rgba(0,209,255,.3); }
.success-id { margin-top: 12rpx; padding: 18rpx; border-radius: 12rpx; color: #00d1ff; background: rgba(0,209,255,.08); font-family: Menlo, Consolas, monospace; font-size: 24rpx; word-break: break-all; }

.publish-preview-card { padding: 34rpx 30rpx 30rpx; box-shadow: 0 24rpx 60rpx rgba(0,0,0,.28); }
.publish-replay-shell { position: relative; z-index: 1; margin: 26rpx -14rpx 0; }
.publish-preview-card > .hero-line,
.publish-preview-card > .metric-strip,
.publish-preview-card > .preview-section { display: none; }
.preview-accent { position: absolute; top: 0; left: -32rpx; width: 260rpx; height: 12rpx; background: #e60012; transform: skewX(-30deg); box-shadow: 120rpx 0 0 #00d1ff; }
.preview-head, .hero-line, .friend-picker-head, .action-row { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.preview-title { color: #fff; font-size: 42rpx; font-weight: 1000; letter-spacing: 1rpx; }
.preview-subtitle { margin-top: 8rpx; color: rgba(255,255,255,.52); font-size: 22rpx; }
.privacy-confirmation { margin-top: 24rpx; padding: 18rpx 20rpx; border-left: 6rpx solid #00d1ff; border-radius: 4rpx 16rpx 16rpx 4rpx; background: rgba(0,209,255,.07); }
.privacy-confirmation-title { color: #d8f8ff; font-size: 23rpx; font-weight: 1000; }
.privacy-confirmation-copy { margin-top: 7rpx; color: rgba(255,255,255,.62); font-size: 21rpx; line-height: 1.55; }
.bb-stamp { flex: none; padding: 10rpx 13rpx; border: 2rpx solid #00d1ff; color: #00d1ff; font-size: 25rpx; font-weight: 1000; transform: rotate(-4deg); }
.hero-line { margin-top: 30rpx; padding: 24rpx; border-left: 7rpx solid #e60012; background: linear-gradient(90deg, rgba(230,0,18,.16), rgba(255,255,255,.035)); }
.hero-label { color: #fff; font-size: 29rpx; font-weight: 1000; }
.hero-stack { margin-top: 8rpx; color: #00d1ff; font-size: 23rpx; font-weight: 900; }
.card-line, .board-row, .player-chip-row { display: flex; flex-wrap: wrap; gap: 10rpx; }
.poker-card, .board-card { display: flex; align-items: center; justify-content: center; width: 58rpx; height: 76rpx; border-radius: 9rpx; color: #111217; background: #fff; font-size: 25rpx; font-weight: 1000; box-shadow: 0 7rpx 18rpx rgba(0,0,0,.3); }
.board-card { width: 52rpx; height: 68rpx; font-size: 23rpx; }
.metric-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-top: 24rpx; }
.metric { padding: 18rpx 10rpx; border-radius: 13rpx; text-align: center; background: rgba(0,209,255,.06); border: 1rpx solid rgba(0,209,255,.18); }
.metric-value { color: #fff; font-size: 29rpx; font-weight: 1000; }
.metric-label { margin-top: 5rpx; color: rgba(255,255,255,.46); font-size: 18rpx; }
.preview-section { margin-top: 26rpx; }
.preview-section-label { margin-bottom: 13rpx; color: #00d1ff; font-size: 20rpx; font-weight: 1000; letter-spacing: 3rpx; }
.player-chip { padding: 10rpx 14rpx; border-radius: 9rpx; color: rgba(255,255,255,.82); background: rgba(255,255,255,.07); font-size: 21rpx; }
.action-list { overflow: hidden; border-radius: 12rpx; border: 1rpx solid rgba(255,255,255,.1); }
.action-row { min-height: 58rpx; padding: 0 16rpx; color: rgba(255,255,255,.78); font-size: 21rpx; border-bottom: 1rpx solid rgba(255,255,255,.08); }
.action-row:last-child { border-bottom: 0; }
.action-amount { color: #ffdc3a; font-weight: 900; }
.empty-inline { color: rgba(255,255,255,.38); font-size: 22rpx; }

.scope-card { margin-top: 24rpx; padding: 30rpx; }
.scope-title { color: #fff; font-size: 34rpx; font-weight: 1000; }
.scope-subtitle { margin-top: 8rpx; color: rgba(255,255,255,.48); font-size: 22rpx; }
.scope-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10rpx; margin-top: 24rpx; }
.scope-option { min-height: 116rpx; padding: 18rpx 10rpx; border: 1rpx solid rgba(255,255,255,.12); border-radius: 14rpx; text-align: center; background: rgba(255,255,255,.045); box-sizing: border-box; }
.scope-option.is-active { border-color: #e60012; background: linear-gradient(145deg, rgba(230,0,18,.28), rgba(230,0,18,.08)); box-shadow: inset 0 -5rpx 0 #e60012; }
.scope-name { color: #fff; font-size: 24rpx; font-weight: 1000; }
.scope-desc { margin-top: 9rpx; color: rgba(255,255,255,.48); font-size: 18rpx; line-height: 1.35; }
.public-warning { margin-top: 20rpx; padding: 18rpx; border-left: 6rpx solid #ffdc3a; color: rgba(255,255,255,.78); background: rgba(255,220,58,.08); font-size: 22rpx; line-height: 1.55; }
.friend-picker { margin-top: 24rpx; }
.friend-picker-head { color: #00d1ff; font-size: 22rpx; font-weight: 900; }
.friend-list { margin-top: 14rpx; border-top: 1rpx solid rgba(255,255,255,.09); }
.friend-row { display: flex; align-items: center; gap: 16rpx; min-height: 98rpx; padding: 12rpx 8rpx; border-bottom: 1rpx solid rgba(255,255,255,.09); }
.friend-row.is-selected { background: linear-gradient(90deg, rgba(230,0,18,.13), transparent); }
.friend-avatar { display: flex; align-items: center; justify-content: center; flex: none; width: 62rpx; height: 62rpx; border-radius: 18rpx; color: #fff; background: #252a36; font-size: 24rpx; font-weight: 1000; }
.friend-main { flex: 1; min-width: 0; }
.friend-name { overflow: hidden; color: #fff; font-size: 25rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.friend-title { margin-top: 6rpx; color: rgba(255,255,255,.42); font-size: 19rpx; }
.friend-check { display: flex; align-items: center; justify-content: center; flex: none; width: 38rpx; height: 38rpx; border: 2rpx solid rgba(255,255,255,.24); border-radius: 50%; color: #fff; font-size: 22rpx; }
.is-selected .friend-check { border-color: #e60012; background: #e60012; }
.friend-empty, .friend-error { padding: 28rpx 0 8rpx; color: rgba(255,255,255,.46); text-align: center; font-size: 22rpx; }
.friend-error, .inline-error { color: #ff7984; }
.load-more { display: flex; align-items: center; justify-content: center; min-height: 70rpx; margin-top: 16rpx; border-radius: 12rpx; color: #00d1ff; background: rgba(0,209,255,.07); font-size: 23rpx; font-weight: 900; }
.is-disabled { opacity: .5; }
.inline-error { margin-top: 18rpx; font-size: 22rpx; line-height: 1.5; }
.publish-cta { height: 90rpx; margin: 28rpx 0 0; border: 0; border-radius: 16rpx; color: #fff; background: linear-gradient(135deg, #b9000e, #e60012 54%, #ff3342); font-size: 30rpx; font-weight: 1000; line-height: 90rpx; box-shadow: 0 18rpx 36rpx rgba(230,0,18,.25); }
.publish-cta::after { border: 0; }
.publish-cta[disabled] { opacity: .58; }

@media (prefers-reduced-motion: reduce) {
  .scope-option, .publish-cta { transition: none; }
}
