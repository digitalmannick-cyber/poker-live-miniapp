@import '../../app.wxss';

.session-duration-instrument {
  margin: 2rpx 0 26rpx;
  padding: 26rpx 24rpx 22rpx;
  border-radius: 22rpx;
  text-align: center;
  background:
    radial-gradient(circle at 50% 0, rgba(230, 0, 18, 0.13), transparent 58%),
    linear-gradient(180deg, rgba(18, 21, 30, 0.92), rgba(10, 12, 18, 0.96));
  border: 1rpx solid rgba(255,255,255,0.11);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.06),
    0 16rpx 34rpx rgba(0,0,0,0.22);
}

.session-duration-instrument.running .session-duration-rule {
  animation: session-timer-pulse 1.6s ease-in-out infinite;
}

.session-duration-instrument.running .session-duration-caption::before {
  content: '';
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #ff3046;
  box-shadow: 0 0 14rpx rgba(255, 48, 70, 0.72);
  animation: session-timer-dot 1s steps(2, end) infinite;
}

@keyframes session-timer-pulse {
  0%, 100% {
    opacity: 0.58;
    transform: scaleX(0.92);
    box-shadow: 0 0 10rpx rgba(255, 24, 53, 0.26);
  }
  50% {
    opacity: 1;
    transform: scaleX(1);
    box-shadow: 0 0 24rpx rgba(255, 24, 53, 0.62);
  }
}

@keyframes session-timer-dot {
  0%, 45% { opacity: 1; }
  46%, 100% { opacity: 0.28; }
}

.session-duration-label {
  color: rgba(255,255,255,0.48);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 5rpx;
}

.session-duration-value {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 76rpx;
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: 8rpx;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 26rpx rgba(255, 30, 55, 0.18);
}

.session-duration-rule {
  width: 72%;
  height: 5rpx;
  margin: 18rpx auto 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(230,0,18,0), #ff1835 20%, #ff4b5d 50%, #ff1835 80%, rgba(230,0,18,0));
  box-shadow: 0 0 18rpx rgba(255, 24, 53, 0.42);
}

.session-duration-caption {
  margin-top: 13rpx;
  color: rgba(255,255,255,0.52);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.session-time-stack {
  margin-bottom: 6rpx;
}

.session-time-block + .session-time-block {
  margin-top: 8rpx;
}

.session-time-row {
  display: flex;
  gap: 14rpx;
}

.session-time-item {
  flex: 1;
  min-width: 0;
}

.session-profit-preview {
  font-weight: 900;
}

.session-profit-preview.empty {
  padding: 0 28rpx;
  text-align: left;
  color: rgba(255,255,255,0.52);
  font-weight: 700;
}

.preset-trigger {
  justify-content: flex-start;
}

.session-straddle-row {
  margin: 16rpx 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.session-straddle-label {
  margin: 0;
  flex: 0 0 auto;
}

.session-straddle-segment {
  flex: 0 0 284rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  padding: 5rpx;
  border-radius: 15rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.session-straddle-option {
  height: 56rpx;
  border-radius: 11rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.66);
  font-size: 24rpx;
  font-weight: 900;
  background: transparent;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.session-straddle-option.active {
  color: #ffffff;
  background: rgba(230, 0, 18, 0.22);
  border-color: rgba(230, 0, 18, 0.44);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08);
}

.session-status-badge.active {
  background: rgba(16, 185, 129, 0.16);
  border-color: rgba(16, 185, 129, 0.34);
  color: #b8ffdf;
}

.session-status-badge.finished {
  background: rgba(148, 163, 184, 0.12);
  border-color: rgba(148, 163, 184, 0.24);
  color: rgba(255,255,255,0.78);
}

.session-notes-textarea {
  min-height: 112rpx;
  height: 112rpx;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  line-height: 1.45;
}

.session-action-row {
  display: grid;
  grid-template-columns: 1fr;
  align-items: stretch;
  gap: 14rpx;
  margin-top: 22rpx;
}

.session-action-row.session-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.session-action-btn {
  width: 100%;
  min-width: 0;
  height: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  white-space: nowrap;
  margin: 0;
  line-height: 1;
  box-sizing: border-box;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
  overflow: hidden;
  -webkit-appearance: none;
  appearance: none;
  background-clip: padding-box;
  transform: translateZ(0);
  isolation: isolate;
}

.session-action-pressed {
  transform: translateZ(0) scale(0.985);
  opacity: 0.92;
}

.session-action-main {
  color: #ffffff;
  background: linear-gradient(135deg, #e60012, #ff3038);
  border-color: rgba(255,255,255,0.16);
  box-shadow: 0 12rpx 24rpx rgba(230, 0, 18, 0.22);
}

.session-action-side {
  color: rgba(255,255,255,0.88);
  background: rgba(255,255,255,0.055);
  border-color: rgba(255,255,255,0.14);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.06);
}

.session-record-btn {
  color: #081018;
  background: linear-gradient(135deg, #19e3ff, #5cf6d3);
  border: 1rpx solid rgba(255,255,255,0.18);
  box-shadow: 0 12rpx 24rpx rgba(25, 227, 255, 0.20);
}

.session-full-record-btn {
  color: #101114;
  background: linear-gradient(135deg, #ffffff, #d8dbe2);
  border-color: rgba(255,255,255,0.42);
  box-shadow: 0 12rpx 24rpx rgba(255,255,255,0.12);
}

.session-pause-btn {
  color: rgba(255,255,255,0.90);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  box-shadow: none;
}

.session-pause-btn.paused {
  color: #ffe4a3;
  background: rgba(255, 177, 35, 0.12);
  border-color: rgba(255, 177, 35, 0.28);
}

.session-finish-btn {
  color: #ffffff;
  background: rgba(230, 0, 18, 0.16);
  border-color: rgba(230, 0, 18, 0.30);
}

.session-action-btn.disabled {
  opacity: 0.45;
  filter: grayscale(0.3);
}

.session-summary-grid {
  margin-bottom: 20rpx;
}

.session-hand-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.session-hand-main {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  flex: 1 1 auto;
  gap: 8rpx;
  min-width: 0;
  overflow: visible;
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
}

.session-hand-main text {
  flex: 0 0 auto;
  white-space: nowrap;
}

.session-hero-inline .mini-card {
  width: 48rpx;
  height: 70rpx;
  padding: 8rpx 8rpx 9rpx;
  border-radius: 13rpx;
}

.session-hero-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
}

.session-hero-inline .mini-card .mini-card-rank {
  font-size: 31rpx;
}

.session-hero-inline .mini-card .mini-card-suit {
  font-size: 21rpx;
}

.session-board-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
  margin-left: 0;
}

.mini-card-board {
  width: 39rpx;
  height: 56rpx;
  padding: 5rpx 5rpx 6rpx;
  border-radius: 9rpx;
}

.mini-card-rank-board {
  font-size: 23rpx;
}

.mini-card-suit-board {
  font-size: 16rpx;
}

.session-hand-profit {
  flex: 0 0 auto;
  min-width: 92rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 800;
}

.position-chip {
  flex: 0 0 auto;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.90);
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.session-hand-meta-row {
  margin-top: 12rpx;
}

.selector-modal {
  position: fixed;
  inset: 0;
  z-index: 1200;
}

.selector-mask {
  position: absolute;
  inset: 0;
  background: rgba(4, 6, 10, 0.74);
  backdrop-filter: blur(10rpx);
}

.selector-sheet {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 88rpx;
  bottom: calc(208rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(18, 23, 34, 0.98), rgba(7, 10, 16, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 22rpx 60rpx rgba(0,0,0,0.34);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.selector-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.selector-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.picker-close-btn {
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.82);
  font-size: 24rpx;
}

.picker-close-btn::after {
  border: none;
}

.selector-option-list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.selector-option {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.10);
  color: rgba(255,255,255,0.82);
  box-sizing: border-box;
}

.selector-option.active {
  background: rgba(0, 209, 255, 0.16);
  border-color: rgba(0, 209, 255, 0.34);
  color: #ffffff;
}

.selector-option-label {
  font-size: 28rpx;
  font-weight: 800;
}

.session-detail-hero {
  position: relative;
  margin: 0 -24rpx 28rpx;
  padding: 26rpx 32rpx 34rpx;
  text-align: center;
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.18), transparent 43%),
    repeating-linear-gradient(135deg, rgba(255,255,255,0.025) 0 1rpx, transparent 1rpx 18rpx),
    rgba(7, 10, 14, 0.86);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  overflow: hidden;
}

.session-detail-hero::after {
  content: '';
  position: absolute;
  right: -62rpx;
  top: 118rpx;
  width: 250rpx;
  height: 64rpx;
  background: rgba(230, 0, 18, 0.28);
  transform: rotate(-15deg);
}

.session-detail-top {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 72rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 48rpx;
}

.session-detail-back,
.session-detail-more {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(255,255,255,0.14);
}

.session-detail-more {
  border-radius: 14rpx;
  font-size: 24rpx;
  transform: skewX(-6deg);
}

.session-detail-more.edit {
  width: 88rpx;
}

.session-detail-title {
  min-width: 0;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.14;
  font-weight: 950;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-detail-profit {
  position: relative;
  z-index: 1;
  color: #18dc91;
  font-size: 86rpx;
  line-height: 1;
  font-weight: 1000;
  letter-spacing: 0;
}

.session-detail-profit.negative {
  color: #ff6775;
}

.session-detail-buyline {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  color: rgba(255,255,255,0.78);
  font-size: 30rpx;
  font-weight: 700;
}

.session-detail-metrics {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx 36rpx;
  margin-top: 54rpx;
  text-align: left;
}

.session-detail-metric-main {
  color: rgba(255,255,255,0.78);
  font-size: 30rpx;
  font-weight: 800;
}

.session-detail-metric-main.positive {
  color: #18dc91;
}

.session-detail-metric-main.negative {
  color: #ff6775;
}

.session-detail-metric-sub {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.38);
  font-size: 22rpx;
  font-weight: 700;
}

.session-edit-head {
  position: relative;
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr) 132rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 34rpx;
  padding-top: 6rpx;
}

.session-edit-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(255,255,255,0.14);
}

.session-edit-title {
  min-width: 0;
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1.14;
  font-weight: 950;
  text-align: center;
}

.session-edit-save {
  min-height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #09090b;
  font-size: 28rpx;
  font-weight: 900;
  background: #ffffff;
  border: 2rpx solid rgba(255,255,255,0.82);
}

.session-edit-panel {
  display: grid;
  gap: 20rpx;
  margin: 0 -8rpx 8rpx;
  padding: 0 8rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.10);
}

.session-edit-money-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.session-edit-bankroll-summary {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 104rpx;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  box-sizing: border-box;
}

.session-edit-bankroll-line {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
  color: rgba(255,255,255,0.60);
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 900;
}

.session-edit-bankroll-divider {
  color: rgba(255,255,255,0.28);
}

.session-edit-bankroll-profit {
  color: #17d49b;
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 1000;
}

.session-edit-bankroll-profit.negative {
  color: #ff5d6c;
}

.session-edit-money-field {
  min-width: 0;
}

.session-edit-field-label {
  margin: 0 0 10rpx;
  color: rgba(255,255,255,0.72);
  font-size: 24rpx;
  line-height: 1.15;
  font-weight: 900;
}

.session-edit-money-input {
  height: 78rpx;
  border-radius: 16rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: rgba(255,255,255,0.56);
  font-size: 22rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.055);
  border: 2rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.session-edit-money-input input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 1000;
}

.session-edit-profit-row {
  min-height: 68rpx;
  border-radius: 16rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(255,255,255,0.58);
  font-size: 24rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.038);
  border: 1rpx solid rgba(255,255,255,0.09);
  box-sizing: border-box;
}

.session-edit-profit-row .session-profit-preview {
  min-height: 0;
  padding: 0;
  border: 0;
  background: transparent;
  font-size: 34rpx;
  font-weight: 1000;
}

.session-edit-section {
  display: grid;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.045);
  border: 2rpx solid rgba(255,255,255,0.11);
  box-sizing: border-box;
}

.session-edit-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.picker.static {
  color: rgba(255,255,255,0.72);
}

.session-table-options {
  height: 78rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.session-table-option {
  min-width: 0;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.78);
  font-size: 22rpx;
  font-weight: 1000;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(255,255,255,0.11);
  box-sizing: border-box;
}

.session-table-option.active {
  color: #ffd429;
  background: rgba(230, 0, 18, 0.22);
  border-color: rgba(255, 212, 41, 0.72);
}

.session-straddle-segment.compact {
  height: 78rpx;
}

.session-notes-textarea.compact {
  height: 120rpx;
  min-height: 120rpx;
}

.session-edit-tools {
  margin: 0 -2rpx 10rpx;
  padding: 20rpx 0 12rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.session-edit-tool {
  min-width: 0;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  color: rgba(255,255,255,0.72);
  font-size: 22rpx;
  font-weight: 1000;
}

.session-edit-tool-icon {
  width: 64rpx;
  height: 64rpx;
  display: block;
}

.session-detail-timeline {
  padding: 0 8rpx 28rpx;
}

.session-detail-timeline.editable {
  padding-top: 28rpx;
}

.session-timeline-group {
  margin-top: 34rpx;
}

.session-live-date {
  margin: 0 0 20rpx;
  padding-left: 18rpx;
  border-left: 8rpx solid #e60012;
  color: rgba(255,255,255,0.78);
  font-size: 36rpx;
  line-height: 1.18;
  font-weight: 1000;
}

.session-timeline-swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
}

.session-timeline-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 16rpx;
  width: 176rpx;
  display: none;
  grid-template-columns: repeat(2, 88rpx);
  overflow: hidden;
  border-radius: 0 22rpx 22rpx 0;
}

.session-timeline-swipe-row.open .session-timeline-actions {
  display: grid;
}

.session-timeline-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.session-timeline-action.edit {
  background: linear-gradient(180deg, #0aa8d6, #087ea5);
}

.session-timeline-action.delete {
  background: linear-gradient(180deg, #ef233c, #b80f24);
}

.session-live-event {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 82rpx 78rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: start;
  min-height: 116rpx;
  padding-bottom: 18rpx;
  background: transparent;
  transition: transform 0.18s ease;
}

.session-timeline-swipe-row.open .session-live-event {
  transform: translateX(-176rpx);
}

