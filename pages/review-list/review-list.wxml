      </view>
      <view class="review-ai-card-provider">{{view.providerDisplay}}</view>
    </view>

    <view wx:if="{{view.verdict}}" class="review-ai-card-verdict">
      <view class="review-ai-slash-label">结论</view>
      <view class="review-ai-card-verdict-text">{{view.verdict}}</view>
    </view>

    <view wx:if="{{view.hasKeyTakeaway}}" class="review-ai-takeaway">
      <view>
        <view class="review-ai-takeaway-title">关键行动</view>
        <view class="review-ai-takeaway-text">{{view.keyTakeaway}}</view>
      </view>
    </view>

    <view wx:if="{{view.hasStreetBreakdown}}" class="review-ai-street-panel">
      <view wx:for="{{view.streetBreakdown}}" wx:key="key" class="review-ai-street-row {{item.rowClass}}">
        <view class="review-ai-street-head">
          <view class="review-ai-street-name">{{item.streetDisplay}}</view>
          <view wx:if="{{item.hasDisplayStatus}}" class="review-ai-street-badge {{item.displayStatusClass}}">{{item.displayStatusText}}</view>
        </view>
        <view wx:for="{{item.pointItems}}" wx:for-item="point" wx:key="key" class="review-ai-street-point">
          <text wx:for="{{point.segments}}" wx:for-item="segment" wx:key="index" class="{{segment.highlight ? 'review-ai-wave-mark' : ''}}">{{segment.text}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{view.hasInsightCards || view.hasExploitSection || view.hasTrainingSection}}" class="review-ai-insight-stack">
      <view wx:if="{{view.hasInsightCards}}" class="review-ai-insight-group">
        <view wx:for="{{view.insightCards}}" wx:key="key" class="review-ai-insight-card {{item.type}}">
          <view class="review-ai-insight-index">{{item.indexText}}</view>
          <view class="review-ai-insight-title">{{item.label}}</view>
          <view class="review-ai-insight-text">
            <text wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index" class="{{segment.highlight ? 'review-ai-wave-mark' : ''}}">{{segment.text}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{view.hasExploitSection}}" class="review-ai-insight-card full {{view.exploitSection.type}}">
        <view class="review-ai-insight-index">{{view.exploitSection.indexText}}</view>
        <view class="review-ai-insight-title">{{view.exploitSection.label}}</view>
        <view wx:for="{{view.exploitSection.points}}" wx:key="index" class="review-ai-insight-point">{{item}}</view>
      </view>
      <view wx:if="{{view.hasTrainingSection}}" class="review-ai-insight-card full {{view.trainingSection.type}}">
        <view class="review-ai-insight-index">{{view.trainingSection.indexText}}</view>
        <view class="review-ai-insight-title">{{view.trainingSection.label}}</view>
        <view wx:for="{{view.trainingSection.points}}" wx:key="index" class="review-ai-insight-point">{{item}}</view>
      </view>
    </view>

    <view wx:if="{{view.answer}}" class="review-ai-fallback-text">{{view.answer}}</view>
    <view wx:if="{{view.hasMissingFields}}" class="review-ai-missing">
      <view class="review-ai-insight-title">缺失信息</view>
      <view wx:for="{{view.missingFields}}" wx:key="index" class="review-ai-insight-point">{{item}}</view>
    </view>
  </view>
</template>
