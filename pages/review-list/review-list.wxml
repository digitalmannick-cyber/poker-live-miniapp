<view class="app-bg"></view>
<view class="container">
  <view class="card">
    <view class="row">
      <view>
        <view class="card-title">复盘列表</view>
        <view class="muted small">语音复盘和完整录入的手牌会在这里展示</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">复盘摘要</view>
    <view class="grid-2">
      <view>
        <view class="kpi-value">{{summary.totalHands}}</view>
        <view class="kpi-label">筛选后手数</view>
      </view>
      <view>
        <view class="kpi-value {{summary.totalProfit >= 0 ? 'positive' : 'negative'}}">{{summary.totalProfitDisplay}}</view>
        <view class="kpi-label">筛选后盈亏</view>
      </view>
    </view>
  </view>

  <view class="review-filter-strip" bindtap="openFilterModal">
    <view class="review-filter-strip-main">
      <view class="review-filter-strip-title">筛选</view>
      <view class="review-filter-strip-summary">{{filterSummary}}</view>
    </view>
    <button class="review-filter-button" catchtap="openFilterModal">筛选</button>
  </view>

  <scroll-view scroll-x="true" class="review-sort-scroll">
    <view class="review-sort-compact">
      <view class="review-sort-label">排序</view>
      <view wx:for="{{sortControlOptions}}" wx:key="field" class="review-sort-chip {{item.active ? 'active' : ''}}" bindtap="changeSort" data-field="{{item.field}}">
        <text>{{item.label}}</text>
        <text class="review-sort-arrow">{{item.arrow}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="card">
    <view wx:if="{{hands.length}}">
      <view wx:for="{{hands}}" wx:key="_id" class="review-swipe-row {{item.onboardingReviewEntryTargetClass}} {{item.swiped ? 'open' : ''}}">
        <view class="review-swipe-actions {{item.onboardingReviewSwipeTargetClass}}">
          <view class="review-swipe-action edit" catchtap="editHandFromList" data-id="{{item._id}}">编辑</view>
          <view class="review-swipe-action delete {{item.onboardingReviewDeleteTargetClass}}" catchtap="deleteHandFromList" data-id="{{item._id}}">删除</view>
        </view>
        <view
          class="list-item review-swipe-content"
          bindtap="openHandDetail"
          bindtouchstart="onReviewItemTouchStart"
          bindtouchmove="onReviewItemTouchMove"
          bindtouchend="onReviewItemTouchEnd"
          bindtouchcancel="onReviewItemTouchEnd"
          data-id="{{item._id}}"
        >
          <view class="review-top-row">
            <view class="review-hand-main cards-inline">
              <view class="cards-inline tight review-hero-inline">
                <view wx:for="{{item.heroCardsVisual}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-{{card.suitClass}}">
                  <text class="mini-card-rank">{{card.rank}}</text>
                  <text class="mini-card-suit">{{card.suitSymbol}}</text>
                </view>
              </view>
              <view wx:if="{{item.showHeroPosition}}" class="position-chip {{item.heroPositionClass}}">{{item.heroPosition}}</view>
              <view class="cards-inline tight review-board-inline">
                <block wx:for="{{item.boardStreetVisual}}" wx:for-item="street" wx:key="street">
                  <view wx:for="{{street.cards}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-board mini-card-{{card.suitClass}}">
                    <text class="mini-card-rank mini-card-rank-board">{{card.rank}}</text>
                    <text class="mini-card-suit mini-card-suit-board">{{card.suitSymbol}}</text>
                  </view>
                </block>
              </view>
            </view>
            <view class="review-result-actions">
              <view class="review-profit {{item.currentProfit >= 0 ? 'positive' : 'negative'}}">{{item.currentProfitDisplay}}</view>
            </view>
          </view>
          <view wx:if="{{item.showActionLine}}" class="review-action-line">{{item.actionLine}}</view>
          <view wx:if="{{item.hasMetaText || item.replayAvailable || item.aiReviewReady || item.aiReviewGenerating || item.canRequestAiAdvice || item.canHandComment}}" class="review-meta-row">
            <view wx:if="{{item.hasMetaText}}" class="small muted">{{item.metaText}}</view>
            <view wx:if="{{item.replayAvailable || item.aiReviewReady || item.aiReviewGenerating || item.canRequestAiAdvice || item.canHandComment}}" class="review-meta-actions">
              <view
                wx:if="{{item.canHandComment}}"
                class="review-comment-trigger {{item.hasHandComments ? 'has-comments' : ''}}"
                catchtap="openHandComment"
                data-id="{{item._id}}"
                aria-label="comment hand"
              >
                <image class="review-comment-icon-img" src="/assets/review-icons/comment-bubble-v263.png" mode="aspectFit"></image>
                <text wx:if="{{item.hasHandComments}}" class="review-comment-count">{{item.handCommentCount}}</text>
              </view>
              <view
                wx:if="{{item.replayAvailable}}"
                class="review-replay-trigger {{item.onboardingReviewReplayTargetClass}}"
                catchtap="openHandReplay"
                data-id="{{item._id}}"
                aria-label="play replay"
              >
                <view class="review-replay-icon"></view>
              </view>
              <view wx:if="{{item.aiReviewReady || item.aiReviewGenerating || item.canRequestAiAdvice}}" class="review-ai-badge {{item.aiReviewGenerating ? 'loading' : 'ready'}} {{item.onboardingReviewAiAdviceTargetClass}}" catchtap="openAiAdviceSheet" data-id="{{item._id}}">
                <view wx:if="{{item.aiReviewGenerating}}" class="review-ai-badge-dot"></view>
                <text>{{item.aiReviewGenerating ? 'AI生成中' : 'AI建议'}}</text>
              </view>
          </view>
        </view>
      </view>
    </view>
    </view>
    <view wx:else class="empty">还没有可复盘的手牌。</view>
  </view>

  <view wx:if="{{replayVisible}}" class="review-replay-modal">
    <view class="review-replay-mask" bindtap="closeHandReplay"></view>
    <view class="review-replay-panel onboarding-target-review-replay-sheet" catchtap="stopModalTap">
      <hand-replay-player replay="{{replayData}}" bindclose="closeHandReplay" />
    </view>
  </view>

  <view wx:if="{{handCommentVisible}}" class="review-comment-modal">
    <view class="review-comment-mask" bindtap="closeHandComment"></view>
    <view class="review-comment-panel" catchtap="stopModalTap">
      <view class="review-comment-head">
        <view class="review-comment-close" bindtap="closeHandComment">关闭</view>
        <view class="review-comment-save review-comment-save-inline {{handCommentSaving ? 'saving' : ''}}" bindtap="saveHandComment">{{handCommentSaving ? '保存中' : '保存评论'}}</view>
      </view>
      <view wx:if="{{handCommentItems.length}}" class="review-comment-list">
        <view wx:for="{{handCommentItems}}" wx:key="id" class="review-comment-item">
          <view class="review-comment-text">{{item.text}}</view>
          <view wx:if="{{item.timeDisplay}}" class="review-comment-time">{{item.timeDisplay}}</view>
        </view>
      </view>
      <view wx:else class="review-comment-empty">还没有评论。</view>
      <textarea
        class="review-comment-input"
        value="{{handCommentDraft}}"
        maxlength="500"
        placeholder="写下这手牌的观察、问题或复盘结论"
        bindinput="onHandCommentInput"
      ></textarea>
    </view>
  </view>

  <view wx:if="{{aiAdviceSheetVisible}}" class="review-ai-sheet-modal">
    <view class="review-ai-sheet-mask" bindtap="closeAiAdviceSheet"></view>
    <view class="review-ai-sheet-panel onboarding-target-review-ai-sheet" catchtap="stopModalTap">
      <view class="review-ai-sheet-handle"></view>
      <view class="review-ai-sheet-head">
        <view>
          <view class="review-ai-sheet-kicker">EV BRAIN · STRUCTURED REVIEW</view>
          <view class="review-ai-sheet-title">AI建议</view>
        </view>
        <view class="review-ai-sheet-close" bindtap="closeAiAdviceSheet">×</view>
      </view>
      <scroll-view scroll-y="true" class="review-ai-sheet-scroll">
        <template is="ai-advice-card" data="{{view: aiAdviceSheetView, mode: 'sheet'}}" />
      </scroll-view>
      <view class="review-ai-sheet-actions">
        <button class="review-ai-sheet-btn" bindtap="closeAiAdviceSheet">关闭</button>
        <button class="review-ai-sheet-btn primary" bindtap="goHandDetailPage">完整详情</button>
      </view>
    </view>
  </view>

  <view wx:if="{{reviewChoiceVisible}}" class="review-choice-modal">
    <view class="review-choice-mask" bindtap="closeReviewChoice"></view>
    <view class="review-choice-panel" catchtap="stopModalTap">
      <view class="review-choice-handle"></view>
      <view class="review-choice-title">选择复盘方式</view>
      <view class="review-choice-sub">语音复盘适合补充想法，精准录入适合逐街校准行动线。</view>
      <view class="review-choice-grid">
        <view class="review-choice-card" data-mode="voice" bindtap="chooseReviewMode">
          <view class="review-choice-icon">V</view>
          <view class="review-choice-name">语音复盘</view>
          <view class="review-choice-desc">进入原复盘页</view>
        </view>
        <view class="review-choice-card primary" data-mode="ledger" bindtap="chooseReviewMode">
          <view class="review-choice-icon">P</view>
          <view class="review-choice-name">精准录入</view>
          <view class="review-choice-desc">按牌桌逐街录入</view>
        </view>
      </view>
      <view class="review-choice-cancel" bindtap="closeReviewChoice">取消</view>
    </view>
  </view>

  <view wx:if="{{filterModalVisible}}" class="review-filter-modal">
    <view class="review-filter-mask" bindtap="closeFilterModal"></view>
    <view class="review-filter-panel" catchtap="stopModalTap">
      <view class="review-filter-panel-head">
        <view class="review-filter-title-wrap">
          <view class="review-filter-panel-title">筛选手牌</view>
          <view class="muted small">选择条件后点完成应用到列表</view>
        </view>
        <view class="review-filter-head-actions">
          <view class="review-filter-head-btn" bindtap="resetFilters">重置</view>
          <view class="review-filter-head-btn primary" bindtap="applyFilterModal">完成</view>
        </view>
      </view>

      <scroll-view scroll-y="true" class="review-filter-scroll">
        <view class="review-filter-block">
          <view class="kpi-label">牌局状态</view>
          <view class="review-chip-wrap session">
            <view wx:for="{{draftSessionStatusOptions}}" wx:key="key" class="pill review-filter-pill {{item.active ? 'active' : ''}}" bindtap="selectSessionStatus" data-key="{{item.key}}">
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="review-filter-block">
          <view class="kpi-label">时间</view>
          <view class="review-chip-wrap">
            <view wx:for="{{draftDateFilterOptions}}" wx:key="key" class="pill review-filter-pill {{item.active ? 'active' : ''}}" bindtap="selectDateRange" data-key="{{item.key}}">
              <text>{{item.label}}</text>
            </view>
          </view>
          <view wx:if="{{draftDateRange === 'custom'}}" class="review-date-row">
            <picker mode="date" value="{{draftStartDate}}" bindchange="onStartDateChange">
              <view class="review-date-input">{{draftStartDate || '开始日期'}}</view>
            </picker>
            <picker mode="date" value="{{draftEndDate}}" bindchange="onEndDateChange">
              <view class="review-date-input">{{draftEndDate || '结束日期'}}</view>
            </picker>
          </view>
        </view>

        <view class="review-filter-block">
          <view class="kpi-label">输赢</view>
          <view class="review-chip-wrap">
            <view wx:for="{{draftResultFilterOptions}}" wx:key="key" class="pill review-filter-pill {{item.active ? 'active' : ''}}" bindtap="selectResultFilter" data-key="{{item.key}}">
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="review-filter-block">
          <view class="kpi-label">标签</view>
          <view class="review-chip-wrap review-chip-wrap-tags">
            <view wx:for="{{draftTagFilterOptions}}" wx:key="key" class="pill review-filter-pill {{item.active ? 'active' : ''}}" bindtap="selectTagFilter" data-key="{{item.key}}">
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>

      </scroll-view>
    </view>
  </view>

  <view wx:if="{{detailVisible}}" class="review-modal">
    <view class="review-modal-mask" bindtap="closeHandDetail"></view>
    <view class="review-modal-panel" catchtap="stopModalTap">
      <view class="review-modal-header review-modal-header-redesign">
        <view class="review-detail-title-wrap">
          <view class="review-detail-eyebrow">HAND REVIEW</view>
          <view class="review-detail-title">手牌复盘</view>
          <view class="small muted">{{detailSession ? detailSession.title : ''}}</view>
        </view>
        <view class="review-modal-header-right">
          <view class="review-detail-close-icon" bindtap="closeHandDetail" role="button" aria-label="关闭" hover-class="review-detail-close-icon-active">
            <view class="review-detail-close-glyph"></view>
          </view>
        </view>
      </view>

      <view wx:if="{{detailLoading && !detailHand}}" class="empty">详情加载中...</view>

      <view wx:elif="{{detailHand}}" class="review-detail-loaded">
        <view class="review-hero-summary">
          <view class="review-hero-left">
            <view class="cards-inline tight review-detail-hero-cards">
              <view wx:for="{{detailHand.heroCardsVisual}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-{{card.suitClass}}">
                <text class="mini-card-rank">{{card.rank}}</text>
                <text class="mini-card-suit">{{card.suitSymbol}}</text>
              </view>
            </view>
            <view class="review-position-meta">
              <view class="review-position-line">{{detailHand.heroPosition || '-'}}</view>
              <view class="review-copy-hand-id-btn" bindtap="copyDetailHandId">复制ID</view>
              <view class="review-copy-hand-id-btn export" bindtap="openDetailExport">导出</view>
              <view class="review-copy-hand-id-btn publish" bindtap="openDetailSocialHandPublish">发布</view>
            </view>
            <view class="small muted">
              {{detailHand.playedDate || '-'}} · {{detailHand.stakeLevel || '-'}}
            </view>
          </view>
          <view class="review-hero-result">
            <view class="review-profit review-detail-profit {{detailHand.currentProfit >= 0 ? 'positive' : 'negative'}}">{{detailHand.currentProfitDisplay}}</view>
            <view class="review-result-bb">{{detailHand.resultBBDisplay}}</view>
            <view wx:if="{{detailHand.hasAllInEvDisplay}}" class="review-all-in-ev-pill">
              <text class="review-all-in-ev-label">All-in EV</text>
              <text class="review-all-in-ev-value">{{detailHand.allInEvDisplay}}</text>
            </view>
          </view>
        </view>

        <scroll-view class="review-detail-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
          <view class="review-detail-scroll-content">
        <view wx:if="{{!voicePanelVisible}}" class="review-detail-review-entry">
          <view class="review-detail-entry-head">
            <view class="section-title">{{detailHand.hasCompletedReview ? '重新复盘' : '开始复盘'}}</view>
            <view class="small muted">两种方式都会回到同一张手牌详情，成功后更新 AI 建议。</view>
          </view>
          <view class="review-detail-entry-grid">
            <view class="review-detail-entry-card onboarding-target-review-voice" bindtap="handleVoiceEntry">
              <view class="review-detail-entry-icon voice">□</view>
              <view class="review-detail-entry-main">
                <view class="review-detail-entry-title">语音录入复盘</view>
                <view class="review-detail-entry-desc">补充口述思路和行动线</view>
              </view>
              <view class="review-detail-entry-arrow">›</view>
            </view>
            <view class="review-detail-entry-card primary onboarding-target-review-ledger" bindtap="openDetailLedgerReview">
              <view class="review-detail-entry-icon ledger">▤</view>
              <view class="review-detail-entry-main">
                <view class="review-detail-entry-title">完整录入复盘</view>
                <view class="review-detail-entry-desc">用桌面 replay 精准补全</view>
              </view>
              <view class="review-detail-entry-arrow">›</view>
            </view>
          </view>
        </view>

        <view wx:if="{{voicePanelVisible}}" class="review-detail-card review-voice-card">
          <view class="review-voice-head">
            <view>
              <view class="section-title">语音输入复盘</view>
              <view class="small muted">{{voiceStatus || '使用手机 AI 输入法转文字，再让 AI 提取字段并回填。'}}</view>
            </view>
            <view class="review-voice-head-actions">
              <view class="review-voice-badge">AI 提取</view>
              <view class="review-voice-collapse" bindtap="collapseVoicePanel">收起</view>
            </view>
          </view>
          <view class="review-voice-label-row">
            <view class="label">原始口述</view>
            <view class="review-voice-label-actions">
              <view class="review-voice-count">{{voiceNoteLength}} 字</view>
              <view class="review-voice-clear" bindtap="clearVoiceNote">清空</view>
            </view>
          </view>
          <textarea
            class="textarea review-voice-textarea"
            placeholder=""
            value="{{voiceNote}}"
            bindinput="onVoiceNoteInput"
            bindblur="commitVoiceNoteDraft"
            cursor-spacing="120"
            maxlength="-1"
          ></textarea>
          <view wx:if="{{voiceBusy}}" class="review-voice-loading">
            <view class="review-voice-spinner"></view>
            <view class="review-voice-loading-text">
              <view>正在解析口述内容</view>
              <view class="small muted">AI 正在提取位置、底池、输赢和逐街牌面，请稍等。</view>
            </view>
          </view>
          <view class="review-voice-actions">
            <button class="voice-action-btn voice-action-parse onboarding-target-review-parse" bindtap="parseVoiceNote" disabled="{{voiceBusy || !voiceNoteHasText}}">
              {{voiceBusy ? '解析中...' : '解析字段'}}
            </button>
            <button class="voice-action-btn voice-action-apply onboarding-target-review-apply" bindtap="applyVoicePatch" disabled="{{voiceBusy || !parsedVoice || voiceNeedsRefresh}}">
              确认回填
            </button>
          </view>

          <view wx:if="{{parsedVoice}}" class="review-voice-preview">
            <view class="review-ai-feedback-card">
              <view class="review-ai-feedback-head">
                <view>
                  <view class="kpi-label">AI 识别内容</view>
                  <view class="review-detail-text">{{parsedVoice.feedbackText || '已生成字段建议，请核对后回填。'}}</view>
                </view>
              </view>
            </view>
            <view wx:if="{{parsedVoice.confirmItems.length}}" class="review-confirm-card">
              <view class="kpi-label">需要确认</view>
              <view wx:for="{{parsedVoice.confirmItems}}" wx:key="key" class="review-confirm-item" bindtap="focusMissingField" data-field="{{item.field}}">
                <view class="review-confirm-main">{{item.label}}</view>
                <view class="review-confirm-sub">{{item.hint}}</view>
              </view>
              <textarea
                class="review-confirm-textarea"
                value="{{voiceCorrectionNote}}"
                bindinput="onVoiceCorrectionInput"
                placeholder=""
                auto-height="true"
              ></textarea>
              <button class="voice-correction-btn" bindtap="reparseVoiceWithCorrection" disabled="{{voiceBusy || !voiceCorrectionNote}}">
                提交修正并重新解析
              </button>
            </view>
            <view class="review-editing-note">
              <view class="review-editing-title">
                <text>待回填字段</text>
                <text class="review-editing-badge">可编辑</text>
              </view>
              <text class="review-editing-help">点字段修改，确认回填会以修改后的内容为准。</text>
            </view>
            <view class="review-voice-meta-grid unified-field-grid">
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">日期</view>
                <view class="review-edit-hint">编辑</view>
                <input class="review-field-input" value="{{parsedVoice.playedDate}}" data-field="playedDate" bindinput="onParsedVoiceFieldInput" bindblur="commitParsedVoiceFieldValue" bindconfirm="commitParsedVoiceFieldValue" focus="{{parsedVoice.focusPlayedDate}}" placeholder="-" />
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">级别</view>
                <view class="review-edit-hint">选择</view>
                <view class="review-field-picker" data-field="stakeLevel" bindtap="openVoicePresetSelector">{{parsedVoice.stakeLevel || '-'}}</view>
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">人数</view>
                <view class="review-edit-hint">编辑</view>
                <input class="review-field-input" value="{{parsedVoice.playerCountDisplayText}}" data-field="playerCount" bindinput="onParsedVoiceFieldInput" bindblur="commitParsedVoiceFieldValue" bindconfirm="commitParsedVoiceFieldValue" focus="{{parsedVoice.focusPlayerCount}}" placeholder="" />
              </view>
              <view class="review-voice-meta-item unified-field-card editable {{voiceStraddleMissingClass}}">
                <view class="kpi-label">是否 Straddle</view>
                <view class="review-edit-hint">勾选</view>
                <view class="voice-straddle-segment">
                  <view class="voice-straddle-option {{parsedVoice.straddleYesClass}}" data-value="1" bindtap="selectVoiceStraddleOption">是</view>
                  <view class="voice-straddle-option {{parsedVoice.straddleNoClass}}" data-value="0" bindtap="selectVoiceStraddleOption">否</view>
                </view>
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">Hero 位置</view>
                <view class="review-edit-hint">选择</view>
                <view class="review-field-picker" data-field="heroPosition" bindtap="openVoicePresetSelector">{{parsedVoice.heroPosition || '-'}}</view>
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">对手位置</view>
                <view class="review-edit-hint">选择</view>
                <view class="review-field-picker" data-field="villainPosition" bindtap="openVoicePresetSelector">{{parsedVoice.villainPositionText || '-'}}</view>
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">对手类型</view>
                <view class="review-edit-hint">选择</view>
                <view class="review-field-picker" data-field="opponentType" bindtap="openVoicePresetSelector">{{parsedVoice.opponentTypeText || '-'}}</view>
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">当前底池</view>
                <view class="review-edit-hint">编辑</view>
                <input class="review-field-input" value="{{parsedVoice.potSize}}" data-field="potSize" bindinput="onParsedVoiceFieldInput" bindblur="commitParsedVoiceFieldValue" bindconfirm="commitParsedVoiceFieldValue" focus="{{parsedVoice.focusPotSize}}" placeholder="-" />
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">本手输赢</view>
                <view class="review-edit-hint">编辑</view>
                <input class="review-field-input" value="{{parsedVoice.currentProfitDisplayText}}" data-field="currentProfit" bindinput="onParsedVoiceFieldInput" bindblur="commitParsedVoiceFieldValue" bindconfirm="commitParsedVoiceFieldValue" focus="{{parsedVoice.focusCurrentProfit}}" placeholder="+ / -" />
              </view>
              <view class="review-voice-meta-item unified-field-card editable">
                <view class="kpi-label">对手昵称</view>
                <view class="review-edit-hint">编辑</view>
                <input class="review-field-input" value="{{parsedVoice.opponentName}}" data-field="opponentName" bindinput="onParsedVoiceFieldInput" bindblur="commitParsedVoiceFieldValue" bindconfirm="commitParsedVoiceFieldValue" focus="{{parsedVoice.focusOpponentName}}" placeholder="-" />
              </view>
