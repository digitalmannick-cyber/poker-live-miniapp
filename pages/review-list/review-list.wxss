.hero-picker-deck {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: none;
  overflow: visible;
}

.hero-picker-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-picker-card {
  width: 80rpx;
  height: 108rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10rpx 10rpx 12rpx;
  box-sizing: border-box;
  color: #ffffff;
  border: 1rpx solid transparent;
  opacity: 0.95;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.20);
}

.hero-picker-card.selected {
  transform: translateY(-2rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.24),
    0 0 0 2rpx rgba(0, 209, 255, 0.26);
  border-color: rgba(0, 209, 255, 0.38);
}

.quick-picked-card.replace-active {
  transform: translateY(-4rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.24),
    0 0 0 3rpx rgba(0, 209, 255, 0.42),
    0 10rpx 22rpx rgba(0, 209, 255, 0.18);
}

.hero-picker-card.disabled {
  opacity: 0.26;
}

.hero-picker-card-spade {
  background: linear-gradient(180deg, #585858, #373737);
}

.hero-picker-card-heart {
  background: linear-gradient(180deg, #cb1c00, #9b1000);
}

.hero-picker-card-diamond {
  background: linear-gradient(180deg, #3855ea, #2438b8);
}

.hero-picker-card-club {
  background: linear-gradient(180deg, #19cb40, #0da22c);
}

.hero-picker-rank {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-picker-suit {
  font-size: 30rpx;
  line-height: 1;
  align-self: flex-end;
}

.hero-picker-tools {
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
}

.picker-tool-main {
  flex: 1;
}

.selector-sheet {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 88rpx;
  bottom: calc(208rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(18, 23, 34, 0.98), rgba(7, 10, 16, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 22rpx 60rpx rgba(0,0,0,0.34);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.selector-option-list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.selector-option {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.10);
  color: rgba(255,255,255,0.82);
  box-sizing: border-box;
}

.selector-option.active {
  background: rgba(0, 209, 255, 0.16);
  border-color: rgba(0, 209, 255, 0.34);
  color: #ffffff;
}

.selector-option-label {
  font-size: 28rpx;
  font-weight: 800;
}

.review-ai-inline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.review-ai-verdict {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 209, 255, 0.12);
  border: 1rpx solid rgba(0, 209, 255, 0.22);
  color: rgba(0, 209, 255, 0.95);
  font-size: 22rpx;
  font-weight: 800;
}

.review-modal-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 8rpx;
}

.review-voice-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 88rpx;
  margin: 4rpx 0 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(0, 209, 255, 0.12);
  border: 1rpx solid rgba(0, 209, 255, 0.28);
  box-sizing: border-box;
}

.review-voice-entry-main {
  min-width: 0;
}

.review-voice-entry-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-voice-entry-desc {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.62);
  font-size: 21rpx;
  line-height: 1.35;
}

.review-voice-entry-action {
  flex-shrink: 0;
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 209, 255, 0.16);
  border: 1rpx solid rgba(0, 209, 255, 0.34);
  color: #00d1ff;
  font-size: 23rpx;
  font-weight: 900;
  box-sizing: border-box;
}

@media (max-width: 360px) {
  .hero-picker-card {
    width: 72rpx;
    height: 100rpx;
    padding: 9rpx 9rpx 10rpx;
  }
}
