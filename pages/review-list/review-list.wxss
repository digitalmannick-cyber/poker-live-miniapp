@import '../../app.wxss';

.review-filter-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 18rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.review-filter-strip-main {
  flex: 1 1 auto;
  min-width: 0;
}

.review-filter-strip-title {
  color: rgba(0, 209, 255, 0.96);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.review-filter-strip-summary {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.86);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-filter-button,
.review-filter-head-btn {
  flex: 0 0 auto;
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.78);
  font-size: 23rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.review-filter-head-btn.primary {
  border-color: rgba(0, 209, 255, 0.34);
  background: rgba(0, 209, 255, 0.16);
  color: rgba(0, 209, 255, 0.96);
}

.review-filter-modal {
  position: fixed;
  inset: 0;
  z-index: 20000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx calc(190rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.review-filter-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.68);
}

.review-filter-panel {
  position: relative;
  width: 100%;
  max-height: 58vh;
  padding: 26rpx 28rpx 30rpx;
  border-radius: 28rpx;
  background: rgba(11, 11, 15, 0.98);
  border: 1rpx solid rgba(255,255,255,0.14);
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.52);
  box-sizing: border-box;
  overflow: hidden;
}

.review-filter-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
  text-align: left;
}

.review-filter-title-wrap {
  flex: 1 1 auto;
  min-width: 0;
}

.review-filter-panel-title {
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.review-filter-head-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.review-filter-scroll {
  max-height: 40vh;
  padding-bottom: 10rpx;
}

.review-filter-block {
  display: grid;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.review-chip-wrap {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.review-chip-wrap.session {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.review-chip-wrap-tags {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.review-filter-pill {
  min-width: 0;
  height: 62rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 23rpx;
  line-height: 1.2;
}

.review-filter-pill text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-date-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.review-date-input {
  min-height: 66rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.88);
  font-size: 24rpx;
  font-weight: 700;
}

.review-sort-scroll {
  margin: 0 0 18rpx;
}

.review-sort-compact {
  display: flex;
  align-items: center;
  gap: 10rpx;
  white-space: nowrap;
}

.review-sort-label {
  flex: 0 0 auto;
  color: rgba(255,255,255,0.56);
  font-size: 22rpx;
  font-weight: 900;
}

.review-sort-chip {
  min-width: 112rpx;
  height: 54rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  display: inline-flex;
  gap: 6rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.13);
  color: rgba(255,255,255,0.72);
  font-size: 22rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.review-sort-chip.active {
  background: rgba(0, 209, 255, 0.13);
  border-color: rgba(0, 209, 255, 0.34);
  color: rgba(0, 209, 255, 0.96);
}

.review-sort-arrow {
  min-width: 18rpx;
  font-size: 24rpx;
  line-height: 1;
}

.review-swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 22rpx;
  margin-bottom: 14rpx;
}

.review-swipe-row .list-item {
  margin-bottom: 0;
}

.review-swipe-content {
  position: relative;
  z-index: 2;
  background: #15171d;
  transition: transform 160ms ease-out;
  will-change: transform;
}

.review-swipe-row.open .review-swipe-content {
  transform: translateX(-176rpx);
}

.review-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  width: 176rpx;
  display: none;
  grid-template-columns: repeat(2, 88rpx);
  overflow: hidden;
  border-radius: 0 22rpx 22rpx 0;
}

.review-swipe-row.open .review-swipe-actions {
  display: grid;
}

.review-swipe-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.review-swipe-action.edit {
  background: linear-gradient(180deg, #0aa8d6, #087ea5);
}

.review-swipe-action.delete {
  background: linear-gradient(180deg, #ef233c, #b80f24);
}

.review-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.review-hand-main {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  flex: 1 1 auto;
  gap: 8rpx;
  min-width: 0;
  overflow: visible;
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
}

.review-hand-main text {
  flex: 0 0 auto;
  white-space: nowrap;
}

.review-hero-inline .mini-card {
  width: 48rpx;
  height: 70rpx;
  padding: 8rpx 8rpx 9rpx;
  border-radius: 13rpx;
}

.review-hero-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
}

.review-hero-inline .mini-card .mini-card-rank {
  font-size: 31rpx;
}

.review-hero-inline .mini-card .mini-card-suit {
  font-size: 21rpx;
}

.review-profit {
  flex: 0 0 auto;
  min-width: 92rpx;
  padding: 8rpx 10rpx;
  border-radius: 15rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.position-chip {
  flex: 0 0 auto;
  height: 44rpx;
  min-width: 54rpx;
  padding: 0 12rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.90);
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.position-chip.pos-btn {
  border-color: rgba(0, 209, 255, 0.72);
  background: rgba(0, 209, 255, 0.10);
  box-shadow: inset 0 0 0 1rpx rgba(0, 209, 255, 0.16);
}

.position-chip.pos-sb {
  border-color: rgba(255, 84, 112, 0.74);
  background: rgba(255, 84, 112, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 84, 112, 0.16);
}

.position-chip.pos-bb {
  border-color: rgba(99, 230, 190, 0.72);
  background: rgba(99, 230, 190, 0.10);
  box-shadow: inset 0 0 0 1rpx rgba(99, 230, 190, 0.16);
}

.position-chip.pos-co {
  border-color: rgba(255, 189, 89, 0.76);
  background: rgba(255, 189, 89, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 189, 89, 0.16);
}

.position-chip.pos-hj {
  border-color: rgba(124, 92, 255, 0.74);
  background: rgba(124, 92, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(124, 92, 255, 0.16);
}

.position-chip.pos-lj {
  border-color: rgba(80, 138, 255, 0.74);
  background: rgba(80, 138, 255, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(80, 138, 255, 0.16);
}

.position-chip.pos-utg,
.position-chip.pos-utg1 {
  border-color: rgba(255, 121, 63, 0.76);
  background: rgba(255, 121, 63, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 121, 63, 0.16);
}

.position-chip.pos-str {
  border-color: rgba(237, 92, 255, 0.72);
  background: rgba(237, 92, 255, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(237, 92, 255, 0.16);
}

.position-chip.pos-unknown {
  border-color: rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.05);
}

.review-action-line {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.20);
  color: rgba(0, 209, 255, 0.92);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
}

.review-action-line.detail {
  margin-top: 8rpx;
}

.review-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 12rpx;
}

.review-meta-row .small {
  min-width: 0;
}

.review-ai-badge {
  flex: 0 0 auto;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: rgba(0, 209, 255, 0.95);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.22);
  white-space: nowrap;
}

.review-ai-badge.loading {
  color: rgba(255, 216, 107, 0.96);
  background: rgba(255, 216, 107, 0.10);
  border-color: rgba(255, 216, 107, 0.22);
}

.review-ai-badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 216, 107, 0.96);
  animation: review-ai-pulse 900ms ease-in-out infinite;
}

.review-board-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
  margin-left: 0;
}

.mini-card-board {
  width: 39rpx;
  height: 56rpx;
  padding: 5rpx 5rpx 6rpx;
  border-radius: 9rpx;
}

.mini-card-rank-board {
  font-size: 23rpx;
}

.mini-card-suit-board {
  font-size: 16rpx;
}

.review-modal {
  position: fixed;
  inset: 0;
  z-index: 15000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
}

.review-modal-panel {
  position: relative;
  width: 100%;
  max-height: 88vh;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(11, 11, 15, 0.98);
  border-top: 1rpx solid rgba(255,255,255,0.14);
  box-sizing: border-box;
  overflow: auto;
}

.review-modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.review-modal-header-redesign {
  align-items: center;
}

.review-detail-title-wrap {
  min-width: 0;
}

.review-detail-eyebrow {
  color: rgba(0, 209, 255, 0.9);
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0;
  margin-bottom: 6rpx;
}

.review-detail-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-hero-summary {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(230, 0, 18, 0.18), rgba(255,255,255,0.055) 38%, rgba(0, 209, 255, 0.08));
  border: 1rpx solid rgba(255,255,255,0.14);
}

.review-hero-left {
  flex: 1 1 auto;
  min-width: 0;
  display: grid;
  gap: 10rpx;
}

.review-detail-hero-cards .mini-card {
  width: 62rpx;
  height: 90rpx;
  border-radius: 16rpx;
}

.review-position-line {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.review-hero-result {
  flex: 0 0 auto;
  display: grid;
  align-content: center;
  justify-items: end;
  gap: 10rpx;
}

.review-detail-profit {
  min-width: 156rpx;
  font-size: 30rpx;
}

.review-result-bb {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.13);
  color: rgba(255,255,255,0.84);
  font-size: 23rpx;
  font-weight: 800;
}

.review-modal-header-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-top-action {
  min-width: 132rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.86);
  font-size: 24rpx;
  font-weight: 700;
}

.review-top-action.voice {
  border-color: rgba(230, 0, 18, 0.30);
  color: #ffffff;
  background: rgba(230, 0, 18, 0.18);
}

.review-top-action.voice.recording {
  border-color: rgba(248, 113, 113, 0.32);
  background: rgba(127, 29, 29, 0.56);
  color: #fee2e2;
}

.review-top-action.close {
  min-width: 96rpx;
}

.review-detail-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
  margin-bottom: 20rpx;
}

.review-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.review-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.review-info-item {
  min-width: 0;
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.review-detail-block {
  margin-top: 18rpx;
}

.review-detail-block.no-top {
  margin-top: 0;
}

.review-detail-text {
  margin-top: 8rpx;
  color: #f8fafc;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.review-tag-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  max-width: 100%;
  margin-top: 8rpx;
}

.review-hand-tag {
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.28);
  color: rgba(0, 209, 255, 0.95);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.review-agent-card {
  border-color: rgba(0, 209, 255, 0.18);
  background: linear-gradient(180deg, rgba(0, 209, 255, 0.055), rgba(255,255,255,0.035));
}

.review-agent-provider {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(0, 209, 255, 0.95);
  font-size: 20rpx;
  font-weight: 900;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.22);
}

.review-agent-provider.failed {
  color: rgba(255, 107, 107, 0.96);
  background: rgba(255, 107, 107, 0.12);
  border-color: rgba(255, 107, 107, 0.26);
}

.review-agent-answer {
  margin-top: 10rpx;
  padding: 18rpx 20rpx;
  border-left: 6rpx solid rgba(0, 209, 255, 0.62);
  border-radius: 16rpx;
  background: rgba(0, 209, 255, 0.07);
  border-top: 1rpx solid rgba(0, 209, 255, 0.16);
  border-right: 1rpx solid rgba(0, 209, 255, 0.12);
  border-bottom: 1rpx solid rgba(0, 209, 255, 0.12);
  white-space: pre-wrap;
}

.review-agent-pending-card {
  border-color: rgba(255, 216, 107, 0.18);
  background: linear-gradient(180deg, rgba(255, 216, 107, 0.055), rgba(255,255,255,0.035));
}

.review-agent-pending-body {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 216, 107, 0.07);
  border: 1rpx solid rgba(255, 216, 107, 0.18);
}

.review-agent-spinner {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 216, 107, 0.22);
  border-top-color: rgba(255, 216, 107, 0.96);
  animation: review-ai-spin 0.8s linear infinite;
  flex: 0 0 auto;
}

.review-agent-pending-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.3;
}

.review-agent-pending-text {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.64);
  font-size: 22rpx;
  line-height: 1.42;
}

.review-agent-failed-card {
  border-color: rgba(255, 107, 107, 0.20);
  background: linear-gradient(180deg, rgba(255, 107, 107, 0.055), rgba(255,255,255,0.035));
}

.review-agent-failed-text {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
  line-height: 1.45;
  background: rgba(255, 107, 107, 0.07);
  border: 1rpx solid rgba(255, 107, 107, 0.16);
}

.review-agent-section {
  margin-top: 18rpx;
}

.review-agent-section > .kpi-label {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
  box-sizing: border-box;
}

.review-agent-section-verdict > .kpi-label,
.review-agent-section-takeaway > .kpi-label {
  color: rgba(0, 209, 255, 0.96);
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.22);
}

.review-agent-section-street > .kpi-label {
  color: rgba(41, 255, 178, 0.94);
  background: rgba(41, 255, 178, 0.10);
  border: 1rpx solid rgba(41, 255, 178, 0.20);
}

.review-agent-section-good > .kpi-label {
  color: rgba(68, 255, 163, 0.94);
  background: rgba(68, 255, 163, 0.10);
  border: 1rpx solid rgba(68, 255, 163, 0.20);
}

.review-agent-section-issue > .kpi-label {
  color: rgba(255, 190, 92, 0.96);
  background: rgba(255, 190, 92, 0.11);
  border: 1rpx solid rgba(255, 190, 92, 0.24);
}

.review-agent-section-mistake > .kpi-label {
  color: rgba(255, 107, 107, 0.98);
  background: rgba(255, 107, 107, 0.12);
  border: 1rpx solid rgba(255, 107, 107, 0.26);
}

.review-agent-section-optimize > .kpi-label {
  color: rgba(111, 190, 255, 0.98);
  background: rgba(111, 190, 255, 0.11);
  border: 1rpx solid rgba(111, 190, 255, 0.24);
}

.review-agent-section-adjust > .kpi-label {
  color: rgba(255, 216, 107, 0.96);
  background: rgba(255, 216, 107, 0.11);
  border: 1rpx solid rgba(255, 216, 107, 0.24);
}

.review-agent-section-training > .kpi-label {
  color: rgba(151, 235, 142, 0.96);
  background: rgba(151, 235, 142, 0.10);
