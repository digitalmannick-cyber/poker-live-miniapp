  padding: 36rpx 32rpx 34rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background:
    linear-gradient(135deg, rgba(237, 0, 24, 0.16) 0 14%, transparent 14% 100%),
