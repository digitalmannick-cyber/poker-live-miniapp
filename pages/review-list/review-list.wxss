  inset: 0;
  background:
    repeating-linear-gradient(135deg, rgba(255,255,255,0.035) 0 2rpx, transparent 2rpx 18rpx),
    linear-gradient(90deg, rgba(237, 0, 24, 0.10), transparent 44%, rgba(0, 209, 255, 0.08));
