.review-ai-card {
  position: relative;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.18), transparent 34%),
    linear-gradient(180deg, rgba(20,20,28,0.98), rgba(7,7,12,0.98));
  box-shadow: 10rpx 10rpx 0 rgba(230,0,18,0.16);
  box-sizing: border-box;
  overflow: hidden;
}

.review-ai-card-sheet {
