  padding: 22rpx 0 120rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  overflow: visible;
}

.review-ai-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: -42rpx;
  width: 230rpx;
  height: 68rpx;
  transform: skew(-28deg);
  background: #e60012;
  box-shadow: -42rpx 42rpx 0 rgba(255,255,255,0.08);
  pointer-events: none;
}

.review-ai-card-sheet::before {
  display: none;
}

.review-ai-card-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.review-ai-kicker {
  color: #00d1ff;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.1;
}

.review-ai-title {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.review-ai-card-provider {
  position: relative;
  z-index: 1;
  max-width: 180rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #07070b;
  background: #00d1ff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-ai-fact-main {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  color: #07070b;
  background: #ffffff;
  box-shadow: 10rpx 10rpx 0 #e60012;
}

.review-ai-fact-label {
  color: #e60012;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-ai-fact-value {
  margin-top: 8rpx;
  color: #07070b;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.28;
}

.review-ai-meta-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-ai-meta-cell {
  min-height: 96rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.065);
  box-sizing: border-box;
}

.review-ai-meta-label {
  color: rgba(255,255,255,0.54);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.review-ai-meta-value {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.3;
  word-break: break-word;
}

.review-ai-card-verdict {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(230,0,18,0.72);
  background:
    linear-gradient(135deg, rgba(230,0,18,0.44), rgba(230,0,18,0.08)),
    rgba(14,14,20,0.95);
  overflow: hidden;
}

.review-ai-card-verdict::after {
  content: 'CHECK';
  position: absolute;
  right: -8rpx;
  bottom: -14rpx;
  color: rgba(255,255,255,0.07);
  font-size: 76rpx;
  font-weight: 900;
  line-height: 1;
  transform: skew(-12deg);
}

.review-ai-slash-label {
  display: inline-flex;
  height: 34rpx;
  padding: 0 18rpx;
  align-items: center;
  color: #07070b;
  background: #ffd400;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 34rpx;
  transform: skew(-12deg);
}

.review-ai-card-verdict-text {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.46;
}

.review-ai-takeaway {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 8rpx 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(0,209,255,0.38);
  background: rgba(0,209,255,0.09);
  box-sizing: border-box;
}

.review-ai-takeaway::before {
  content: '';
  width: 8rpx;
  border-radius: 999rpx;
  background: #00d1ff;
  box-shadow: 0 0 22rpx rgba(0,209,255,0.78);
}

.review-ai-takeaway-title {
  color: #00d1ff;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-ai-takeaway-text {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.9);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.5;
}

.review-ai-street-panel {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.055);
  overflow: hidden;
}

.review-ai-street-panel::before {
  content: '';
  position: absolute;
  top: 34rpx;
  bottom: 34rpx;
  left: 38rpx;
  width: 4rpx;
  background: linear-gradient(180deg, #00d1ff, #ffd400, #19d66b, rgba(255,255,255,0.28));
  opacity: 0.9;
}

.review-ai-street-row {
  position: relative;
  display: grid;
  grid-template-columns: 58rpx 1fr;
  gap: 14rpx;
  min-height: 150rpx;
  padding: 22rpx 20rpx 22rpx 10rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.09);
  box-sizing: border-box;
}

.review-ai-street-row:last-child {
  border-bottom: 0;
}

.review-ai-street-row::before {
  content: '';
  position: relative;
  z-index: 1;
  grid-row: 1 / span 3;
  align-self: start;
  justify-self: center;
  width: 30rpx;
  height: 30rpx;
  margin-top: 4rpx;
  border-radius: 50%;
  border: 6rpx solid #08080d;
  background: #00d1ff;
  box-shadow: 0 0 0 3rpx rgba(255,255,255,0.34), 0 0 24rpx rgba(0,209,255,0.48);
}

.review-ai-street-row.is-error::before {
  background: #e60012;
  box-shadow: 0 0 0 3rpx rgba(230,0,18,0.38), 0 0 24rpx rgba(230,0,18,0.54);
}

.review-ai-street-row.is-optimize::before {
  background: #ffd400;
  box-shadow: 0 0 0 3rpx rgba(255,212,0,0.42), 0 0 24rpx rgba(255,212,0,0.54);
}

.review-ai-street-head,
.review-ai-street-point {
  grid-column: 2;
}

.review-ai-street-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.review-ai-street-name {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-ai-street-badge {
  flex: 0 0 auto;
  padding: 7rpx 14rpx;
  border-radius: 10rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}

.review-ai-street-badge.error {
  background: #e60012;
}

.review-ai-street-badge.optimize {
  color: #07070b;
  background: #ffd400;
}

.review-ai-street-point {
  margin-top: 14rpx;
  padding-left: 16rpx;
  padding-bottom: 4rpx;
  border-left: 4rpx solid rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.84);
  font-size: 25rpx;
  line-height: 1.55;
}

.review-ai-insight-stack {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.review-ai-insight-group {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.review-ai-insight-card {
  position: relative;
  min-height: 170rpx;
  padding: 20rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
  background: rgba(0,0,0,0.24);
  box-sizing: border-box;
  overflow: hidden;
}

.review-ai-insight-card.full {
