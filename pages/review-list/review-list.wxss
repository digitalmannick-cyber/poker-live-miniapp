@import '../../app.wxss';

.review-filter-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 18rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.review-filter-strip-main {
  flex: 1 1 auto;
  min-width: 0;
}

.review-filter-strip-title {
  color: rgba(0, 209, 255, 0.96);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.review-filter-strip-summary {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.86);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-filter-button,
.review-filter-head-btn {
  flex: 0 0 auto;
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.78);
  font-size: 23rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.review-filter-head-btn.primary {
  border-color: rgba(0, 209, 255, 0.34);
  background: rgba(0, 209, 255, 0.16);
  color: rgba(0, 209, 255, 0.96);
}

.review-replay-modal {
  position: fixed;
  inset: 0;
  z-index: 43000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 24rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.review-replay-mask {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 18%, rgba(0, 209, 255, 0.14), transparent 36%),
    rgba(0, 0, 0, 0.76);
}

.review-replay-panel {
  position: relative;
  width: 100%;
  max-width: 720rpx;
  box-sizing: border-box;
}

.review-filter-modal {
  position: fixed;
  inset: 0;
  z-index: 20000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx calc(190rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.review-filter-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.68);
}

.review-filter-panel {
  position: relative;
  width: 100%;
  max-height: 58vh;
  padding: 26rpx 28rpx 30rpx;
  border-radius: 28rpx;
  background: rgba(11, 11, 15, 0.98);
  border: 1rpx solid rgba(255,255,255,0.14);
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.52);
  box-sizing: border-box;
  overflow: hidden;
}

.review-filter-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
  text-align: left;
}

.review-filter-title-wrap {
  flex: 1 1 auto;
  min-width: 0;
}

.review-filter-panel-title {
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.review-filter-head-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.review-filter-scroll {
  max-height: 40vh;
  padding-bottom: 10rpx;
}

.review-filter-block {
  display: grid;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.review-chip-wrap {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.review-chip-wrap.session {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.review-chip-wrap-tags {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.review-filter-pill {
  min-width: 0;
  height: 62rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 23rpx;
  line-height: 1.2;
}

.review-filter-pill text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-date-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.review-date-input {
  min-height: 66rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.88);
  font-size: 24rpx;
  font-weight: 700;
}

.review-sort-scroll {
  margin: 0 0 18rpx;
}

.review-sort-compact {
  display: flex;
  align-items: center;
  gap: 10rpx;
  white-space: nowrap;
}

.review-sort-label {
  flex: 0 0 auto;
  color: rgba(255,255,255,0.56);
  font-size: 22rpx;
  font-weight: 900;
}

.review-sort-chip {
  min-width: 112rpx;
  height: 54rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  display: inline-flex;
  gap: 6rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.13);
  color: rgba(255,255,255,0.72);
  font-size: 22rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.review-sort-chip.active {
  background: rgba(0, 209, 255, 0.13);
  border-color: rgba(0, 209, 255, 0.34);
  color: rgba(0, 209, 255, 0.96);
}

.review-sort-arrow {
  min-width: 18rpx;
  font-size: 24rpx;
  line-height: 1;
}

.review-swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 22rpx;
  margin-bottom: 14rpx;
}

.review-swipe-row .list-item {
  margin-bottom: 0;
}

.review-swipe-content {
  position: relative;
  z-index: 2;
  background: #15171d;
  transition: transform 160ms ease-out;
  will-change: transform;
}

.review-swipe-row.open .review-swipe-content {
  transform: translateX(-176rpx);
}

.review-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  width: 176rpx;
  display: none;
  grid-template-columns: repeat(2, 88rpx);
  overflow: hidden;
  border-radius: 0 22rpx 22rpx 0;
}

.review-swipe-row.open .review-swipe-actions {
  display: grid;
}

.review-swipe-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.review-swipe-action.edit {
  background: linear-gradient(180deg, #0aa8d6, #087ea5);
}

.review-swipe-action.delete {
  background: linear-gradient(180deg, #ef233c, #b80f24);
}

.review-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.review-hand-main {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  flex: 1 1 auto;
  gap: 8rpx;
  min-width: 0;
  overflow: visible;
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
}

.review-hand-main text {
  flex: 0 0 auto;
  white-space: nowrap;
}

.review-hero-inline .mini-card {
  width: 48rpx;
  height: 70rpx;
  padding: 8rpx 8rpx 9rpx;
  border-radius: 13rpx;
}

.review-hero-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
}

.review-hero-inline .mini-card .mini-card-rank {
  font-size: 31rpx;
}

.review-hero-inline .mini-card .mini-card-suit {
  font-size: 21rpx;
}

.review-profit {
  flex: 0 0 auto;
  min-width: 92rpx;
  padding: 8rpx 10rpx;
  border-radius: 15rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.review-result-actions {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.review-comment-trigger {
  position: relative;
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 0;
  box-sizing: border-box;
}

.review-comment-trigger.has-comments {
  background: transparent;
}

.review-comment-icon-img {
  width: 42rpx;
  height: 42rpx;
  display: block;
}

.review-comment-count {
  position: absolute;
  right: -8rpx;
  top: -10rpx;
  min-width: 24rpx;
  height: 24rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 17rpx;
  line-height: 1;
  font-weight: 1000;
  background: #e60012;
  border: 1rpx solid rgba(255,255,255,0.24);
  box-sizing: border-box;
}

.position-chip {
  flex: 0 0 auto;
  height: 44rpx;
  min-width: 54rpx;
  padding: 0 12rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.90);
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.position-chip.pos-btn {
  border-color: rgba(0, 209, 255, 0.72);
  background: rgba(0, 209, 255, 0.10);
  box-shadow: inset 0 0 0 1rpx rgba(0, 209, 255, 0.16);
}

.position-chip.pos-sb {
  border-color: rgba(255, 84, 112, 0.74);
  background: rgba(255, 84, 112, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 84, 112, 0.16);
}

.position-chip.pos-bb {
  border-color: rgba(99, 230, 190, 0.72);
  background: rgba(99, 230, 190, 0.10);
  box-shadow: inset 0 0 0 1rpx rgba(99, 230, 190, 0.16);
}

.position-chip.pos-co {
  border-color: rgba(255, 189, 89, 0.76);
  background: rgba(255, 189, 89, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 189, 89, 0.16);
}

.position-chip.pos-hj {
  border-color: rgba(124, 92, 255, 0.74);
  background: rgba(124, 92, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(124, 92, 255, 0.16);
}

.position-chip.pos-lj {
  border-color: rgba(80, 138, 255, 0.74);
  background: rgba(80, 138, 255, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(80, 138, 255, 0.16);
}

.position-chip.pos-utg,
.position-chip.pos-utg1 {
  border-color: rgba(255, 121, 63, 0.76);
  background: rgba(255, 121, 63, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 121, 63, 0.16);
}

.position-chip.pos-str {
  border-color: rgba(237, 92, 255, 0.72);
  background: rgba(237, 92, 255, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(237, 92, 255, 0.16);
}

.position-chip.pos-unknown {
  border-color: rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.05);
}

.review-action-line {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.20);
  color: rgba(0, 209, 255, 0.92);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
}

.review-action-line.detail {
  margin-top: 8rpx;
}

.review-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 12rpx;
}

.review-meta-row .small {
  min-width: 0;
}

.review-meta-actions {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.review-replay-trigger {
  flex: 0 0 auto;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 209, 255, 0.30);
  background: rgba(0, 209, 255, 0.10);
  color: rgba(84, 234, 255, 0.96);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 14rpx rgba(0, 209, 255, 0.08);
}

.review-replay-icon {
  width: 0;
  height: 0;
  margin-left: 2rpx;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid rgba(84, 234, 255, 0.96);
}

.review-replay-trigger:active {
  background: rgba(0, 209, 255, 0.18);
  transform: scale(0.94);
}

.review-ai-badge {
  flex: 0 0 auto;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: rgba(0, 209, 255, 0.95);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.22);
  white-space: nowrap;
}

.review-ai-badge.loading {
  color: rgba(255, 216, 107, 0.96);
  background: rgba(255, 216, 107, 0.10);
  border-color: rgba(255, 216, 107, 0.22);
}

.review-ai-badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 216, 107, 0.96);
  animation: review-ai-pulse 900ms ease-in-out infinite;
}

.review-board-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
  margin-left: 0;
}

.mini-card-board {
  width: 39rpx;
  height: 56rpx;
  padding: 5rpx 5rpx 6rpx;
  border-radius: 9rpx;
}

.mini-card-rank-board {
  font-size: 23rpx;
}

.mini-card-suit-board {
  font-size: 16rpx;
}

.review-modal {
  position: fixed;
  inset: 0;
  z-index: 15000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
}

.review-modal-panel {
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 88vh;
  max-height: 88vh;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(11, 11, 15, 0.98);
  border-top: 1rpx solid rgba(255,255,255,0.14);
  box-sizing: border-box;
  overflow: auto;
}

.review-choice-modal {
  position: fixed;
  inset: 0;
  z-index: 17000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-choice-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.74);
  backdrop-filter: blur(8rpx);
}

.review-choice-panel {
  position: relative;
  width: 100%;
  padding: 24rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(8, 9, 13, 0.98);
  border-top: 1rpx solid rgba(255,255,255,0.14);
  box-sizing: border-box;
}

.review-choice-handle {
  width: 136rpx;
  height: 10rpx;
  margin: 0 auto 28rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
}

.review-choice-title {
  font-size: 34rpx;
  font-weight: 950;
  color: #ffffff;
}

.review-choice-sub {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.62);
  font-size: 24rpx;
  line-height: 1.45;
}

.review-choice-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.review-choice-card {
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.06);
  box-sizing: border-box;
}

.review-choice-card.primary {
  color: #111217;
  background: linear-gradient(135deg, #ffffff, #dfe3ea);
  border-color: rgba(255,255,255,0.54);
}

.review-choice-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(230, 0, 18, 0.88);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 950;
}

.review-choice-card.primary .review-choice-icon {
  background: #e60012;
}

.review-choice-name {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 920;
}

.review-choice-desc {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.56);
  font-size: 22rpx;
}

.review-choice-card.primary .review-choice-desc {
  color: rgba(17,18,23,0.62);
}

.review-choice-cancel {
  height: 76rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.72);
  font-size: 26rpx;
  font-weight: 800;
}

.review-comment-modal {
  position: fixed;
  inset: 0;
  z-index: 16000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-comment-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  backdrop-filter: blur(8rpx);
}

.review-comment-panel {
  position: relative;
  width: 100%;
  max-height: 78vh;
  padding: 28rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.18), transparent 240rpx),
    rgba(11, 11, 15, 0.98);
  border-top: 1rpx solid rgba(255,255,255,0.14);
  box-sizing: border-box;
  overflow: hidden;
}

.review-comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.review-comment-close {
  flex: 0 0 auto;
  padding: 14rpx 22rpx;
  border-radius: 16rpx;
  color: rgba(255,255,255,0.72);
  font-size: 24rpx;
  font-weight: 850;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.review-comment-list {
  display: grid;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.review-comment-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.review-comment-text {
  color: rgba(255,255,255,0.90);
  font-size: 27rpx;
  line-height: 1.42;
  font-weight: 700;
  word-break: break-word;
}

.review-comment-time {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.42);
  font-size: 21rpx;
  font-weight: 700;
}

.review-comment-empty {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  color: rgba(255,255,255,0.45);
  font-size: 25rpx;
  background: rgba(255,255,255,0.035);
  border: 1rpx dashed rgba(255,255,255,0.14);
}

.review-comment-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.4;
  background: rgba(0,0,0,0.24);
  border: 2rpx solid rgba(255,255,255,0.14);
  box-sizing: border-box;
}

.review-comment-save {
  min-height: 86rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.07);
  border: 2rpx solid rgba(255,255,255,0.14);
}

.review-comment-save {
  border-color: rgba(230, 0, 18, 0.86);
  background: linear-gradient(135deg, rgba(230, 0, 18, 0.58), rgba(96, 0, 10, 0.94));
}

.review-comment-save-inline {
  flex: 0 0 auto;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.review-comment-save.saving {
  opacity: 0.72;
}

.review-modal-header {
  flex: 0 0 auto;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.review-modal-header-redesign {
  align-items: center;
}

.review-detail-title-wrap {
  min-width: 0;
}

.review-detail-eyebrow {
