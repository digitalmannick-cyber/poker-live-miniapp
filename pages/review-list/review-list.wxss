@import '../../app.wxss';

.review-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.review-hand-main {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  flex: 1 1 auto;
  gap: 8rpx;
  min-width: 0;
  overflow: visible;
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
}

.review-hand-main text {
  flex: 0 0 auto;
  white-space: nowrap;
}

.review-hero-inline .mini-card {
  width: 48rpx;
  height: 70rpx;
  padding: 8rpx 8rpx 9rpx;
  border-radius: 13rpx;
}

.review-hero-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
}

.review-hero-inline .mini-card .mini-card-rank {
  font-size: 31rpx;
}

.review-hero-inline .mini-card .mini-card-suit {
  font-size: 21rpx;
}

.review-profit {
  flex: 0 0 auto;
  min-width: 92rpx;
  padding: 8rpx 10rpx;
  border-radius: 15rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.position-chip {
  flex: 0 0 auto;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.90);
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.review-action-line {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.20);
  color: rgba(0, 209, 255, 0.92);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
}

.review-meta-row {
  margin-top: 12rpx;
}

.review-board-inline {
  flex: 0 0 auto;
  flex-wrap: nowrap;
  margin-left: 0;
}

.mini-card-board {
  width: 39rpx;
  height: 56rpx;
  padding: 5rpx 5rpx 6rpx;
  border-radius: 9rpx;
}

.mini-card-rank-board {
  font-size: 23rpx;
}

.mini-card-suit-board {
  font-size: 16rpx;
}

.review-modal {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
}

.review-modal-panel {
  position: relative;
  width: 100%;
  max-height: 88vh;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(11, 11, 15, 0.98);
  border-top: 1rpx solid rgba(255,255,255,0.14);
  box-sizing: border-box;
  overflow: auto;
}

.review-modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.review-modal-header-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-top-action {
  min-width: 132rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.86);
  font-size: 24rpx;
  font-weight: 700;
}

.review-top-action.voice {
  border-color: rgba(230, 0, 18, 0.30);
  color: #ffffff;
  background: rgba(230, 0, 18, 0.18);
}

.review-top-action.voice.recording {
  border-color: rgba(248, 113, 113, 0.32);
  background: rgba(127, 29, 29, 0.56);
  color: #fee2e2;
}

.review-top-action.close {
  min-width: 96rpx;
}

.review-detail-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
  margin-bottom: 20rpx;
}

.review-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.review-detail-block {
  margin-top: 18rpx;
}

.review-detail-text {
  margin-top: 8rpx;
  color: #f8fafc;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.review-board-wrap {
  display: grid;
  gap: 0;
}

.review-voice-card-line {
  display: grid;
  gap: 10rpx;
}

.review-action-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.review-action-row:last-child {
  border-bottom: none;
}

.review-action-title {
  color: #f8fafc;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.45;
}

.review-voice-head {
  display: grid;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.review-voice-textarea {
  margin-top: 12rpx;
  min-height: 220rpx;
}

.review-voice-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.review-voice-preview {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.review-modal-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 8rpx;
}
