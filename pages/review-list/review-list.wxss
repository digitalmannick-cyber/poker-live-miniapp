}

.review-ai-insight-card.good {
  border-color: rgba(25,214,107,0.52);
  box-shadow: inset 8rpx 0 0 #19d66b;
}

.review-ai-insight-card.info {
  border-color: rgba(0,209,255,0.52);
  box-shadow: inset 8rpx 0 0 #00d1ff;
}

.review-ai-insight-index {
  position: absolute;
  right: 12rpx;
  bottom: -18rpx;
  color: rgba(255,255,255,0.06);
  font-size: 78rpx;
  font-weight: 900;
  line-height: 1;
}

.review-ai-insight-title {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.25;
}

.review-ai-insight-title::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 3rpx;
  background: currentColor;
  transform: rotate(45deg);
}

.review-ai-insight-text,
.review-ai-insight-point {
  position: relative;
  z-index: 1;
  color: rgba(255,255,255,0.82);
  font-size: 23rpx;
  line-height: 1.48;
}

.review-ai-insight-text {
  margin-top: 12rpx;
}

.review-ai-wave-mark {
  color: #ffffff;
  text-decoration-line: underline;
  text-decoration-style: wavy;
  text-decoration-color: #ff3045;
  text-decoration-thickness: 3rpx;
  text-underline-offset: 7rpx;
}

.review-ai-insight-point {
  display: grid;
  grid-template-columns: 10rpx 1fr;
  gap: 14rpx;
  margin-top: 12rpx;
}

.review-ai-insight-point::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.review-ai-fallback-text,
.review-ai-missing {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  color: rgba(255,255,255,0.84);
  font-size: 25rpx;
  line-height: 1.5;
  border: 1rpx solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.055);
}

.review-ai-sheet-modal {
  position: fixed;
  inset: 0;
  z-index: 44000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.review-ai-sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.62);
  backdrop-filter: blur(6rpx);
}

.review-ai-sheet-panel {
  position: relative;
  width: 100%;
  height: 75vh;
  max-height: 75vh;
  border-radius: 32rpx 32rpx 0 0;
  border-top: 2rpx solid rgba(255,255,255,0.18);
  background:
    linear-gradient(115deg, rgba(230,0,18,0.18), transparent 32%),
    linear-gradient(180deg, #15151d, #08080d);
  box-shadow: 0 -28rpx 90rpx rgba(0,0,0,0.68);
  overflow: hidden;
}

.review-ai-sheet-panel::before {
  content: '';
  position: absolute;
  top: 0;
  right: -34rpx;
  width: 270rpx;
  height: 92rpx;
  transform: skew(-28deg);
  background: #e60012;
  box-shadow: -42rpx 42rpx 0 rgba(255,255,255,0.08);
}

.review-ai-sheet-handle {
  position: absolute;
  top: 12rpx;
  left: 50%;
  width: 76rpx;
  height: 8rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: rgba(255,255,255,0.34);
  z-index: 2;
}

.review-ai-sheet-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 34rpx 28rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.10);
  box-sizing: border-box;
}

.review-ai-sheet-kicker {
  color: #00d1ff;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.1;
}

.review-ai-sheet-title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.review-ai-sheet-close {
  position: relative;
  z-index: 2;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  background: rgba(0,0,0,0.26);
  border: 1rpx solid rgba(255,255,255,0.22);
}

.review-ai-sheet-scroll {
  position: relative;
  z-index: 1;
  height: calc(75vh - 132rpx);
  padding: 0 24rpx;
  box-sizing: border-box;
}

.review-ai-sheet-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 14rpx;
  padding: 18rpx 24rpx calc(22rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent, rgba(6,6,10,0.96) 24%);
  box-sizing: border-box;
}

.review-ai-sheet-btn {
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.18);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.review-ai-sheet-btn::after {
  border: none;
}

.review-ai-sheet-btn.primary {
  color: #07070b;
  background: #ffd400;
  border-color: #ffd400;
  box-shadow: 7rpx 7rpx 0 #e60012;
}

@media (max-width: 420px) {
  .review-ai-insight-group,
  .review-ai-meta-grid {
    grid-template-columns: 1fr;
  }
}

@keyframes review-ai-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes review-ai-pulse {
  0%, 100% {
    opacity: 0.35;
    transform: scale(0.82);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

