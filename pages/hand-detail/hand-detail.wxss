@import '../../app.wxss';

.full-span {
  grid-column: span 2;
}

.board-editor-list {
  display: grid;
  gap: 14rpx;
}

.board-editor-item {
  display: grid;
  gap: 10rpx;
}

.board-editor-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.68);
}

.board-editor-trigger {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.16);
  box-sizing: border-box;
}

.hero-editor-trigger {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.16);
  box-sizing: border-box;
}

.preset-trigger {
  justify-content: flex-start;
}

.readonly-display {
  color: rgba(255,255,255,0.82);
}

.board-picker-modal {
  position: fixed;
  inset: 0;
  z-index: 1200;
}

.board-picker-mask {
  position: absolute;
  inset: 0;
  background: rgba(4, 6, 10, 0.74);
  backdrop-filter: blur(10rpx);
}

.board-picker-panel {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx;
  padding: 20rpx 14rpx 18rpx;
  background: linear-gradient(180deg, rgba(18, 23, 34, 0.98), rgba(7, 10, 16, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 22rpx 60rpx rgba(0,0,0,0.34);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.board-picker-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.board-picker-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.picker-close-btn {
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.82);
  font-size: 24rpx;
}

.picker-close-btn::after {
  border: none;
}

.hero-picked-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
}

.hero-picked-center {
  min-height: 112rpx;
  justify-content: center;
}

.edit-mode-card {
  border-color: rgba(0, 209, 255, 0.22);
  background: rgba(0, 209, 255, 0.07);
}

.quick-picked-card {
  width: 72rpx;
  height: 104rpx;
  border-radius: 20rpx;
  padding: 12rpx 10rpx 12rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.26),
    0 12rpx 24rpx rgba(0,0,0,0.18);
}

.quick-picked-rank {
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1;
}

.quick-picked-suit {
  font-size: 30rpx;
  line-height: 1;
  margin: 0;
}

.review-board-card-editable {
  position: relative;
}

.review-board-card-editable:active {
  transform: translateY(-3rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.24),
    0 0 0 3rpx rgba(0, 209, 255, 0.36);
}

.quick-picked-card.replace-active {
  transform: translateY(-4rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.24),
    0 0 0 3rpx rgba(0, 209, 255, 0.42),
    0 10rpx 22rpx rgba(0, 209, 255, 0.18);
}

.hero-picker-deck {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
  min-height: 0;
  overflow: auto;
}

.hero-picker-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-picker-card {
  width: 80rpx;
  height: 108rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10rpx 10rpx 12rpx;
  box-sizing: border-box;
  color: #ffffff;
  border: 1rpx solid transparent;
  opacity: 0.95;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.20);
}

.hero-picker-card.selected {
  transform: translateY(-2rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.24),
    0 0 0 2rpx rgba(0, 209, 255, 0.26);
  border-color: rgba(0, 209, 255, 0.38);
}

.hero-picker-card.disabled {
  opacity: 0.26;
}

.hero-picker-card-spade {
  background: linear-gradient(180deg, #585858, #373737);
}

.hero-picker-card-heart {
  background: linear-gradient(180deg, #cb1c00, #9b1000);
}

.hero-picker-card-diamond {
  background: linear-gradient(180deg, #3855ea, #2438b8);
}

.hero-picker-card-club {
  background: linear-gradient(180deg, #19cb40, #0da22c);
}

.hero-picker-rank {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-picker-suit {
  font-size: 30rpx;
  line-height: 1;
  align-self: flex-end;
  margin: 0;
}

.hero-picker-tools {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  flex-shrink: 0;
}

.selector-sheet {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 88rpx;
  bottom: calc(208rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(18, 23, 34, 0.98), rgba(7, 10, 16, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 22rpx 60rpx rgba(0,0,0,0.34);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.selector-option-list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.selector-option {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.10);
  color: rgba(255,255,255,0.82);
  box-sizing: border-box;
}

.selector-option.active {
  background: rgba(0, 209, 255, 0.16);
  border-color: rgba(0, 209, 255, 0.34);
  color: #ffffff;
}

.selector-option-label {
  font-size: 28rpx;
  font-weight: 800;
}

.street-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.street-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.street-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #ffffff;
}

.compact-grid {
  gap: 16rpx;
}

.compact-input {
  min-height: 84rpx;
}

.analysis-textarea {
  min-height: 156rpx;
}

.inline-note {
  margin-top: 10rpx;
}

.picker-tool-main {
  flex: 1;
}

@media (max-width: 360px) {
  .board-picker-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-picker-card {
    width: 72rpx;
    height: 100rpx;
    padding: 9rpx 9rpx 10rpx;
  }
}
