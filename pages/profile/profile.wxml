<view class="app-bg"></view>
<view class="container">
  <view class="profile-hero">
    <view class="profile-hero-glow"></view>
    <view class="profile-hero-main">
      <view class="profile-identity">
        <view class="profile-avatar-wrap" bindtap="openProfileEditor">
          <image wx:if="{{profile.avatarUrl}}" class="profile-avatar" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="profile-avatar profile-avatar-fallback">{{profile.avatarText}}</view>
          <view class="profile-avatar-edit-icon" bindtap="openProfileEditor" aria-label="编辑资料">
            <view class="icon-pencil"></view>
          </view>
        </view>
        <view class="profile-primary-copy">
          <view class="profile-name-row">
            <view class="profile-name-display">{{profile.name || '玩家'}}</view>
          </view>
          <view class="profile-tag-trigger">{{profile.title}}</view>
        </view>
      </view>
      <view class="profile-hero-meta">
        <view class="profile-hero-chip profile-hero-chip-hands">
          <view class="profile-hero-chip-kicker">手数</view>
          <view class="profile-hero-chip-value">{{stats.handCount || 0}}</view>
          <view class="profile-hero-chip-sub">总手数</view>
        </view>
        <view class="profile-hero-chip profile-hero-chip-profit">
          <view class="profile-hero-chip-kicker">战绩</view>
          <view class="profile-hero-chip-value {{(stats.totalProfit || 0) >= 0 ? 'positive' : 'negative'}}">{{totalProfitDisplay}}</view>
          <view class="profile-hero-chip-sub">累计</view>
        </view>
      </view>
    </view>
    <view class="profile-hero-art"></view>
  </view>

  <view wx:if="{{wechatProfilePromptVisible}}" class="wechat-sync-card">
    <view class="wechat-sync-card-main">
      <view class="wechat-sync-card-title">同步微信头像和昵称</view>
      <view class="wechat-sync-card-desc">首次使用建议同步一次，之后可手动编辑。</view>
    </view>
    <view class="wechat-sync-card-action" bindtap="openWechatProfilePrompt">同步</view>
  </view>

  <view wx:if="{{profileEditorVisible}}" class="wechat-profile-mask" bindtap="closeProfileEditor">
    <view class="profile-editor-dialog" catchtap="noop">
      <view class="profile-editor-head">
        <view>
          <view class="profile-editor-title">编辑资料</view>
          <view class="profile-editor-subtitle">头像和昵称之后都可以手动修改。</view>
        </view>
        <view class="profile-editor-close" bindtap="closeProfileEditor">关闭</view>
      </view>
      <view class="profile-editor-body">
        <view class="profile-editor-avatar-col">
          <view class="profile-editor-avatar" bindtap="chooseLocalAvatar">
            <image wx:if="{{profile.avatarUrl}}" class="profile-editor-avatar-img" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="profile-editor-avatar-fallback">{{profile.avatarText}}</view>
            <view class="profile-editor-avatar-badge">改</view>
          </view>
          <view class="profile-editor-avatar-tip">相册/拍照更换</view>
        </view>
        <view class="profile-editor-fields">
          <view class="profile-editor-label">昵称</view>
          <input
            class="profile-editor-input"
            value="{{profileEditorName}}"
            placeholder="输入你的玩家昵称"
            placeholder-class="profile-editor-placeholder"
            bindinput="onProfileEditorNameInput"
            confirm-type="done"
          />
          <view class="profile-editor-label profile-editor-label-gap">称号</view>
          <input
            class="profile-editor-input"
            value="{{profileEditorTitle}}"
            placeholder="例如 怪盗团新兵"
            placeholder-class="profile-editor-placeholder"
            bindinput="onProfileEditorTitleInput"
            confirm-type="done"
          />
        </view>
      </view>
      <view class="profile-editor-actions">
        <view class="profile-editor-action profile-editor-action-secondary" bindtap="closeProfileEditor">取消</view>
        <view class="profile-editor-action profile-editor-action-primary" bindtap="saveProfileEditor">保存</view>
      </view>
    </view>
  </view>

  <view class="section-label">牌局管理</view>
  <view class="card profile-card-compact">
    <view class="setting-row" bindtap="importBackup">
      <view class="setting-main">
        <view>
          <view class="setting-title">导入牌局数据</view>
          <view class="small muted">从剪贴板导入备份 JSON</view>
        </view>
      </view>
      <view class="setting-arrow">></view>
    </view>
    <view class="setting-row" bindtap="exportBackup">
      <view class="setting-main">
        <view>
          <view class="setting-title">导出牌局数据</view>
          <view class="small muted">复制完整备份到剪贴板</view>
        </view>
      </view>
      <view class="setting-arrow">></view>
    </view>
  </view>

  <view class="section-label">偏好设置</view>
  <view class="card profile-card-compact">
    <view class="setting-block">
      <view class="setting-head">
        <view>
          <view class="setting-title">筹码单位</view>
          <view class="small muted">当前按 {{unitLabel}} 显示总盈亏</view>
        </view>
      </view>
      <view class="segment-row">
        <view class="segment-item {{settings.chipUnit === 'BB' ? 'active' : ''}}" data-value="BB" bindtap="selectChipUnit">BB</view>
        <view class="segment-item {{settings.chipUnit === 'CNY' ? 'active' : ''}}" data-value="CNY" bindtap="selectChipUnit">¥</view>
        <view class="segment-item {{settings.chipUnit === 'HKD' ? 'active' : ''}}" data-value="HKD" bindtap="selectChipUnit">HK$</view>
        <view class="segment-item {{settings.chipUnit === 'USD' ? 'active' : ''}}" data-value="USD" bindtap="selectChipUnit">$</view>
      </view>
    </view>

    <view class="setting-block">
      <view class="setting-head">
        <view class="setting-title">场地预设</view>
        <view class="profile-action compact" bindtap="editVenues">编辑</view>
      </view>
      <view class="chip-list">
        <view wx:for="{{settings.venues}}" wx:key="*this" class="pref-chip">{{item}}</view>
      </view>
    </view>

    <view class="setting-block">
      <view class="setting-head">
        <view class="setting-title">级别预设</view>
        <view class="profile-action compact" bindtap="editBlindPresets">编辑</view>
      </view>
      <view class="chip-list">
        <view wx:for="{{settings.blindPresets}}" wx:key="*this" class="pref-chip">{{item}}</view>
      </view>
    </view>

    <view class="setting-block">
      <view class="setting-head">
        <view class="setting-title">位置预设</view>
        <view class="profile-action compact" bindtap="editPositions">编辑</view>
      </view>
      <view class="chip-list">
        <view wx:for="{{settings.positions}}" wx:key="*this" class="pref-chip">{{item}}</view>
      </view>
    </view>

    <view class="setting-block">
      <view class="setting-head">
        <view class="setting-title">对手类型</view>
        <view class="profile-action compact" bindtap="editOpponentTypes">编辑</view>
      </view>
      <view class="chip-list">
        <view wx:for="{{settings.opponentTypes}}" wx:key="*this" class="pref-chip">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="section-label">账号与数据</view>
  <view class="card profile-card-compact">
    <view class="setting-row danger" bindtap="clearData">
      <view class="setting-main">
        <view class="setting-title">清除所有数据</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
    <view class="setting-row" bindtap="showAbout">
      <view class="setting-main">
        <view>
          <view class="setting-title">关于</view>
          <view class="small muted">{{version}}</view>
        </view>
      </view>
      <view class="setting-arrow">></view>
    </view>
  </view>

  <view class="profile-footer">
    <view class="small muted">The poker is life.</view>
  </view>

  <view wx:if="{{wechatProfileDialogVisible}}" class="wechat-profile-mask">
    <view class="wechat-profile-dialog">
      <view class="wechat-profile-title">同步微信昵称和头像</view>
      <view class="wechat-profile-desc">首次登录时可使用微信小程序框架同步一次资料。之后头像和昵称都在“编辑资料”里手动修改。</view>
      <view class="wechat-sync-panel">
        <view class="wechat-sync-preview">
          <view class="wechat-sync-avatar-box">
            <image wx:if="{{profile.avatarUrl}}" class="wechat-sync-avatar-img" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="wechat-sync-avatar-fallback">{{profile.avatarText}}</view>
          </view>
          <view class="wechat-sync-preview-copy">
            <view class="wechat-sync-preview-label">当前资料</view>
            <view class="wechat-sync-preview-name">{{profile.name || '玩家'}}</view>
          </view>
        </view>
        <view class="wechat-sync-note">
          微信授权窗口会由小程序框架弹出，本页面不再嵌入头像和昵称原生控件，避免真机样式错乱。
        </view>
      </view>
      <view class="wechat-profile-actions">
        <view class="wechat-profile-action wechat-profile-action-secondary" bindtap="closeWechatProfilePrompt">暂不</view>
        <view class="wechat-profile-action wechat-profile-action-primary" bindtap="syncWechatProfileByFramework">同步微信资料</view>
      </view>
    </view>
  </view>

  <view wx:if="{{settingsEditorVisible}}" class="settings-editor-mask" bindtap="onSettingsEditorMaskTap">
    <view class="settings-editor-sheet" catchtap="noop">
      <view class="settings-editor-head">
        <view>
          <view class="settings-editor-title">{{settingsEditorTitle}}</view>
          <view class="settings-editor-subtitle">可直接修改、删除已有预设，也可新增一项。</view>
        </view>
        <view class="settings-editor-close" bindtap="closeSettingsEditor">
          <view class="icon-close">
            <view class="icon-close-line"></view>
            <view class="icon-close-line icon-close-line-rotated"></view>
          </view>
        </view>
      </view>

      <view class="settings-editor-list">
        <view wx:for="{{settingsEditorItems}}" wx:key="id" wx:for-item="preset" wx:for-index="index" class="settings-editor-row">
          <input
            class="settings-editor-input"
            value="{{preset.value}}"
            data-index="{{index}}"
            placeholder="{{settingsEditorPlaceholder}}"
            placeholder-class="settings-editor-placeholder"
            bindinput="onSettingsEditorInput"
          />
          <view class="settings-editor-delete" data-index="{{index}}" bindtap="removeSettingsEditorItem">
            <view class="icon-trash">
              <view class="icon-trash-lid"></view>
              <view class="icon-trash-body">
                <view class="icon-trash-stem"></view>
                <view class="icon-trash-stem"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="settings-editor-create">
        <input
          class="settings-editor-input settings-editor-input-create"
          value="{{settingsEditorNewValue}}"
          placeholder="{{settingsEditorPlaceholder}}"
          placeholder-class="settings-editor-placeholder"
          bindinput="onSettingsEditorNewValueInput"
          confirm-type="done"
        />
        <view class="settings-editor-add" bindtap="addSettingsEditorItem">
          <view class="icon-plus">
            <view class="icon-plus-line"></view>
            <view class="icon-plus-line icon-plus-line-vertical"></view>
          </view>
        </view>
      </view>

      <view class="settings-editor-actions">
        <view class="settings-editor-action settings-editor-action-secondary" bindtap="closeSettingsEditor">取消</view>
        <view class="settings-editor-action settings-editor-action-primary" bindtap="saveSettingsEditor">保存</view>
      </view>
    </view>
  </view>

  <view class="tab-bar-spacer"></view>
</view>
<agent-chat />
