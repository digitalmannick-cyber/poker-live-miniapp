@import '../../app.wxss';

.profile-hero {
  position: relative;
  min-height: 176rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.94), rgba(181, 0, 32, 0.88)),
    linear-gradient(180deg, rgba(20, 20, 27, 0.96), rgba(11, 11, 15, 0.96));
  border: 1rpx solid rgba(255,255,255,0.12);
}

.profile-hero-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04));
  pointer-events: none;
}

.profile-avatar-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  width: 104rpx;
  height: 104rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.10);
  border: 1rpx solid rgba(255,255,255,0.18);
  overflow: visible;
  flex-shrink: 0;
  box-sizing: border-box;
}

.profile-hero-main {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 170rpx;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.profile-identity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.18);
  background: #05050a;
  box-sizing: border-box;
  overflow: hidden;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffedf2;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 212rpx;
  gap: 24rpx;
  align-items: center;
}

.profile-primary-copy {
  flex: 1;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
}

.profile-name-trigger,
.profile-id-trigger,
.profile-tag-trigger {
  display: inline-flex;
  max-width: 100%;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.profile-name-display {
  display: block;
  flex: 1;
  max-width: 100%;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}

.profile-avatar-edit-icon {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  z-index: 3;
  flex-shrink: 0;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(8, 10, 16, 0.76);
  border: 2rpx solid rgba(255,255,255,0.86);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.26);
  box-sizing: border-box;
}

.icon-pencil {
  position: relative;
  width: 18rpx;
  height: 18rpx;
  transform: rotate(-38deg);
}

.icon-pencil::before {
  content: '';
  position: absolute;
  left: 7rpx;
  top: 1rpx;
  width: 5rpx;
  height: 15rpx;
  border-radius: 3rpx;
  background: currentColor;
}

.icon-pencil::after {
  content: '';
  position: absolute;
  left: 5rpx;
  bottom: -2rpx;
  width: 9rpx;
  height: 5rpx;
  clip-path: polygon(50% 100%, 0 0, 100% 0);
  background: currentColor;
}

.profile-name-trigger {
  width: 100%;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.08;
  color: #ffffff;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.profile-name-input {
  height: 50rpx;
  padding: 0;
  background: transparent;
}

.profile-name-placeholder {
  color: rgba(255,255,255,0.58);
}

.profile-id-block {
  margin-top: 8rpx;
}

.profile-id-trigger {
  color: rgba(255,255,255,0.86);
  font-size: 24rpx;
  font-weight: 700;
}

.profile-tag-trigger {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.16);
  color: #fff2f5;
  font-size: 20rpx;
  font-weight: 700;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}

.profile-edit-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(8, 10, 16, 0.38);
  border: 1rpx solid rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.92);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
}

.profile-hero-meta {
  display: grid;
  gap: 10rpx;
  width: 170rpx;
  min-width: 170rpx;
}

.profile-hero-chip {
  position: relative;
  min-height: 72rpx;
  padding: 10rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(201, 236, 255, 0.18);
  background: linear-gradient(180deg, rgba(228, 245, 255, 0.14), rgba(160, 220, 255, 0.06));
  backdrop-filter: blur(10rpx);
  overflow: hidden;
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.20),
    0 10rpx 24rpx rgba(5, 18, 34, 0.12);
  box-sizing: border-box;
}

.profile-hero-chip-hands {
  background:
    radial-gradient(circle at right top, rgba(255, 255, 255, 0.22), rgba(255,255,255,0) 42%),
    linear-gradient(180deg, rgba(233, 245, 255, 0.18), rgba(156, 214, 255, 0.07));
}

.profile-hero-chip-profit {
  background:
    radial-gradient(circle at right top, rgba(118, 214, 255, 0.26), rgba(118,214,255,0) 42%),
    linear-gradient(180deg, rgba(189, 235, 255, 0.20), rgba(103, 196, 255, 0.08));
}

.profile-hero-chip::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: rgba(255,255,255,0.30);
}

.profile-hero-chip::after {
  content: '';
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 0;
  height: 5rpx;
  border-radius: 999rpx 999rpx 0 0;
  opacity: 0.8;
}

.profile-hero-chip-hands::after {
  background: linear-gradient(90deg, rgba(210, 239, 255, 0), rgba(210, 239, 255, 0.24), rgba(210, 239, 255, 0));
}

.profile-hero-chip-profit::after {
  background: linear-gradient(90deg, rgba(91, 203, 255, 0), rgba(91, 203, 255, 0.28), rgba(91, 203, 255, 0));
}

.profile-hero-chip-kicker {
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 0;
  color: rgba(181, 230, 255, 0.80);
  white-space: nowrap;
}

.profile-hero-chip-value {
  margin-top: 3rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #dff5ff;
  line-height: 1.08;
  text-shadow: 0 4rpx 12rpx rgba(35, 84, 124, 0.14);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}

.profile-hero-chip-sub {
  margin-top: 1rpx;
  font-size: 17rpx;
  color: rgba(185, 225, 245, 0.76);
  white-space: nowrap;
}

.profile-hero-chip-hands .profile-hero-chip-kicker {
  color: rgba(255, 232, 169, 0.84);
}

.profile-hero-chip-hands .profile-hero-chip-value {
  color: #ffe4a3;
  text-shadow: 0 4rpx 12rpx rgba(120, 81, 13, 0.18);
}

.profile-hero-chip-hands .profile-hero-chip-sub {
  color: rgba(255, 231, 178, 0.78);
}

.profile-hero-chip-profit .profile-hero-chip-kicker {
  color: rgba(176, 236, 212, 0.86);
}

.profile-hero-chip-profit .profile-hero-chip-value {
  color: #7ef0b0;
  text-shadow: 0 4rpx 12rpx rgba(22, 110, 62, 0.18);
}

.profile-hero-chip-profit .profile-hero-chip-value.negative {
  color: #ff8f8f;
  text-shadow: 0 4rpx 12rpx rgba(138, 32, 32, 0.18);
}

.profile-hero-chip-profit .profile-hero-chip-sub {
  color: rgba(190, 238, 214, 0.78);
}

.profile-hero-art {
  position: absolute;
  right: -32rpx;
  top: -8rpx;
  width: 260rpx;
  bottom: -22rpx;
  opacity: 0.20;
  pointer-events: none;
  background:
    radial-gradient(circle at 38% 24%, rgba(255,255,255,0.20), rgba(255,255,255,0) 34%),
    linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0) 62%);
  transform: rotate(-8deg);
}

.wechat-sync-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 0 0 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.96), rgba(11, 11, 15, 0.96));
  border: 1rpx solid rgba(0, 209, 255, 0.22);
  box-sizing: border-box;
}

.wechat-sync-card-main {
  min-width: 0;
}

.wechat-sync-card-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.wechat-sync-card-desc {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.62);
  font-size: 21rpx;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wechat-sync-card-action {
  flex-shrink: 0;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 209, 255, 0.14);
  border: 1rpx solid rgba(0, 209, 255, 0.34);
  color: #00d1ff;
  font-size: 23rpx;
  font-weight: 900;
}

.profile-editor-dialog {
  width: 100%;
  border-radius: 28rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.98), rgba(11, 11, 15, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.profile-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.profile-editor-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-editor-subtitle {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.62);
  font-size: 22rpx;
}

.profile-editor-close {
  flex-shrink: 0;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.82);
  font-size: 22rpx;
  font-weight: 800;
}

.profile-editor-body {
  display: grid;
  grid-template-columns: 136rpx minmax(0, 1fr);
  gap: 22rpx;
  margin-top: 26rpx;
  align-items: start;
}

.profile-editor-avatar-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.profile-editor-avatar {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  overflow: hidden;
}

.profile-editor-avatar-badge {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e60012;
  border: 2rpx solid rgba(255,255,255,0.82);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  box-sizing: border-box;
}

.profile-editor-avatar::after {
  border: none;
}

.profile-editor-avatar-img,
.profile-editor-avatar-fallback {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}

.profile-editor-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.profile-editor-avatar-tip {
  color: rgba(255,255,255,0.58);
  font-size: 20rpx;
  line-height: 1.2;
}

.profile-editor-fields {
  min-width: 0;
}

.profile-editor-label {
  color: rgba(255,255,255,0.66);
  font-size: 22rpx;
  font-weight: 800;
}

.profile-editor-label-gap {
  margin-top: 18rpx;
}

.profile-editor-input {
  width: 100%;
  height: 78rpx;
  margin-top: 8rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.07);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.profile-editor-placeholder {
  color: rgba(255,255,255,0.42);
}

.profile-editor-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 26rpx;
}

.profile-editor-action {
  height: 84rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.profile-editor-action-secondary {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.86);
}

.profile-editor-action-primary {
  background: linear-gradient(135deg, #e60012, #ff2a2a);
  border: 1rpx solid rgba(255,255,255,0.12);
  color: #ffffff;
}

.section-label {
  margin: 4rpx 0 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.78);
  letter-spacing: 2rpx;
}

.profile-card-compact {
  padding-top: 14rpx;
  padding-bottom: 8rpx;
}

.profile-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-action.compact {
  min-height: 48rpx;
  padding: 0 16rpx;
  font-size: 20rpx;
}

.stats-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stats-cell {
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.setting-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.setting-row::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255,255,255,0.22);
  box-shadow: 0 0 0 8rpx rgba(255,255,255,0.03);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-row.danger::before {
  background: rgba(255, 51, 88, 0.92);
  box-shadow: 0 0 0 8rpx rgba(255, 51, 88, 0.10);
}

.setting-row.danger .setting-title {
  color: #ff3358;
}

.setting-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.setting-main {
  flex: 1;
  min-width: 0;
}

.setting-arrow {
  color: rgba(255,255,255,0.42);
  font-size: 34rpx;
  line-height: 1;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.setting-block {
  position: relative;
  z-index: 1;
  padding: 8rpx 0 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.setting-block:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.setting-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.segment-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 10rpx;
}

.segment-item {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 6rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.04);
  color: rgba(255,255,255,0.68);
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.segment-item.active {
  background: rgba(230, 0, 18, 0.24);
  border-color: rgba(230, 0, 18, 0.42);
  color: #ffffff;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pref-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.84);
  font-size: 22rpx;
}

.profile-footer {
  padding: 20rpx 0 40rpx;
  text-align: center;
}

.wechat-profile-mask {
  position: fixed;
  inset: 0;
  z-index: 118;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: rgba(3, 6, 12, 0.58);
  box-sizing: border-box;
}

.wechat-profile-dialog {
  width: 100%;
  max-width: 690rpx;
  border-radius: 28rpx;
  padding: 30rpx 28rpx;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.98), rgba(11, 11, 15, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.wechat-profile-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.wechat-profile-desc {
  margin-top: 14rpx;
  color: rgba(255,255,255,0.70);
  font-size: 24rpx;
  line-height: 1.6;
}

.wechat-sync-panel {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-sync-avatar-box {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  min-width: 128rpx;
  min-height: 128rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  overflow: hidden;
  line-height: 1;
  box-sizing: border-box;
}

.wechat-sync-avatar-hit {
  position: absolute;
  inset: 0;
  width: 128rpx;
  height: 128rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: transparent;
  opacity: 0;
  line-height: 1;
  box-sizing: border-box;
}

.wechat-sync-avatar-hit::after {
  border: none;
}

.wechat-sync-avatar-img,
.wechat-sync-avatar-fallback {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.wechat-sync-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.wechat-sync-avatar-text {
  margin-top: 12rpx;
  color: rgba(255,255,255,0.66);
  font-size: 22rpx;
  line-height: 1.3;
}

.wechat-sync-field {
  width: 100%;
  margin-top: 22rpx;
}

.wechat-sync-label {
  color: rgba(255,255,255,0.70);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.3;
}

.wechat-profile-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.wechat-profile-action {
  height: 84rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  margin: 0;
  padding: 0;
  line-height: 1;
}

.wechat-profile-action::after {
  border: none;
}

.wechat-profile-action-secondary {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.86);
}

.wechat-profile-action-primary {
  background: linear-gradient(135deg, #e60012, #ff2a2a);
  border: 1rpx solid rgba(255,255,255,0.12);
  color: #ffffff;
}

.wechat-nickname-input {
  display: block;
  width: 100%;
  margin-top: 10rpx;
  height: 70rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.07);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.wechat-nickname-placeholder {
  color: rgba(255,255,255,0.52);
}

.settings-editor-mask {
  position: fixed;
  inset: 0;
  z-index: 120;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx 24rpx calc(214rpx + env(safe-area-inset-bottom));
  background: rgba(3, 6, 12, 0.58);
  box-sizing: border-box;
}

.settings-editor-sheet {
  width: 100%;
  max-height: calc(100vh - 260rpx - env(safe-area-inset-bottom));
  border-radius: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.98), rgba(11, 11, 15, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.settings-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.settings-editor-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.settings-editor-subtitle {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.62);
  font-size: 22rpx;
  line-height: 1.45;
}

.settings-editor-close {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.settings-editor-list {
  margin-top: 22rpx;
  max-height: 42vh;
  overflow-y: auto;
}

.settings-editor-row,
.settings-editor-create {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.settings-editor-row + .settings-editor-row {
  margin-top: 14rpx;
}

.settings-editor-create {
  margin-top: 18rpx;
}

.settings-editor-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: #ffffff;
  font-size: 26rpx;
  box-sizing: border-box;
}

.settings-editor-placeholder {
  color: rgba(255,255,255,0.36);
}

.settings-editor-delete,
.settings-editor-add {
  flex-shrink: 0;
  width: 80rpx;
  height: 88rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.settings-editor-delete {
  background: rgba(255, 59, 89, 0.14);
  border: 1rpx solid rgba(255, 59, 89, 0.30);
  color: #ff97aa;
}

.settings-editor-add {
  background: rgba(0, 209, 255, 0.14);
  border: 1rpx solid rgba(0, 209, 255, 0.30);
  color: #91eaff;
}

.icon-close,
.icon-plus {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}

.icon-close-line,
.icon-plus-line {
  position: absolute;
  left: 0;
  top: 50%;
  width: 24rpx;
  height: 4rpx;
  margin-top: -2rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.icon-close {
  color: rgba(255,255,255,0.88);
}

.icon-close-line {
  transform: rotate(45deg);
}

.icon-close-line-rotated {
  transform: rotate(-45deg);
}

.icon-plus {
  color: #91eaff;
}

.icon-plus-line-vertical {
  transform: rotate(90deg);
}

.icon-trash {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.icon-trash-lid {
  position: absolute;
  left: 4rpx;
  top: 2rpx;
  width: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.icon-trash-body {
  position: absolute;
  left: 6rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-top-width: 3rpx;
  border-radius: 3rpx 3rpx 5rpx 5rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.icon-trash-stem {
  width: 2rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.settings-editor-delete .icon-trash {
  color: #ff97aa;
}

.settings-editor-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.settings-editor-action {
  height: 84rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.settings-editor-action-secondary {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.86);
}

.settings-editor-action-primary {
  background: linear-gradient(135deg, #e60012, #ff2a2a);
  border: 1rpx solid rgba(255,255,255,0.12);
  color: #ffffff;
}

@media (max-width: 360px) {
  .profile-hero-main {
    grid-template-columns: minmax(0, 1fr) 158rpx;
    gap: 12rpx;
  }

  .profile-hero-meta {
    width: 158rpx;
    min-width: 158rpx;
  }

  .profile-avatar-wrap,
  .profile-avatar {
    width: 92rpx;
    height: 92rpx;
  }

  .profile-name-display,
  .profile-name-trigger {
    font-size: 28rpx;
  }

  .profile-hero-chip-value {
    font-size: 21rpx;
  }
}

/* Real-device reset for WeChat profile sync controls. */
.wechat-profile-dialog {
  width: calc(100vw - 64rpx);
  max-width: 690rpx;
  max-height: calc(100vh - 220rpx);
  overflow-y: auto;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.wechat-sync-panel {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.wechat-sync-preview {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-width: 0;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.10);
  box-sizing: border-box;
}

.wechat-sync-preview-copy {
  min-width: 0;
}

.wechat-sync-preview-label {
  color: rgba(255,255,255,0.58);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.wechat-sync-preview-name {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.18;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wechat-sync-avatar-box {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  min-height: 112rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
  flex: 0 0 112rpx;
}

.wechat-sync-native-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  min-width: 0;
  min-height: 0;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(0, 209, 255, 0.34);
  border-radius: 18rpx;
  background: rgba(0, 209, 255, 0.12);
  color: #00d1ff;
  font-size: 26rpx;
  font-weight: 900;
  overflow: hidden;
  line-height: 1;
  box-sizing: border-box;
}

.wechat-sync-native-button::after {
  border: none;
}

.wechat-sync-avatar-img,
.wechat-sync-avatar-fallback {
  display: flex;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  box-sizing: border-box;
}

.wechat-sync-avatar-hit {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: block;
  width: 132rpx;
  height: 132rpx;
  min-width: 0;
  min-height: 0;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: transparent;
  opacity: 0;
  line-height: 1;
  transform: none;
  box-sizing: border-box;
}

.wechat-sync-avatar-hit::after {
  border: none;
}

.wechat-sync-avatar-text {
  width: 100%;
  margin: 0;
  text-align: center;
  line-height: 1.35;
}

.wechat-sync-field {
  width: 100%;
  min-width: 0;
  margin: 0;
  box-sizing: border-box;
}

.wechat-nickname-input {
  width: 100%;
  height: 88rpx;
  margin-top: 12rpx;
  padding: 0 22rpx;
  line-height: 88rpx;
  box-sizing: border-box;
}

.wechat-profile-actions {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  box-sizing: border-box;
}

.wechat-profile-action {
  width: 100%;
  min-width: 0;
  height: 84rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.profile-editor-avatar {
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  min-height: 112rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  line-height: 1;
  overflow: hidden;
  box-sizing: border-box;
}

.profile-editor-avatar::after {
  border: none;
}
