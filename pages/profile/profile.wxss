@import '../../app.wxss';

.profile-hero {
  position: relative;
  min-height: 222rpx;
  padding: 24rpx 22rpx 24rpx 24rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.94), rgba(181, 0, 32, 0.88)),
    linear-gradient(180deg, rgba(20, 20, 27, 0.96), rgba(11, 11, 15, 0.96));
  border: 1rpx solid rgba(255,255,255,0.12);
}

.profile-hero-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04));
  pointer-events: none;
}

.profile-avatar-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  width: 148rpx;
  height: 148rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.10);
  border: 1rpx solid rgba(255,255,255,0.18);
  overflow: visible;
  flex-shrink: 0;
  box-sizing: border-box;
}

.profile-hero-main {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190rpx;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.profile-identity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.18);
  background: #05050a;
  box-sizing: border-box;
  overflow: hidden;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffedf2;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 212rpx;
  gap: 24rpx;
  align-items: center;
}

.profile-primary-copy {
  flex: 1;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
}

.profile-name-trigger,
.profile-id-trigger,
.profile-tag-trigger {
  display: inline-flex;
  max-width: 100%;
}

.profile-title-hours {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.80);
  font-size: 21rpx;
  font-weight: 800;
  white-space: nowrap;
}

.profile-tag-skeleton {
  width: 156rpx;
  height: 42rpx;
  margin-top: 10rpx;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.14);
}

.profile-title-hours-skeleton {
  width: 188rpx;
  height: 21rpx;
  margin-top: 10rpx;
  border-radius: 4rpx;
  background: rgba(255,255,255,0.12);
}

.profile-title-progress-copy-skeleton {
  width: 240rpx;
  height: 18rpx;
  margin-top: 7rpx;
  border-radius: 4rpx;
  background: rgba(255,255,255,0.10);
}

.profile-title-progress-track {
  width: 320rpx;
  max-width: 100%;
  height: 8rpx;
  margin-top: 8rpx;
  overflow: hidden;
  background: rgba(8,10,16,0.38);
  transform: skewX(-12deg);
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.08);
}

.profile-title-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #00d1ff, #7df7ff);
  box-shadow: 0 0 14rpx rgba(0, 209, 255, 0.58);
}

.profile-title-progress-copy {
  width: 320rpx;
  max-width: 100%;
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 7rpx;
  color: rgba(255,255,255,0.70);
  font-size: 18rpx;
  font-weight: 800;
  white-space: nowrap;
}

.profile-title-next {
  color: #ffe52b;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-title-route-action {
  display: none;
}

.profile-title-route-chevron {
  display: none;
}

.title-route-mask {
  position: fixed;
  inset: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  background: rgba(0,0,0,0.78);
  backdrop-filter: blur(8rpx);
  box-sizing: border-box;
}

.title-route-panel {
  width: 100%;
  max-height: 88vh;
  overflow: hidden;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.18);
  background:
    repeating-linear-gradient(135deg, rgba(255,255,255,0.018) 0 1rpx, transparent 1rpx 14rpx),
    #090a0e;
  box-shadow: 0 34rpx 90rpx rgba(0,0,0,0.58);
  box-sizing: border-box;
}

.title-route-head {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  min-height: 90rpx;
  padding: 22rpx 28rpx 16rpx;
  background: linear-gradient(180deg, #090a0e 76%, rgba(9,10,14,0));
  box-sizing: border-box;
}

.title-route-heading {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.title-route-english {
  margin-left: auto;
  margin-right: 64rpx;
  color: #e60012;
  font-size: 18rpx;
  font-weight: 900;
  font-style: italic;
}

.title-route-close {
  position: absolute;
  right: 20rpx;
  top: 18rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1rpx solid rgba(255,255,255,0.18);
  background: #181920;
}

.title-route-close-icon,
.title-route-close-icon::after {
  width: 22rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: rotate(45deg);
}

.title-route-close-icon::after {
  content: '';
  display: block;
  transform: rotate(90deg);
}

.title-route-list {
  position: relative;
  padding: 0 24rpx 32rpx 66rpx;
}

.title-route-list::before {
  content: '';
  position: absolute;
  left: 42rpx;
  top: 12rpx;
  bottom: 44rpx;
  width: 2rpx;
  background: #343640;
}

.title-level {
  position: relative;
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 76rpx;
  align-items: center;
  gap: 12rpx;
  min-height: 88rpx;
  padding: 12rpx 12rpx 12rpx 18rpx;
  border-bottom: 1rpx solid #292b32;
  color: #777881;
  box-sizing: border-box;
}

.title-level-node {
  position: absolute;
  left: -31rpx;
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #555761;
  background: #090a0e;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.title-level.done {
  color: #bfc0c6;
}

.title-level.done .title-level-node {
  border-color: #00d1ff;
  background: #00d1ff;
}

.title-level.current {
  border: 1rpx solid #e60012;
  color: #ffffff;
  background: rgba(230,0,18,0.12);
}

.title-level.current .title-level-node {
  left: -35rpx;
  width: 22rpx;
  height: 22rpx;
  border-color: #ffffff;
  background: #e60012;
}

.title-level-hours {
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.title-level-hours text {
  display: block;
  margin-top: 6rpx;
  color: #777881;
  font-size: 15rpx;
}

.title-level-name {
  min-width: 0;
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.title-level-state {
  color: #62636b;
  font-size: 17rpx;
  font-weight: 900;
  text-align: right;
  white-space: nowrap;
}

.title-level.done .title-level-state,
.title-level.current .title-level-state {
  color: #00d1ff;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.profile-name-display {
  display: block;
  flex: 1;
  max-width: 100%;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}

.profile-avatar-edit-icon {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  z-index: 3;
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(8, 10, 16, 0.76);
  border: 2rpx solid rgba(255,255,255,0.86);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.26);
  box-sizing: border-box;
}

.icon-pencil {
  position: relative;
  width: 18rpx;
  height: 18rpx;
  transform: rotate(-38deg);
}

.icon-pencil::before {
  content: '';
  position: absolute;
  left: 7rpx;
  top: 1rpx;
  width: 5rpx;
  height: 15rpx;
  border-radius: 3rpx;
  background: currentColor;
}

.icon-pencil::after {
  content: '';
  position: absolute;
  left: 5rpx;
  bottom: -2rpx;
  width: 9rpx;
  height: 5rpx;
  clip-path: polygon(50% 100%, 0 0, 100% 0);
  background: currentColor;
}

.profile-name-trigger {
  width: 100%;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.08;
  color: #ffffff;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.profile-name-input {
  height: 50rpx;
  padding: 0;
  background: transparent;
}

.profile-name-placeholder {
  color: rgba(255,255,255,0.58);
}

.profile-id-block {
  margin-top: 8rpx;
}

.profile-id-trigger {
  color: rgba(255,255,255,0.86);
  font-size: 24rpx;
  font-weight: 700;
}

.profile-tag-trigger {
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.18);
  color: #fff2f5;
  font-size: 23rpx;
  font-weight: 900;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}

.profile-tag-trigger::after {
  content: '';
  flex-shrink: 0;
  width: 9rpx;
  height: 9rpx;
  margin-left: 9rpx;
  border-top: 2rpx solid currentColor;
  border-right: 2rpx solid currentColor;
  transform: rotate(45deg);
  opacity: 0.88;
}

.profile-edit-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(8, 10, 16, 0.38);
  border: 1rpx solid rgba(255,255,255,0.16);
  color: rgba(255,255,255,0.92);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
}

.profile-hero-meta {
  display: grid;
  gap: 12rpx;
  width: 236rpx;
  min-width: 190rpx;
}

.profile-hero-chip {
  position: relative;
  min-height: 88rpx;
  padding: 12rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(201, 236, 255, 0.18);
  background: linear-gradient(180deg, rgba(228, 245, 255, 0.14), rgba(160, 220, 255, 0.06));
  backdrop-filter: blur(10rpx);
  overflow: hidden;
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.20),
    0 10rpx 24rpx rgba(5, 18, 34, 0.12);
  box-sizing: border-box;
}

.profile-hero-chip-hands {
  background:
    radial-gradient(circle at right top, rgba(255, 255, 255, 0.22), rgba(255,255,255,0) 42%),
    linear-gradient(180deg, rgba(233, 245, 255, 0.18), rgba(156, 214, 255, 0.07));
}

.profile-hero-chip-profit {
  background:
    radial-gradient(circle at right top, rgba(118, 214, 255, 0.26), rgba(118,214,255,0) 42%),
    linear-gradient(180deg, rgba(189, 235, 255, 0.20), rgba(103, 196, 255, 0.08));
}

.profile-hero-chip::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: rgba(255,255,255,0.30);
}

.profile-hero-chip::after {
  content: '';
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 0;
  height: 5rpx;
  border-radius: 999rpx 999rpx 0 0;
  opacity: 0.8;
}

.profile-hero-chip-hands::after {
  background: linear-gradient(90deg, rgba(210, 239, 255, 0), rgba(210, 239, 255, 0.24), rgba(210, 239, 255, 0));
}

.profile-hero-chip-profit::after {
  background: linear-gradient(90deg, rgba(91, 203, 255, 0), rgba(91, 203, 255, 0.28), rgba(91, 203, 255, 0));
}

.profile-hero-chip-kicker {
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
  color: rgba(181, 230, 255, 0.80);
  white-space: nowrap;
}

.profile-hero-chip-value {
  margin-top: 5rpx;
  font-size: 23rpx;
  font-weight: 900;
  color: #dff5ff;
  line-height: 1.08;
  text-shadow: 0 4rpx 12rpx rgba(35, 84, 124, 0.14);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}

.profile-hero-chip-sub {
  margin-top: 3rpx;
  font-size: 18rpx;
  color: rgba(185, 225, 245, 0.76);
  white-space: nowrap;
}

.profile-hero-chip-hands .profile-hero-chip-kicker {
  color: rgba(255, 232, 169, 0.84);
}

.profile-hero-chip-hands .profile-hero-chip-value {
  color: #ffe4a3;
  text-shadow: 0 4rpx 12rpx rgba(120, 81, 13, 0.18);
}

.profile-hero-chip-hands .profile-hero-chip-sub {
  color: rgba(255, 231, 178, 0.78);
}

.profile-hero-chip-profit .profile-hero-chip-kicker {
  color: rgba(176, 236, 212, 0.86);
}

.profile-hero-chip-profit .profile-hero-chip-value {
  color: #7ef0b0;
  text-shadow: 0 4rpx 12rpx rgba(22, 110, 62, 0.18);
}

.profile-hero-chip-profit .profile-hero-chip-value.negative {
  color: #ff8f8f;
  text-shadow: 0 4rpx 12rpx rgba(138, 32, 32, 0.18);
}

.profile-hero-chip-profit .profile-hero-chip-sub {
  color: rgba(190, 238, 214, 0.78);
}

.profile-hero-art {
  position: absolute;
  right: -32rpx;
  top: -8rpx;
  width: 260rpx;
  bottom: -22rpx;
  opacity: 0.20;
  pointer-events: none;
  background:
    radial-gradient(circle at 38% 24%, rgba(255,255,255,0.20), rgba(255,255,255,0) 34%),
    linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0) 62%);
  transform: rotate(-8deg);
}

.profile-login-hero {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr) 112rpx;
  align-items: center;
  gap: 20rpx;
  min-height: 184rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.92), rgba(181, 0, 32, 0.82)),
    linear-gradient(180deg, rgba(20, 20, 27, 0.96), rgba(11, 11, 15, 0.96));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.profile-login-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(8, 10, 16, 0.86);
  border: 2rpx solid rgba(255,255,255,0.24);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.profile-login-copy {
  min-width: 0;
}

.profile-login-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.15;
}

.profile-login-desc {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.76);
  font-size: 23rpx;
  line-height: 1.35;
}

.profile-login-action {
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.16);
  border: 1rpx solid rgba(255,255,255,0.22);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
}

.wechat-sync-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 0 0 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.96), rgba(11, 11, 15, 0.96));
  border: 1rpx solid rgba(0, 209, 255, 0.22);
  box-sizing: border-box;
}

.wechat-sync-card-main {
  min-width: 0;
}

.wechat-sync-card-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.wechat-sync-card-desc {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.62);
  font-size: 21rpx;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wechat-sync-card-action {
  flex-shrink: 0;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 209, 255, 0.14);
  border: 1rpx solid rgba(0, 209, 255, 0.34);
  color: #00d1ff;
  font-size: 23rpx;
  font-weight: 900;
}

.profile-editor-dialog {
  width: 100%;
  border-radius: 28rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.98), rgba(11, 11, 15, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-sizing: border-box;
}

.profile-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.profile-editor-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-editor-subtitle {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.62);
  font-size: 22rpx;
}

.profile-editor-close {
  flex-shrink: 0;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.82);
  font-size: 22rpx;
  font-weight: 800;
}

.profile-editor-body {
  display: grid;
  grid-template-columns: 136rpx minmax(0, 1fr);
  gap: 22rpx;
  margin-top: 26rpx;
  align-items: start;
}

.profile-editor-avatar-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.profile-editor-avatar {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16);
  overflow: hidden;
}

.profile-editor-avatar-badge {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e60012;
  border: 2rpx solid rgba(255,255,255,0.82);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  box-sizing: border-box;
}

.profile-editor-avatar::after {
  border: none;
}

/* Ultimate override for the WeChat profile sync dialog on real devices. */
.wechat-profile-dialog {
  width: calc(100vw - 64rpx);
  max-width: 690rpx;
  max-height: calc(100vh - 220rpx);
  padding: 34rpx 30rpx 30rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.wechat-sync-panel {
  width: 100%;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.wechat-sync-form {
  display: grid;
  grid-template-columns: 156rpx minmax(0, 1fr);
  align-items: center;
  gap: 22rpx;
  width: 100%;
  min-width: 0;
}

.wechat-sync-avatar-button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 156rpx;
  min-width: 156rpx;
  min-height: 156rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(255,255,255,0.18);
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  overflow: hidden;
  line-height: 1;
  box-sizing: border-box;
}

.wechat-sync-avatar-button::after {
  border: none;
}

.wechat-sync-avatar-img,
.wechat-sync-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
