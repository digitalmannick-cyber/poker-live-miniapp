@import '../../app.wxss';

.player-notes-shell {
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.player-notes-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 14rpx 0 24rpx;
}

.player-notes-kicker {
  color: rgba(255,255,255,0.48);
  font-size: 22rpx;
  font-weight: 1000;
  letter-spacing: 4rpx;
}

.player-notes-title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 1000;
}

.player-notes-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.player-notes-context-action {
  min-width: 142rpx;
  height: 68rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 950;
  background: linear-gradient(135deg, rgba(230,0,18,0.92), rgba(255,42,61,0.82));
  border: 1rpx solid rgba(255,255,255,0.2);
  box-shadow: 0 10rpx 24rpx rgba(230,0,18,0.18);
}

.player-notes-invite {
  min-width: 72rpx;
  width: 72rpx;
  padding: 0;
  background: rgba(255,255,255,0.075);
  box-shadow: inset 0 0 0 1rpx rgba(230,0,18,0.18);
}

.player-notes-invite-plus {
  margin-top: -4rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 650;
}

.player-notes-create-plus {
  margin-top: -2rpx;
  font-size: 31rpx;
  line-height: 1;
  font-weight: 600;
}

.player-notes-message {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 1000;
  background: rgba(255,255,255,0.075);
  border: 1rpx solid rgba(255,255,255,0.18);
}

.player-notes-flag-icon {
  position: relative;
  width: 38rpx;
  height: 40rpx;
  transform: rotate(-3deg);
}

.player-notes-flag-pole {
  position: absolute;
  left: 7rpx;
  top: 3rpx;
  width: 5rpx;
  height: 35rpx;
  border-radius: 4rpx;
  background: #ffffff;
  box-shadow: 0 0 8rpx rgba(0,209,255,0.32);
}

.player-notes-flag-cloth {
  position: absolute;
  left: 11rpx;
  top: 5rpx;
  width: 25rpx;
  height: 18rpx;
  background: linear-gradient(135deg, #ff1834 0 58%, #00d1ff 59% 100%);
  clip-path: polygon(0 0, 100% 12%, 78% 52%, 100% 92%, 0 82%);
  filter: drop-shadow(0 4rpx 5rpx rgba(230,0,18,0.28));
}

.player-notes-message-badge {
  position: absolute;
  top: -10rpx;
  right: -12rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 7rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 1000;
  background: #e60012;
  border: 3rpx solid #0b0b0f;
}

.player-section-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  margin: 0 0 22rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.045);
  border: 1rpx solid rgba(255,255,255,0.1);
}

.player-section-tab {
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 13rpx;
  color: rgba(255,255,255,0.60);
  font-size: 27rpx;
  font-weight: 1000;
  background: transparent;
  border: 1rpx solid transparent;
}

.player-section-tab.active {
  color: #ffffff;
  background: rgba(230,0,18,0.82);
  border-color: rgba(255,255,255,0.2);
  box-shadow: 0 8rpx 18rpx rgba(230,0,18,0.16);
}

.player-empty-action {
  min-width: 132rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 14rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 950;
  background: #e60012;
  border: 0;
  transform: skewX(-7deg);
}

.player-search {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.player-search-input {
  min-height: 56rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.player-search-clear {
  color: #ff4354;
  font-size: 24rpx;
  font-weight: 900;
}

.player-type-scroll {
  margin: 20rpx -32rpx 16rpx;
  white-space: nowrap;
}

.player-type-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 32rpx;
}

.player-type-chip {
  display: flex;
  align-items: center;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: rgba(255,255,255,0.66);
  font-size: 24rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.player-type-chip.active {
  color: #ffffff;
  background: rgba(230,0,18,0.76);
  border-color: rgba(255,255,255,0.22);
}

.player-list {
  display: grid;
  gap: 14rpx;
}

.player-card {
  position: relative;
  display: grid;
  grid-template-columns: 8rpx 156rpx minmax(0, 1fr);
  gap: 16rpx;
  height: 204rpx;
  padding: 18rpx 18rpx 18rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 22rpx;
  background: linear-gradient(105deg, var(--player-card-color), rgba(23,26,34,0.94) 42%, #171a22 76%);
  border: 2rpx solid rgba(255,255,255,0.18);
}

.player-card::after {
  content: '';
  position: absolute;
  right: -36rpx;
  top: 0;
  width: 210rpx;
  height: 86rpx;
  background: rgba(230,0,18,0.28);
  transform: skewX(-12deg);
}

.player-card-color {
  width: 8rpx;
  height: 100%;
  align-self: center;
  border-radius: 999rpx;
  box-shadow: 0 0 24rpx rgba(255,255,255,0.18);
}

.player-avatar {
  width: 156rpx;
  height: 156rpx;
  align-self: center;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 54rpx;
  font-weight: 1000;
  background: rgba(255,255,255,0.09);
  border: 2rpx solid rgba(255,255,255,0.16);
  overflow: hidden;
}

.player-avatar-img {
  width: 100%;
  height: 100%;
}

.player-main {
  position: relative;
  z-index: 1;
  min-width: 0;
  align-self: center;
  overflow: hidden;
}

.player-row {
  display: block;
  padding-right: 132rpx;
}

.player-name {
  min-width: 0;
  color: #ffffff;
  font-size: 38rpx;
  line-height: 1.18;
  font-weight: 1000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-type {
  position: absolute;
  z-index: 2;
  top: 22rpx;
  right: 24rpx;
  flex: none;
  max-width: 150rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 950;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-meta,
.player-note-preview {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.56);
  font-size: 24rpx;
  line-height: 1.35;
}

.player-note-preview {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-tags {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
  height: 42rpx;
  margin-top: 10rpx;
  overflow: hidden;
}

.player-tag {
  flex: none;
  max-width: 188rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(255,255,255,0.88);
  font-size: 22rpx;
  font-weight: 900;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.14);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-empty {
  margin-top: 120rpx;
  text-align: center;
  padding: 56rpx 34rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.player-empty-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 1000;
}

.player-empty-text {
  margin: 16rpx auto 28rpx;
  max-width: 520rpx;
  color: rgba(255,255,255,0.54);
  font-size: 26rpx;
  line-height: 1.45;
}
