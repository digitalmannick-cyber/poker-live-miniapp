@import '../../app.wxss';

.card-preview-page { padding-top: 30rpx; padding-bottom: 52rpx; }
.card-preview-top { display: grid; grid-template-columns: 64rpx 1fr 64rpx; align-items: center; margin-bottom: 28rpx; }
.card-preview-back { color: #fff; font-size: 58rpx; line-height: 1; }
.card-preview-title { color: #fff; font-size: 34rpx; font-weight: 1000; text-align: center; }
.state-card, .player-card, .duplicate-card { position: relative; overflow: hidden; border: 1rpx solid rgba(255,255,255,.15); border-radius: 26rpx; background: linear-gradient(145deg, rgba(30,34,45,.98), rgba(10,11,16,.99)); }
.state-card { min-height: 300rpx; padding: 38rpx; box-sizing: border-box; }
.state-kicker, .duplicate-kicker, .field-label { color: #00d1ff; font-size: 20rpx; font-weight: 1000; letter-spacing: 3rpx; }
.state-title { margin-top: 14rpx; color: #fff; font-size: 38rpx; font-weight: 1000; }
.state-text { margin-top: 16rpx; color: rgba(255,255,255,.62); font-size: 25rpx; line-height: 1.6; }
.imported-card { text-align: center; }
.imported-mark { display: flex; align-items: center; justify-content: center; width: 88rpx; height: 88rpx; margin: 0 auto; color: #0b0b0f; background: #00d1ff; border-radius: 50%; font-size: 48rpx; font-weight: 1000; box-shadow: 0 0 36rpx rgba(0,209,255,.35); }
.sender-line { display: flex; align-items: center; gap: 18rpx; margin-bottom: 20rpx; padding: 0 8rpx; }
.sender-avatar { width: 74rpx; height: 74rpx; border: 2rpx solid rgba(0,209,255,.5); border-radius: 20rpx; background: #202530; }
.sender-avatar-text, .player-avatar-text { display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 1000; }
.sender-name { color: #fff; font-size: 27rpx; font-weight: 900; }
.sender-label { margin-top: 6rpx; color: rgba(255,255,255,.48); font-size: 22rpx; }
.player-card { padding: 34rpx; box-shadow: inset 0 0 0 1rpx rgba(230,0,18,.10); }
.card-accent { position: absolute; top: 0; left: 0; width: 150rpx; height: 10rpx; background: #e60012; transform: skewX(-28deg); transform-origin: left; box-shadow: 64rpx 0 0 #00d1ff; }
.player-head { display: flex; align-items: center; gap: 24rpx; }
.player-avatar { flex: none; width: 126rpx; height: 126rpx; border: 3rpx solid rgba(255,255,255,.75); border-radius: 28rpx; background: #222733; }
.player-name { color: #fff; font-size: 42rpx; font-weight: 1000; }
.player-type { display: inline-flex; margin-top: 12rpx; padding: 7rpx 16rpx; color: #fff; background: #e60012; border-radius: 8rpx; font-size: 22rpx; font-weight: 900; }
.field-label { margin-top: 30rpx; }
.tag-row { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 14rpx; }
.leak-tag { padding: 10rpx 16rpx; color: #fff; background: rgba(230,0,18,.16); border: 1rpx solid rgba(230,0,18,.46); border-radius: 9rpx; font-size: 22rpx; }
.empty-value { margin-top: 12rpx; color: rgba(255,255,255,.4); font-size: 24rpx; }
.note-label { color: #ff4050; }
.note-content { margin-top: 14rpx; color: rgba(255,255,255,.82); font-size: 25rpx; line-height: 1.7; white-space: pre-wrap; }
.duplicate-card { margin-top: 22rpx; padding: 28rpx; border-color: rgba(255,197,61,.34); }
.duplicate-kicker { color: #ffc53d; }
.duplicate-title { margin-top: 10rpx; color: #fff; font-size: 31rpx; font-weight: 1000; }
.duplicate-text, .overwrite-summary { margin-top: 12rpx; color: rgba(255,255,255,.58); font-size: 23rpx; line-height: 1.6; }
.overwrite-summary { padding: 18rpx; color: rgba(255,255,255,.78); background: rgba(255,197,61,.08); border-left: 6rpx solid #ffc53d; }
.import-actions { margin-top: 24rpx; }
.primary-action, .secondary-action { display: flex; align-items: center; justify-content: center; min-height: 86rpx; margin-top: 18rpx; border-radius: 15rpx; font-size: 27rpx; font-weight: 1000; }
.primary-action { color: #fff; background: linear-gradient(135deg, #e60012, #ff3947); box-shadow: 0 14rpx 28rpx rgba(230,0,18,.24); }
.danger-action { background: linear-gradient(135deg, #b90916, #e60012); }
.secondary-action { color: rgba(255,255,255,.86); background: rgba(255,255,255,.08); border: 1rpx solid rgba(255,255,255,.15); }
.is-disabled { opacity: .5; }
.progress-mask { position: fixed; z-index: 50; inset: 0; display: flex; align-items: center; justify-content: center; padding: 44rpx; background: rgba(3,4,8,.78); backdrop-filter: blur(8rpx); }
.progress-card { width: 100%; padding: 38rpx; border: 1rpx solid rgba(0,209,255,.38); border-radius: 24rpx; background: #11151e; box-sizing: border-box; box-shadow: 0 0 42rpx rgba(0,209,255,.15); }
.progress-title { color: #fff; font-size: 34rpx; font-weight: 1000; }
.progress-text { margin-top: 12rpx; color: rgba(255,255,255,.58); font-size: 24rpx; line-height: 1.6; }
