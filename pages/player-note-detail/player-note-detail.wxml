<view class="app-bg"></view>
<view class="container player-detail-shell">
  <view class="player-detail-top">
    <view class="player-detail-back" bindtap="goBack">‹</view>
    <view class="player-detail-title">{{editMode ? (mode === 'new' ? '新增玩家' : '编辑玩家') : (note && note.name || (mode === 'friend' ? '好友资料' : '玩家详情'))}}</view>
    <view wx:if="{{!editMode && detailState === 'ready' && note}}" class="player-detail-edit" bindtap="startEdit">编辑</view>
  </view>

  <view wx:if="{{detailState === 'loading'}}" class="detail-state-card">好友资料加载中…</view>
  <view wx:elif="{{detailState === 'unavailable' || detailState === 'error'}}" class="detail-state-card">
    <view>{{loadError}}</view>
    <view class="small-action detail-retry" bindtap="retryFriendLoad">重试</view>
  </view>

  <view wx:elif="{{editMode && detailState === 'ready' && (note || mode === 'new')}}" class="photo-editor">
    <view class="photo-pick" bindtap="choosePlayerPhoto">
      <image wx:if="{{form.avatarDisplayUrl || form.avatarUrl}}" class="photo-pick-img" src="{{form.avatarDisplayUrl || form.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="photo-placeholder">
        <view class="photo-placeholder-head"></view>
        <view class="photo-placeholder-body"></view>
      </view>
    </view>
    <view class="photo-actions">
      <view class="photo-action-primary" bindtap="choosePlayerPhoto">{{form.avatarUrl ? '更换照片' : '添加照片'}}</view>
      <view wx:if="{{form.avatarUrl}}" class="photo-action-secondary" bindtap="clearPlayerPhoto">移除</view>
    </view>
    <view class="photo-crop-hint">选择后可裁剪、缩放，确认头像预览区域</view>
  </view>

  <view wx:if="{{editMode && detailState === 'ready' && (note || mode === 'new')}}" class="detail-card form-card">
    <view class="field-block">
      <view class="field-label">玩家名字</view>
      <input class="field-input" value="{{form.name}}" placeholder="例如 老张" bindinput="onNameInput" />
    </view>
    <view class="field-block">
      <view class="field-label">玩家类型</view>
      <view class="type-grid">
        <view wx:for="{{typeOptions}}" wx:key="label" class="type-option {{item.active ? 'active' : ''}}" data-type="{{item.label}}" bindtap="selectType">{{item.label}}</view>
      </view>
    </view>
    <view class="field-block">
      <view class="field-label">leak 标签</view>
      <view class="leak-grid">
        <view wx:for="{{leakOptions}}" wx:key="label" class="leak-option {{item.active ? 'active' : ''}}" data-label="{{item.label}}" bindtap="toggleLeakTag">
          <text>{{item.label}}</text>
          <text class="leak-remove" data-label="{{item.label}}" catchtap="removeLeakTag">×</text>
        </view>
      </view>
      <view class="new-leak-row">
        <input class="field-input leak-input" value="{{newLeakTag}}" placeholder="新增 leak 标签" bindinput="onNewLeakInput" />
        <view class="small-action" bindtap="addLeakTag">添加</view>
      </view>
    </view>
    <view class="field-block">
      <view class="field-label">note</view>
      <textarea class="note-textarea" value="{{form.note}}" placeholder="记录倾向、showdown 信息、 exploit 计划" maxlength="1200" bindinput="onNoteInput"></textarea>
    </view>
    <view wx:if="{{saveError}}" class="save-error">{{saveError}}</view>
    <view class="detail-actions">
      <view class="secondary-action" bindtap="cancelEdit">取消</view>
      <view class="primary-action {{saving ? 'is-saving' : ''}}" bindtap="saveNote">{{saving ? '保存中' : '保存'}}</view>
    </view>
  </view>

  <view wx:elif="{{detailState === 'ready' && note}}" class="detail-card player-profile-card">
    <view class="profile-head">
      <view class="profile-avatar">
        <image wx:if="{{note.avatarDisplayUrl || note.avatarUrl}}" class="profile-avatar-img" src="{{note.avatarDisplayUrl || note.avatarUrl}}" mode="aspectFill"></image>
        <text wx:else>{{note.avatarText}}</text>
      </view>
      <view class="profile-main">
        <view class="profile-name">{{note.name}}</view>
        <view class="profile-meta">{{note.updatedDate || note.createdDate}} · {{battleHands.length}} 手对战</view>
        <view class="profile-type" style="background: {{note.typeColor}};">{{note.type}}</view>
      </view>
    </view>
    <view wx:if="{{note.leakTags.length}}" class="detail-tags">
      <view wx:for="{{note.leakTags}}" wx:key="*this" class="detail-tag">{{item}}</view>
    </view>
    <view class="note-content">{{note.note || '暂无 note'}}</view>
  </view>

  <view wx:if="{{!editMode && mode === 'friend' && note && friend}}" class="detail-card friend-public-card">
    <view class="section-head">
      <view>
        <view class="section-title-main">好友公开资料</view>
        <view class="section-sub">以下资料由好友授权展示，无法在本地编辑</view>
      </view>
      <view class="friend-title-badge">称号 · {{friend.title || '未设称号'}}</view>
    </view>
    <view wx:if="{{friend.statsVisible}}" class="friend-stats-grid">
      <view class="friend-stat-item">
        <view class="friend-stat-label">累计时长</view>
        <view class="friend-stat-value">{{friend.durationLabel}}</view>
      </view>
      <view class="friend-stat-item">
        <view class="friend-stat-label">记录手牌</view>
        <view class="friend-stat-value">{{friend.recordedHandCount || 0}} 手</view>
      </view>
    </view>
    <view wx:else class="friend-stats-hidden">对方已隐藏统计数据</view>
    <view wx:if="{{friend.friendshipDate}}" class="friend-since">成为好友：{{friend.friendshipDate}}</view>
  </view>

  <view wx:if="{{mode === 'view' && !editMode && detailState === 'ready' && id && note && note.sourceKind !== 'friend'}}" class="player-card-share-entry" bindtap="openPlayerCardShare">
    <view>
      <view class="player-card-share-entry-title">分享玩家名片</view>
      <view class="player-card-share-entry-sub">预览后发送给一位好友</view>
    </view>
    <view class="player-card-share-entry-arrow">›</view>
  </view>

  <view wx:if="{{!editMode && note}}" class="detail-card battle-section">
    <view class="section-head">
      <view>
        <view class="section-title-main">对战手牌</view>
        <view class="section-sub">展示 Hero 和该玩家打过的已记录手牌</view>
      </view>
      <view class="small-action" bindtap="openHandPicker">添加</view>
    </view>

    <view wx:if="{{battleHands.length}}" class="battle-list">
      <view wx:for="{{battleHands}}" wx:key="handId" class="battle-card">
        <view class="battle-vs-row">
          <view class="battle-vs-side battle-vs-hero">
            <view class="cards-inline tight battle-vs-cards">
              <view wx:for="{{item.versusSummary.heroCardsVisual}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-{{card.suitClass}}">
                <text class="mini-card-rank">{{card.rank}}</text>
                <text class="mini-card-suit">{{card.suitSymbol}}</text>
              </view>
            </view>
            <view wx:if="{{item.versusSummary.heroPosition}}" class="battle-position">{{item.versusSummary.heroPosition}}</view>
          </view>
          <view class="battle-vs-center">
            <view class="battle-vs-label">VS</view>
            <view class="battle-profit {{item.versusSummary.profitTone}}">{{item.versusSummary.currentProfitDisplay}}</view>
          </view>
          <view class="battle-vs-side battle-vs-opponent">
            <view wx:if="{{item.versusSummary.hasOpponentCards}}" class="cards-inline tight battle-vs-cards">
              <view wx:for="{{item.versusSummary.opponentCardsVisual}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-{{card.suitClass}}">
                <text class="mini-card-rank">{{card.rank}}</text>
                <text class="mini-card-suit">{{card.suitSymbol}}</text>
              </view>
            </view>
            <view wx:if="{{item.versusSummary.opponentPosition}}" class="battle-position opponent">{{item.versusSummary.opponentPosition}}</view>
          </view>
        </view>
        <view class="battle-board">
          <block wx:for="{{item.boardStreetVisual}}" wx:for-item="street" wx:key="street">
            <view wx:for="{{street.cards}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-board mini-card-{{card.suitClass}}">
              <text class="mini-card-rank mini-card-rank-board">{{card.rank}}</text>
              <text class="mini-card-suit mini-card-suit-board">{{card.suitSymbol}}</text>
            </view>
          </block>
        </view>
        <view class="battle-meta">{{item.playedDate}} · {{item.relationshipText}}</view>
        <view wx:if="{{item.hasActionLine}}" class="battle-action-line">{{item.actionLine}}</view>
        <view class="battle-actions">
          <view class="small-action" data-id="{{item.handId}}" bindtap="playBattleHand">播放</view>
          <view class="danger-link" data-id="{{item.handId}}" bindtap="removeBattleHand">移除</view>
        </view>
      </view>
    </view>
    <view wx:else class="battle-empty">还没有关联对战手牌。</view>
  </view>

  <view wx:if="{{!editMode && note && mode !== 'friend'}}" class="danger-zone" bindtap="deleteNote">删除玩家 note</view>
  <view wx:if="{{!editMode && note && mode === 'friend' && !detachPending}}" class="danger-zone" bindtap="confirmRemoveFriend">{{removingFriend ? '解除中…' : '解除好友'}}</view>
  <view wx:if="{{detachPending}}" class="detail-card detach-retry-card">
    <view class="save-error">{{detachError}}</view>
    <view class="primary-action" bindtap="retryDetachFriendNote">重试本地归档</view>
  </view>
  <view wx:if="{{removeError && !detachPending}}" class="detail-card detach-retry-card">
    <view class="save-error">{{removeError}}</view>
  </view>
</view>

<view wx:if="{{handPickerVisible}}" class="sheet">
  <view class="sheet-mask" bindtap="closeHandPicker"></view>
  <view class="sheet-panel" catchtap="stopModalTap">
    <view class="sheet-head">
      <view class="sheet-title">选择对战手牌</view>
      <view class="sheet-close" bindtap="closeHandPicker">关闭</view>
    </view>
    <scroll-view scroll-y="true" class="sheet-scroll">
      <view wx:for="{{handCandidates}}" wx:key="_id" class="candidate-card {{item.linked ? 'linked' : ''}}" data-id="{{item._id}}" data-disabled="{{item.disabled}}" bindtap="addBattleHand">
        <view class="battle-top">
          <view class="cards-inline tight">
            <view wx:for="{{item.heroCardsVisual}}" wx:for-item="card" wx:key="index" class="mini-card mini-card-{{card.suitClass}}">
              <text class="mini-card-rank">{{card.rank}}</text>
              <text class="mini-card-suit">{{card.suitSymbol}}</text>
            </view>
          </view>
          <view class="battle-profit {{item.currentProfit >= 0 ? 'positive' : 'negative'}}">{{item.currentProfitDisplay}}</view>
        </view>
        <view class="battle-meta">{{item.playedDate}} {{item.heroPosition}}</view>
        <view wx:if="{{item.linked}}" class="candidate-linked">已添加</view>
      </view>
      <view wx:if="{{!handCandidates.length}}" class="battle-empty">还没有可选择的手牌。</view>
    </scroll-view>
  </view>
</view>

<view wx:if="{{replayVisible}}" class="replay-modal">
  <view class="sheet-mask" bindtap="closeReplay"></view>
  <view class="replay-panel" catchtap="stopModalTap">
    <hand-replay-player replay="{{replayData}}" bindclose="closeReplay" />
  </view>
</view>

<view wx:if="{{cardShareVisible}}" class="sheet player-card-share-sheet">
  <view class="sheet-mask" bindtap="closePlayerCardShare"></view>
  <view class="sheet-panel player-card-share-panel" catchtap="stopModalTap">
    <view class="sheet-head">
      <view>
        <view class="sheet-title">分享玩家名片</view>
        <view class="card-share-sheet-sub">先确认内容，再选择一位好友</view>
      </view>
      <view class="sheet-close {{cardShareStatus === 'sending' ? 'is-disabled' : ''}}" bindtap="closePlayerCardShare">关闭</view>
    </view>

    <scroll-view scroll-y="true" class="card-share-scroll">
      <view class="card-share-preview">
        <view class="card-share-preview-head">
          <view class="card-preview-avatar">
            <image wx:if="{{cardSharePreview.avatarUrl}}" class="card-preview-avatar-img" src="{{cardSharePreview.avatarUrl}}" mode="aspectFill"></image>
            <text wx:else>{{cardSharePreview.avatarText}}</text>
          </view>
          <view class="card-share-preview-main">
            <view class="card-preview-label">玩家名称</view>
            <view class="card-preview-name">{{cardSharePreview.name}}</view>
            <view class="card-preview-type-label">玩家类型 · {{cardSharePreview.type}}</view>
          </view>
        </view>
        <view class="card-preview-section">
          <view class="card-preview-label">Leak 标签</view>
          <view wx:if="{{cardSharePreview.leakTags.length}}" class="card-preview-tags">
            <view wx:for="{{cardSharePreview.leakTags}}" wx:key="*this" class="detail-tag">{{item}}</view>
          </view>
          <view wx:else class="card-preview-empty">暂无标签</view>
        </view>
        <view class="card-preview-section">
          <view class="card-preview-label">完整 Note</view>
          <view class="card-preview-note">{{cardSharePreview.note || '暂无 Note'}}</view>
        </view>
      </view>

      <view class="card-friend-picker-title">选择接收好友</view>
      <view wx:if="{{cardShareStatus === 'loading'}}" class="card-share-state">正在加载好友…</view>
      <view wx:elif="{{cardShareStatus === 'error'}}" class="card-share-state is-error">
        <view>{{cardShareError}}</view>
        <view class="card-share-state-action" bindtap="refreshCardFriends">重试</view>
      </view>
      <view wx:elif="{{cardShareStatus === 'empty'}}" class="card-share-state">
        <view>还没有可分享的好友</view>
        <view class="card-share-state-action" bindtap="refreshCardFriends">刷新好友列表</view>
      </view>
      <view wx:else class="card-friend-list">
        <view wx:for="{{cardFriends}}" wx:key="socialUserId" class="card-friend-row {{selectedCardFriendId === item.socialUserId ? 'is-selected' : ''}}" data-id="{{item.socialUserId}}" bindtap="selectCardFriend">
          <view class="card-friend-avatar">
            <image wx:if="{{item.avatarUrl}}" class="card-friend-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill"></image>
            <text wx:else>{{item.avatarText}}</text>
          </view>
          <view class="card-friend-main">
            <view class="card-friend-name">{{item.nickname}}</view>
            <view wx:if="{{item.title}}" class="card-friend-title">{{item.title}}</view>
          </view>
          <view class="card-friend-radio"><view class="card-friend-radio-dot"></view></view>
        </view>
        <view wx:if="{{nextCardFriendOffset !== null}}" class="card-load-more {{cardFriendLoadingMore ? 'is-loading' : ''}}" bindtap="loadMoreCardFriends">{{cardFriendLoadingMore ? '加载中…' : '加载更多'}}</view>
        <view wx:if="{{cardFriendLoadMoreError}}" class="card-load-more-error" bindtap="loadMoreCardFriends">{{cardFriendLoadMoreError}} · 点击重试</view>
      </view>

      <view wx:if="{{cardShareStatus === 'failure'}}" class="card-share-failure">
        <view>{{cardShareError}}</view>
        <view wx:if="{{cardShareNeedsFriendRefresh}}" class="card-share-state-action" bindtap="refreshCardFriends">刷新好友列表</view>
      </view>
      <view wx:if="{{cardShareStatus === 'success'}}" class="card-share-success">名片已分享</view>
    </scroll-view>

    <view class="card-share-submit {{!selectedCardFriendId || cardShareStatus === 'sending' ? 'is-disabled' : ''}}" bindtap="confirmSharePlayerCard">
      {{cardShareStatus === 'sending' ? '发送中…' : '确认分享'}}
    </view>
  </view>
</view>
