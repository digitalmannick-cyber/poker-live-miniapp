@import '../../app.wxss';

.social-invite-page { padding-top: 40rpx; }

.invite-hero { position: relative; margin: 8rpx 0 30rpx; }
.invite-kicker { color: #00d1ff; font-size: 22rpx; font-weight: 1000; letter-spacing: 5rpx; }
.invite-title { margin-top: 12rpx; color: #fff; font-size: 58rpx; font-weight: 1000; line-height: 1; }
.invite-slash { width: 166rpx; height: 10rpx; margin-top: 16rpx; background: #e60012; transform: skewX(-28deg); box-shadow: 20rpx 10rpx 0 rgba(0, 209, 255, 0.55); }

.invite-card { position: relative; overflow: hidden; padding: 32rpx; border: 1rpx solid rgba(255,255,255,0.16); border-radius: 28rpx; background: linear-gradient(145deg, rgba(28,32,43,0.98), rgba(10,10,15,0.98)); box-shadow: inset 0 0 0 1rpx rgba(230,0,18,0.12); }
.invite-card::after { content: ''; position: absolute; right: -90rpx; top: -70rpx; width: 250rpx; height: 170rpx; background: linear-gradient(135deg, rgba(230,0,18,0.30), transparent 70%); transform: rotate(-12deg); pointer-events: none; }
.invite-card-kicker { position: relative; z-index: 1; color: rgba(255,255,255,0.48); font-size: 22rpx; font-weight: 1000; letter-spacing: 4rpx; }
.invite-card-title, .invite-state-title { position: relative; z-index: 1; margin-top: 14rpx; color: #fff; font-size: 38rpx; font-weight: 1000; }
.invite-card-text, .invite-state-text { position: relative; z-index: 1; margin-top: 18rpx; color: rgba(255,255,255,0.66); font-size: 26rpx; line-height: 1.65; }

.invite-qr { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; width: 312rpx; height: 312rpx; margin: 30rpx auto 0; border-radius: 20rpx; background: #fff; }
.invite-qr-empty { color: #171a22; font-size: 56rpx; font-weight: 1000; letter-spacing: 8rpx; background: repeating-linear-gradient(135deg, #fff 0 12rpx, #edf0f3 12rpx 24rpx); }
.invite-qr-caption { position: relative; z-index: 1; margin-top: 16rpx; color: rgba(255,255,255,0.48); font-size: 22rpx; text-align: center; }

.invite-profile { position: relative; z-index: 1; display: flex; align-items: center; gap: 18rpx; margin-top: 28rpx; }
.invite-avatar { flex: none; width: 100rpx; height: 100rpx; border-radius: 22rpx; background: rgba(255,255,255,0.10); border: 2rpx solid rgba(0,209,255,0.54); overflow: hidden; }
.invite-avatar-text { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 32rpx; font-weight: 1000; }
.invite-name { color: #fff; font-size: 34rpx; font-weight: 1000; }
.invite-title-text { margin-top: 8rpx; color: #00d1ff; font-size: 22rpx; font-weight: 800; }

.invite-action { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; min-height: 88rpx; margin-top: 30rpx; padding: 0; border-radius: 16rpx; font-size: 28rpx; font-weight: 1000; line-height: 88rpx; }
.invite-action::after { border: 0; }
.invite-action-primary { color: #fff; background: linear-gradient(135deg, #e60012, #ff3947); box-shadow: 0 14rpx 28rpx rgba(230,0,18,0.28); }
.invite-action-secondary { color: rgba(255,255,255,0.86); background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.16); }
.invite-action.is-disabled { opacity: 0.56; }
.invite-sent { position: relative; z-index: 1; margin-top: 28rpx; padding: 20rpx; color: #00d1ff; font-size: 26rpx; font-weight: 900; text-align: center; background: rgba(0,209,255,0.10); border: 1rpx solid rgba(0,209,255,0.25); border-radius: 16rpx; }
.invite-login-flow { position: relative; z-index: 1; margin-top: 24rpx; padding: 22rpx; border-radius: 18rpx; background: rgba(0,209,255,0.07); border: 1rpx solid rgba(0,209,255,0.20); }
.invite-login-title { color: #d9f8ff; font-size: 24rpx; font-weight: 1000; }
.invite-login-steps { display: grid; gap: 13rpx; margin-top: 16rpx; color: rgba(255,255,255,0.82); font-size: 23rpx; font-weight: 850; }
.invite-login-steps view { display: flex; align-items: center; gap: 14rpx; }
.invite-login-steps text { width: 34rpx; height: 34rpx; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; color: #07131a; background: #00d1ff; font-size: 19rpx; font-weight: 1000; }
.invite-login-tip { margin-top: 16rpx; color: rgba(255,255,255,0.48); font-size: 20rpx; line-height: 1.5; }
.invite-login-error { position: relative; z-index: 1; margin-top: 16rpx; color: #ff8793; font-size: 22rpx; text-align: center; }
.invite-state-card { min-height: 260rpx; box-sizing: border-box; }

.invite-search-card { margin-top: 24rpx; }
.invite-search-row { position: relative; z-index: 1; display: flex; gap: 12rpx; margin-top: 24rpx; }
.invite-search-input { flex: 1; min-width: 0; height: 76rpx; padding: 0 22rpx; box-sizing: border-box; border-radius: 15rpx; color: #fff; font-size: 25rpx; background: rgba(255,255,255,.065); border: 1rpx solid rgba(255,255,255,.14); }
.invite-search-button { flex: 0 0 118rpx; height: 76rpx; display: flex; align-items: center; justify-content: center; border-radius: 15rpx; color: #fff; font-size: 24rpx; font-weight: 950; background: linear-gradient(135deg, #e60012, #ff3045); }
.invite-search-button.is-disabled, .invite-search-add.is-disabled { opacity: .48; }
.invite-search-error, .invite-search-empty { position: relative; z-index: 1; padding: 22rpx 0 2rpx; color: #ff8793; font-size: 22rpx; text-align: center; }
.invite-search-empty { color: rgba(255,255,255,.44); }
.invite-search-results { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 12rpx; margin-top: 20rpx; }
.invite-search-result { display: flex; align-items: center; gap: 15rpx; min-width: 0; padding: 16rpx; border-radius: 17rpx; background: rgba(255,255,255,.045); border: 1rpx solid rgba(255,255,255,.09); }
.invite-search-avatar { flex: 0 0 72rpx; width: 72rpx; height: 72rpx; overflow: hidden; border-radius: 15rpx; background: #252b38; border: 1rpx solid rgba(255,255,255,.15); }
.invite-search-avatar-text { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 25rpx; font-weight: 950; }
.invite-search-copy { flex: 1; min-width: 0; }
.invite-search-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #fff; font-size: 25rpx; font-weight: 950; }
.invite-search-title { margin-top: 5rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: rgba(255,255,255,.44); font-size: 20rpx; }
.invite-search-add { flex: 0 0 100rpx; height: 58rpx; display: flex; align-items: center; justify-content: center; border-radius: 13rpx; color: #fff; font-size: 21rpx; font-weight: 950; background: #e60012; }
