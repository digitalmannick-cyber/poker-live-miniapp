<view class="app-bg"></view>
<view class="container social-invite-page">
  <view class="invite-hero">
    <view class="invite-kicker">SOCIAL LINK</view>
    <view class="invite-title">好友邀请</view>
    <view class="invite-slash"></view>
  </view>

  <view wx:if="{{loading}}" class="invite-card invite-state-card">
    <view class="invite-state-title">正在读取邀请</view>
    <view class="invite-state-text">请稍候，正在核验邀请信息。</view>
  </view>

  <view wx:elif="{{status === 'expired' || status === 'error'}}" class="invite-card invite-state-card">
    <view class="invite-state-title">{{status === 'expired' ? '邀请不可用' : '暂时无法继续'}}</view>
    <view class="invite-state-text">{{errorMessage}}</view>
    <view class="invite-action invite-action-secondary" bindtap="retry">重试</view>
  </view>

  <block wx:elif="{{mode === 'mine'}}">
  <view class="invite-card">
    <view class="invite-card-kicker">MY INVITE</view>
    <view class="invite-card-title">把好友带进你的牌局记录</view>
    <view class="invite-card-text">从微信分享卡片或个人小程序码进入后，对方需要主动发送申请；不会自动成为好友。</view>
    <image wx:if="{{qrCodeUrl}}" class="invite-qr" src="{{qrCodeUrl}}" mode="aspectFit"></image>
    <view wx:else class="invite-qr invite-qr-empty">QR</view>
    <view class="invite-qr-caption">{{qrUnavailable ? '小程序码暂不可用，仍可用微信卡片分享' : '个人邀请小程序码'}}</view>
    <button class="invite-action invite-action-primary" open-type="share">发送微信邀请</button>
  </view>

  <view class="invite-card invite-search-card">
    <view class="invite-card-kicker">FIND PLAYERS</view>
    <view class="invite-card-title">搜索小程序好友</view>
    <view class="invite-card-text">输入至少 2 个字，按对方在小程序中的昵称查找。</view>
    <view class="invite-search-row">
      <input class="invite-search-input" value="{{searchQuery}}" placeholder="输入小程序昵称" maxlength="24" bindinput="onSearchInput" bindconfirm="searchUsers" confirm-type="search" />
      <view class="invite-search-button {{searchStatus === 'loading' ? 'is-disabled' : ''}}" bindtap="searchUsers">{{searchStatus === 'loading' ? '搜索中' : '搜索'}}</view>
    </view>
    <view wx:if="{{searchError}}" class="invite-search-error">{{searchError}}</view>
    <view wx:if="{{searchStatus === 'ready' && !searchResults.length}}" class="invite-search-empty">没有找到匹配的玩家</view>
    <view wx:if="{{searchResults.length}}" class="invite-search-results">
      <view wx:for="{{searchResults}}" wx:key="socialUserId" class="invite-search-result">
        <image wx:if="{{item.avatarUrl}}" class="invite-search-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="invite-search-avatar invite-search-avatar-text">{{item.avatarText || '牌'}}</view>
        <view class="invite-search-copy">
          <view class="invite-search-name">{{item.nickname}}</view>
          <view class="invite-search-title">{{item.title || '小程序玩家'}}</view>
        </view>
        <view class="invite-search-add {{item.canRequest ? '' : 'is-disabled'}}" data-id="{{item.socialUserId}}" bindtap="addSearchedUser">{{item.requesting ? '发送中' : item.actionLabel}}</view>
      </view>
    </view>
  </view>
  </block>

  <view wx:else class="invite-card">
    <view class="invite-card-kicker">FRIEND REQUEST</view>
    <view class="invite-profile">
      <image wx:if="{{inviter.avatarUrl}}" class="invite-avatar" src="{{inviter.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="invite-avatar invite-avatar-text">{{inviter.avatarText || 'P5'}}</view>
      <view>
        <view class="invite-name">{{inviter.nickname || '牌友'}}</view>
        <view class="invite-title-text">{{inviter.title || '牌局记录玩家'}}</view>
      </view>
    </view>
    <view class="invite-card-text">发送申请后需对方确认。确认前，双方都不会看到彼此的牌局数据。</view>
    <view wx:if="{{loginRequired}}" class="invite-login-flow">
      <view class="invite-login-title">首次使用流程</view>
      <view class="invite-login-steps">
        <view><text>1</text>微信身份登录</view>
        <view><text>2</text>建立玩家资料</view>
        <view><text>3</text>发送好友申请</view>
      </view>
      <view class="invite-login-tip">邀请信息会保留，登录后会在当前页面继续。</view>
    </view>
    <view wx:if="{{loginError}}" class="invite-login-error">{{loginError}}</view>
    <view wx:if="{{status === 'sent'}}" class="invite-sent">申请已发送，等待对方确认</view>
    <view wx:else class="invite-action invite-action-primary {{submitting ? 'is-disabled' : ''}}" bindtap="sendFriendRequest">{{submitting ? (loginRequired ? '正在登录' : '正在发送') : (loginRequired ? '微信登录并发送申请' : '发送好友申请')}}</view>
  </view>
</view>
