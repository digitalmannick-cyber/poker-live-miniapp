<view class="tab-shell">
  <view class="tab-rail">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{item.active ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      bindtap="switchTab"
    >
      <text class="tab-short">{{item.short}}</text>
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
</view>
