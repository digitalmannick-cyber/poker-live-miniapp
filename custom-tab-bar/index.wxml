<view class="tab-shell">
  <view class="tab-rail">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{item.active ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      bindtap="switchTab"
    >
      <view
        wx:if="{{socialUnread && item.pagePath === '/pages/player-notes/player-notes'}}"
        class="tab-social-badge"
        aria-label="玩家有{{socialUnreadLabel}}条未读消息"
      >{{socialUnreadLabel}}</view>
      <text class="tab-short">{{item.short}}</text>
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
</view>
