.tab-shell {
  position: relative;
  padding: 0 22rpx calc(18rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(11, 11, 15, 0), rgba(11, 11, 15, 0.92) 28rpx, rgba(11, 11, 15, 0.98));
}

.tab-rail {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(18, 23, 34, 0.96), rgba(8, 10, 17, 0.98));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 18rpx 46rpx rgba(0,0,0,0.34);
}

.tab-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 14rpx 8rpx 16rpx;
  border-radius: 22rpx;
  color: rgba(255,255,255,0.44);
  transition: transform 120ms ease, background 120ms ease;
}

.tab-item.active {
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
  color: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.06);
}

.tab-item.active .tab-short {
  color: #00d1ff;
}

.tab-item:active {
  transform: scale(0.98);
}

.tab-short {
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1.4rpx;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 700;
}
