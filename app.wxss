page {
  background:
    linear-gradient(135deg, rgba(230, 0, 18, 0.18) 0 18%, transparent 18% 100%),
    radial-gradient(circle at 74% 14%, rgba(0, 209, 255, 0.10), transparent 38%),
    radial-gradient(circle at 20% 86%, rgba(255, 212, 0, 0.06), transparent 48%),
    linear-gradient(180deg, #0b0b0f, #07070a);
  color: #ffffff;
  font-size: 28rpx;
}

.app-bg {
  display: none;
  pointer-events: none;
}

.app-bg-char {
  position: fixed;
  left: -120rpx;
  right: -120rpx;
  top: 60rpx;
  bottom: -260rpx;
  z-index: 0;
  opacity: 0.82;
  pointer-events: none;
  animation: appCharFloat 4.2s ease-in-out infinite;
}

@keyframes appCharFloat {
  0% {
    transform: translate3d(0, -14rpx, 0);
  }
  50% {
    transform: translate3d(0, 14rpx, 0);
  }
  100% {
    transform: translate3d(0, -14rpx, 0);
  }
}

@keyframes appBgDrift {
  0% {
    transform: translate3d(-1.0%, -0.6%, 0) scale(1.06);
  }
  50% {
    transform: translate3d(1.0%, 0.7%, 0) scale(1.08);
  }
  100% {
    transform: translate3d(-1.0%, -0.6%, 0) scale(1.06);
  }
}

@media (prefers-reduced-motion: reduce) {
  .app-bg {
    animation: none;
  }
  .app-bg-char {
    animation: none;
  }
}

.container {
  padding: 28rpx;
  padding-bottom: calc(188rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.card {
  position: relative;
  background: linear-gradient(180deg, rgba(20, 20, 27, 0.96), rgba(11, 11, 15, 0.96));
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 28rpx;
  padding: 26rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: inherit;
  pointer-events: none;
  opacity: 0.22;
  background: repeating-linear-gradient(135deg, rgba(255,255,255,0.06) 0 1rpx, transparent 1rpx 18rpx);
}

.card::after {
  content: '';
  position: absolute;
  left: -120rpx;
  top: -80rpx;
  width: 360rpx;
  height: 240rpx;
  pointer-events: none;
  opacity: 0.55;
  background: linear-gradient(135deg, rgba(230, 0, 18, 0.92), rgba(230, 0, 18, 0));
  transform: rotate(-12deg);
}

.card-title {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-left: 6rpx solid #e60012;
  background: linear-gradient(90deg, rgba(230, 0, 18, 0.24), rgba(230, 0, 18, 0));
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.muted {
  color: rgba(255,255,255,0.68);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.unified-field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.unified-field-card {
  position: relative;
  min-height: 118rpx;
  padding: 18rpx 16rpx 14rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(0, 209, 255, 0.065), rgba(255,255,255,0.035));
  border: 1rpx solid rgba(0, 209, 255, 0.30);
  box-sizing: border-box;
}

.unified-field-card.full-span {
  grid-column: span 2;
}

.unified-field-action {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  color: rgba(0, 209, 255, 0.94);
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1.2;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.24);
}

.unified-field-value {
  display: flex;
  align-items: center;
  min-height: 54rpx;
  height: 54rpx;
  margin-top: 8rpx;
  padding: 0 6rpx;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 54rpx;
  background: rgba(0,0,0,0.10);
  border-bottom: 2rpx solid rgba(0, 209, 255, 0.30);
  box-sizing: border-box;
}

.detail-checkbox-group {
  min-height: 54rpx;
  height: 54rpx;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  padding: 0 6rpx;
  background: rgba(0,0,0,0.10);
  border-bottom: 2rpx solid rgba(0, 209, 255, 0.30);
  box-sizing: border-box;
}

.detail-checkbox {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.detail-checkbox checkbox {
  transform: scale(0.72);
  transform-origin: left center;
  margin-right: -8rpx;
}

.detail-checkbox .wx-checkbox-input {
  width: 34rpx !important;
  height: 34rpx !important;
  border-radius: 8rpx !important;
  border-color: rgba(0, 209, 255, 0.52) !important;
  background: rgba(0, 0, 0, 0.18) !important;
}

.detail-checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background: rgba(0, 209, 255, 0.18) !important;
  border-color: rgba(0, 209, 255, 0.92) !important;
}

.detail-checkbox .wx-checkbox-input.wx-checkbox-input-checked::before {
  color: #00d1ff !important;
}

.readonly-field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.readonly-field-card {
  min-height: 108rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
}

.readonly-field-label {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
}

.readonly-field-value {
  margin-top: 12rpx;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.45;
  word-break: break-word;
}

.edit-detail-card {
  margin-top: 0;
  margin-bottom: 0;
  border-radius: 0;
  border-color: rgba(0, 209, 255, 0.22);
  background: rgba(11, 24, 30, 0.78);
}

.edit-detail-main {
  order: 10;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  border-bottom-color: rgba(0, 209, 255, 0.08);
}

.edit-detail-analysis {
  order: 20;
  border-top-color: rgba(0, 209, 255, 0.08);
  border-bottom-color: rgba(0, 209, 255, 0.08);
}

.edit-detail-streets {
  order: 30;
  border-top-color: rgba(0, 209, 255, 0.08);
  border-bottom-left-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
}

.edit-detail-extra {
  order: 40;
}

.edit-detail-card .section-title {
  display: none;
}

.edit-detail-streets > .label:not(.edit-detail-section-label),
.edit-detail-streets > .board-editor-list {
  display: none;
}

.edit-detail-label,
.edit-detail-section-label {
  margin-top: 20rpx;
}

.edit-hero-trigger {
  min-height: 86rpx;
  position: relative;
  justify-content: center;
  border-radius: 14rpx;
  border-color: rgba(0, 209, 255, 0.34);
  background: rgba(0, 209, 255, 0.06);
}

.edit-select-affordance {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: rgba(0, 209, 255, 0.94);
  font-size: 20rpx;
  font-weight: 900;
  background: rgba(0, 209, 255, 0.10);
  border: 1rpx solid rgba(0, 209, 255, 0.26);
}

.edit-detail-card .analysis-textarea {
  min-height: 96rpx;
  margin-bottom: 16rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,0.035);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.edit-detail-card .hero-question-textarea {
  min-height: 86rpx;
}

.edit-tag-input-hidden {
  display: none;
}

.edit-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.edit-tag-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(0, 209, 255, 0.92);
  font-size: 22rpx;
  font-weight: 900;
  background: rgba(0, 209, 255, 0.09);
  border: 1rpx solid rgba(0, 209, 255, 0.28);
}

.edit-tag-chip.active {
  color: #071116;
  background: #00d1ff;
  border-color: #00d1ff;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(230, 0, 18, 0.20);
  border: 1rpx solid rgba(230, 0, 18, 0.30);
  color: #ffffff;
}

.badge-outline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.80);
}

.kpi-value {
  font-size: 44rpx;
  font-weight: 900;
  color: #ffffff;
}

.kpi-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.62);
  margin-top: 10rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
  padding: 22rpx 24rpx;
  transition: transform 120ms ease, box-shadow 120ms ease, opacity 120ms ease;
}

.primary-btn {
  background: linear-gradient(135deg, #e60012, #ff2a2a);
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 16rpx 34rpx rgba(230, 0, 18, 0.22);
}

.secondary-btn {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.84);
  border: 1rpx solid rgba(255,255,255,0.16);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08);
}

.danger-btn {
  background: rgba(230, 0, 18, 0.16);
  color: #ffffff;
  border: 1rpx solid rgba(230, 0, 18, 0.30);
}

.primary-btn::after,
.secondary-btn::after,
.danger-btn::after {
  border: none;
}

.primary-btn:active,
.secondary-btn:active,
.danger-btn:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
  color: #ffffff;
}

.section-kicker {
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: #00d1ff;
  margin-bottom: 10rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.78);
  font-size: 22rpx;
}

.status-pill strong {
  color: #ffffff;
}

.input,
.picker,
.textarea {
  width: 100%;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.16);
  border-radius: 20rpx;
  color: rgba(255,255,255,0.90);
  box-sizing: border-box;
  box-sizing: border-box;
  margin-bottom: 18rpx;
}

.input,
.picker {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 22rpx;
}

.picker {
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 220rpx;
  padding: 22rpx;
  line-height: 1.6;
}

.input.unified-field-value,
input.unified-field-value {
  display: flex;
  align-items: center;
  height: 54rpx;
  min-height: 54rpx;
  margin-top: 8rpx;
  margin-bottom: 0;
  padding: 0 6rpx;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 54rpx;
  background: rgba(0,0,0,0.10);
  border: 0;
  border-radius: 0;
  border-bottom: 2rpx solid rgba(0, 209, 255, 0.30);
  box-sizing: border-box;
}

.label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.64);
  margin-bottom: 10rpx;
}

.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.inline-actions.nowrap {
  flex-wrap: nowrap;
}

.pill {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
}

.pill.active {
  background: rgba(0, 209, 255, 0.14);
  color: rgba(255,255,255,0.92);
  border-color: rgba(0, 209, 255, 0.28);
}

.list-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.12);
  margin-bottom: 16rpx;
}

.list-item:last-child {
  margin-bottom: 0;
}

.small {
  font-size: 24rpx;
}

.cards-inline {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.cards-inline.tight {
  gap: 8rpx;
}

.mini-card {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  width: 46rpx;
  height: 66rpx;
  padding: 7rpx 7rpx 8rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  color: #ffffff;
  font-weight: 800;
  line-height: 1;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.20);
}

.mini-card-rank {
  font-size: 30rpx;
  line-height: 1;
}

.mini-card-suit {
  font-size: 20rpx;
  line-height: 1;
  opacity: 0.88;
  align-self: flex-end;
  margin: 0;
}

.mini-card-spade {
  background: linear-gradient(180deg, #595959, #363636);
}

.mini-card-heart {
  background: linear-gradient(180deg, #c51600, #980d00);
}

.mini-card-diamond {
  background: linear-gradient(180deg, #3651df, #2236b1);
}

.mini-card-club {
  background: linear-gradient(180deg, #17c93a, #0aa52a);
}

.positive {
  color: #00d1ff;
}

.negative {
  color: #ff3b3b;
}

.empty {
  padding: 60rpx 20rpx;
  text-align: center;
  color: rgba(255,255,255,0.62);
}

.chip-scroll {
  width: 100%;
  white-space: nowrap;
}

.board-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.board-line + .board-line {
  margin-top: 14rpx;
}

.board-street-label {
  font-size: 24rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.74);
  min-width: 28rpx;
}

.board-empty-text {
  color: rgba(255,255,255,0.52);
}

.board-mini-stack {
  display: grid;
  gap: 10rpx;
}

.board-mini-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.board-mini-label {
  min-width: 24rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.56);
}

.tab-bar-spacer {
  height: calc(188rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
