.replay-shell {
  width: 100%;
  max-width: 690rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.14);
  background:
    radial-gradient(circle at 50% 16%, rgba(0,209,255,0.14), transparent 34%),
    linear-gradient(180deg, rgba(16,18,26,0.98), rgba(5,6,8,0.98));
  box-shadow: 0 34rpx 96rpx rgba(0,0,0,0.62);
  box-sizing: border-box;
}

.replay-head {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 50rpx;
  margin-bottom: 16rpx;
  padding-right: 58rpx;
}

.replay-title {
  color: #54eaff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.1;
}

.replay-sub {
  max-width: 460rpx;
  margin-top: 6rpx;
  color: rgba(248,250,252,0.78);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.replay-close {
  position: absolute;
  right: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.82);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.replay-table {
  position: relative;
  height: 560rpx;
  overflow: hidden;
}

.replay-felt {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 640rpx;
  height: 410rpx;
  transform: translate(-50%, -50%);
  border-radius: 999rpx;
  border: 8rpx solid rgba(255,255,255,0.10);
  background:
    radial-gradient(ellipse at 50% 48%, rgba(0,209,255,0.18), transparent 39%),
    radial-gradient(ellipse at 50% 50%, rgba(255,255,255,0.08), transparent 60%),
    linear-gradient(135deg, rgba(230,0,18,0.38), #182131 36%, #0d121d 100%);
  box-shadow:
    inset 0 0 72rpx rgba(0,0,0,0.52),
    inset 0 0 0 2rpx rgba(255,255,255,0.05),
    0 28rpx 70rpx rgba(0,0,0,0.44);
}

.replay-felt::before {
  content: '';
  position: absolute;
  inset: 28rpx;
  border-radius: 999rpx;
  border: 1rpx dashed rgba(255,255,255,0.16);
}

.replay-action {
  position: absolute;
  left: 50%;
  top: 0;
  z-index: 8;
  width: 560rpx;
  transform: translateX(-50%);
  display: grid;
  gap: 6rpx;
  justify-items: center;
  text-align: center;
}

.replay-action-main {
  max-width: 100%;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 10rpx 26rpx rgba(0,0,0,0.62);
}

.replay-center {
  position: absolute;
  left: 50%;
  top: 48%;
  z-index: 4;
  width: 420rpx;
  transform: translate(-50%, -50%);
  display: grid;
  justify-items: center;
  gap: 12rpx;
}

.replay-pot {
  min-width: 176rpx;
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #00d1ff, #5eead4);
  color: #061014;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 54rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(0,209,255,0.25);
}

.replay-board {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 76rpx;
}

.replay-card,
.replay-slot {
  width: 50rpx;
  height: 72rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.replay-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 7rpx;
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.16);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.22), 0 10rpx 20rpx rgba(0,0,0,0.24);
}

.replay-card-spade { background: linear-gradient(180deg, #525866, #252a33); }
.replay-card-heart { background: linear-gradient(180deg, #f02d34, #a60f20); }
.replay-card-diamond { background: linear-gradient(180deg, #3178ff, #1e3ba8); }
.replay-card-club { background: linear-gradient(180deg, #29d85d, #0d8c35); }

.replay-card-rank {
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.replay-card-suit {
  align-self: flex-end;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
}

.replay-slot {
  border: 1rpx dashed rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.045);
}

.replay-seat {
  position: absolute;
  z-index: 6;
  width: 136rpx;
  height: 92rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.07), transparent 48%),
    rgba(12,14,22,0.92);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.16),
    inset 0 -14rpx 28rpx rgba(0,0,0,0.22),
    0 18rpx 38rpx rgba(0,0,0,0.32);
  box-sizing: border-box;
}

.replay-seat.hero {
  border-color: rgba(230,0,18,0.52);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.08), transparent 45%),
    linear-gradient(135deg, rgba(230,0,18,0.24), rgba(12,14,22,0.94));
}

.replay-seat.active {
  border-color: rgba(0,209,255,0.88);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.09), transparent 45%),
    rgba(0,209,255,0.14);
  box-shadow:
    0 0 0 4rpx rgba(0,209,255,0.14),
    0 0 36rpx rgba(0,209,255,0.32);
}

.replay-action-chip {
  position: absolute;
  left: 50%;
  top: -46rpx;
  z-index: 12;
  min-width: 92rpx;
  max-width: 168rpx;
  height: 38rpx;
  padding: 0 16rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  border: 2rpx solid rgba(255,255,255,0.72);
  background: linear-gradient(135deg, #54eaff, #22c55e);
  color: #031016;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-shadow:
    0 0 0 3rpx rgba(0,0,0,0.38),
    0 12rpx 26rpx rgba(0,0,0,0.42);
}

.seat-sb .replay-action-chip {
  left: 74%;
}

.seat-bb .replay-action-chip {
  left: 118rpx;
}

.action-bet,
.action-raise,
.action-open,
.action-allin {
  background: linear-gradient(135deg, #ffd166, #ff9f1c);
  color: #100b00;
}

.action-call {
  background: linear-gradient(135deg, #54eaff, #5eead4);
  color: #031016;
}

.action-check {
  background: linear-gradient(135deg, #d1d5db, #64748b);
  color: #070b10;
}

.action-fold {
  background: linear-gradient(135deg, #f87171, #b91c1c);
  color: #ffffff;
}

.seat-utg { left: 20%; top: 28%; transform: translate(-50%, -50%); }
.seat-utgplus1 { left: 50%; top: 20%; transform: translate(-50%, -50%); }
.seat-mp { left: 80%; top: 28%; transform: translate(-50%, -50%); }
.seat-hj { right: 0; top: 50%; transform: translateY(-50%); }
.seat-co { left: 80%; bottom: 26%; transform: translate(-50%, 50%); }
.seat-btn { left: 50%; bottom: 17%; transform: translate(-50%, 50%); }
.seat-sb { left: 20%; bottom: 26%; transform: translate(-50%, 50%); }
.seat-bb { left: 0; top: 50%; transform: translateY(-50%); }

.replay-seat-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-bottom: 2rpx;
}

.replay-seat-avatar {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  margin: -2rpx auto 0;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid rgba(255,255,255,0.72);
  box-shadow: 0 8rpx 18rpx rgba(0,0,0,0.32);
}

.replay-seat-avatar-img {
  width: 100%;
  height: 100%;
}

.replay-seat-position-badge {
  position: absolute;
  left: 50%;
  bottom: -1rpx;
  min-width: 36rpx;
  max-width: 48rpx;
  height: 20rpx;
  padding: 0 6rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: rgba(3,5,9,0.86);
  color: #ffffff;
  font-size: 14rpx;
  font-weight: 1000;
  line-height: 20rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.replay-seat-pos {
  color: #54eaff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
}

.replay-seat-stack {
  max-width: 88rpx;
  margin: 2rpx auto 0;
  color: rgba(248,250,252,0.58);
  font-size: 14rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.replay-seat-name {
  max-width: 104rpx;
  margin: 3rpx auto 0;
  color: #f8fafc;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 1.1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.replay-hero-cards {
  position: absolute;
  left: 50%;
  top: 74rpx;
  transform: translateX(-50%);
  display: flex;
  gap: 3rpx;
  z-index: 8;
}

.seat-bb .replay-hero-cards {
  left: 132rpx;
  top: 18rpx;
  transform: none;
}

.seat-sb .replay-hero-cards {
  left: 86%;
  top: -58rpx;
}

.seat-btn .replay-hero-cards {
  top: -58rpx;
}

.seat-co .replay-hero-cards,
.seat-hj .replay-hero-cards,
.seat-mp .replay-hero-cards {
  left: -46rpx;
  top: 12rpx;
  transform: none;
}

.seat-utg .replay-hero-cards,
.seat-utgplus1 .replay-hero-cards {
  top: 76rpx;
}

.replay-hero-card {
  width: 34rpx;
  height: 48rpx;
  padding: 5rpx;
}

.replay-dealer {
  position: absolute;
  right: 8rpx;
  bottom: -9rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #111111;
  font-size: 16rpx;
  font-weight: 900;
  line-height: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(0,0,0,0.30);
}

.replay-controls {
  display: grid;
  justify-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.replay-progress {
  width: 100%;
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.10);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.replay-progress-fill {
  height: 100%;
  width: 0%;
  border-radius: inherit;
  background: linear-gradient(90deg, #e60012, #ffd166, #00d1ff);
  transition: width 180ms ease-out;
}

.replay-buttons {
  position: relative;
  width: 330rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(255,255,255,0.16);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.06), transparent 48%),
    rgba(3,5,9,0.90);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.12),
    0 14rpx 28rpx rgba(0,0,0,0.34);
  box-sizing: border-box;
}

.replay-control {
  width: 56rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  border: 0;
  background: transparent;
  color: rgba(255,255,255,0.76);
  font-size: 0;
  font-weight: 900;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.replay-control.primary {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 86rpx;
  height: 86rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background:
    radial-gradient(circle at 38% 30%, rgba(255,255,255,0.26), transparent 22%),
    linear-gradient(135deg, #ff2a2a, #d90000);
  border: 3rpx solid rgba(255,255,255,0.16);
  box-shadow:
    0 0 0 3rpx rgba(230,0,18,0.28),
    0 10rpx 22rpx rgba(230,0,18,0.30),
    0 12rpx 26rpx rgba(0,0,0,0.42);
}

.replay-control.icon,
.replay-control.side {
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-glyph {
  display: block;
  box-sizing: border-box;
}

.glyph-prev,
.glyph-next {
  position: relative;
  width: 34rpx;
  height: 42rpx;
  filter: drop-shadow(0 0 10rpx rgba(255,255,255,0.28));
}

.glyph-prev view,
.glyph-next view {
  position: absolute;
  left: 2rpx;
  top: 50%;
  width: 30rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform-origin: 50% 50%;
}

.glyph-prev view:first-child {
  transform: translateY(-8rpx) rotate(-45deg);
}

.glyph-prev view:last-child {
  transform: translateY(8rpx) rotate(45deg);
}

.glyph-next view:first-child {
  transform: translateY(-8rpx) rotate(45deg);
}

.glyph-next view:last-child {
  transform: translateY(8rpx) rotate(-45deg);
}

.glyph-play {
  width: 0;
  height: 0;
  margin-left: 8rpx;
  border-top: 24rpx solid transparent;
  border-bottom: 24rpx solid transparent;
  border-left: 32rpx solid #ffffff;
  filter: drop-shadow(0 0 12rpx rgba(255,255,255,0.22));
}

.glyph-pause {
  display: flex;
  gap: 10rpx;
  align-items: center;
  justify-content: center;
}

.glyph-pause view {
  width: 10rpx;
  height: 38rpx;
  border-radius: 6rpx;
  background: #ffffff;
  box-shadow: 0 0 12rpx rgba(255,255,255,0.22);
}
