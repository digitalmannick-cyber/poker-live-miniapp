.replay-shell {
  width: 100%;
  max-width: 690rpx;
  padding: 24rpx 22rpx 26rpx;
  border: 1rpx solid rgba(196, 215, 231, .22);
  border-radius: 28rpx;
  box-sizing: border-box;
  overflow: hidden;
  color: #f8fbff;
  background:
    radial-gradient(circle at 50% 23%, rgba(0, 209, 255, .12), transparent 28%),
    linear-gradient(158deg, rgba(31, 34, 44, .99), rgba(6, 8, 12, .99) 58%);
  box-shadow: 0 34rpx 96rpx rgba(0, 0, 0, .62), inset 0 1rpx 0 rgba(255, 255, 255, .08);
}

.replay-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  margin-bottom: 8rpx;
}

.replay-title { color: rgba(255, 255, 255, .66); font-size: 20rpx; font-weight: 900; letter-spacing: 4rpx; }
.replay-sub { margin-top: 5rpx; color: #fff; font-size: 31rpx; font-weight: 1000; letter-spacing: 1rpx; }
.replay-head-meta { display: flex; align-items: center; gap: 12rpx; }
.replay-street-badge { min-width: 64rpx; height: 46rpx; padding: 0 12rpx; border: 1rpx solid rgba(0, 225, 255, .48); border-radius: 10rpx; color: #39e6ff; background: rgba(0, 209, 255, .08); font-size: 19rpx; font-weight: 1000; line-height: 46rpx; text-align: center; }
.replay-close { width: 46rpx; height: 46rpx; border: 1rpx solid rgba(255, 255, 255, .18); border-radius: 10rpx; color: #fff; background: rgba(255, 255, 255, .06); font-size: 34rpx; font-weight: 500; line-height: 42rpx; text-align: center; }

.replay-table { position: relative; height: 810rpx; margin: 2rpx -4rpx 0; perspective: 1100rpx; }
.replay-table-art { position: absolute; z-index: 1; inset: 0; width: 100%; height: 100%; opacity: 0; transition: opacity 260ms ease-out; }
.table-asset-ready .replay-table-art { opacity: 1; }
.table-asset-ready .replay-table-shadow,
.table-asset-ready .replay-rail,
.table-asset-ready .replay-felt { opacity: 0; }
.replay-table-shadow, .replay-rail, .replay-felt { position: absolute; left: 50%; top: 50%; border-radius: 48% / 42%; transform: translate(-50%, -50%); }
.replay-table-shadow { width: 600rpx; height: 720rpx; background: rgba(0, 0, 0, .56); filter: blur(22rpx); transform: translate(-50%, -46%) scaleY(.94); }
.replay-rail {
  width: 580rpx;
  height: 724rpx;
  border: 8rpx solid rgba(198, 214, 226, .42);
  background: linear-gradient(112deg, #202a32, #78828a 18%, #161d24 44%, #929ba1 66%, #192129);
  box-shadow: inset 0 0 0 8rpx rgba(3, 6, 10, .82), inset 0 0 32rpx rgba(255, 255, 255, .15), 0 26rpx 44rpx rgba(0, 0, 0, .58);
  transform: translate(-50%, -50%) rotateX(4deg);
}
.replay-felt {
  width: 526rpx;
  height: 670rpx;
  border: 2rpx solid rgba(119, 218, 228, .28);
  background:
    radial-gradient(ellipse at 50% 42%, rgba(57, 230, 255, .16), transparent 42%),
    linear-gradient(145deg, #1b3b43, #102c34 48%, #0d242c);
  box-shadow: inset 0 0 88rpx rgba(0, 0, 0, .48), inset 0 0 0 2rpx rgba(255, 255, 255, .07);
  transform: translate(-50%, -50%) rotateX(4deg);
}
.replay-felt::after { content: ''; position: absolute; inset: 24rpx; border: 1rpx dashed rgba(175, 237, 243, .23); border-radius: inherit; }

.replay-street-wipe { position: absolute; z-index: 20; left: -38%; top: 42%; width: 48%; height: 88rpx; opacity: 0; background: linear-gradient(90deg, transparent, rgba(230, 0, 18, .96) 28%, #ff2738); transform: skewX(-24deg); pointer-events: none; }
.street-change .replay-street-wipe { animation: street-wipe 340ms cubic-bezier(.2, .8, .2, 1); }
.replay-chip-flight { position: absolute; z-index: 11; width: 235rpx; height: 24rpx; transform-origin: 0 50%; pointer-events: none; }
.replay-flying-chip { position: absolute; left: 0; top: -5rpx; width: 38rpx; height: 38rpx; filter: drop-shadow(0 0 13rpx rgba(230,0,18,.78)); }
.motion-even .replay-flying-chip { animation: chip-to-pot-a 360ms cubic-bezier(.2,.8,.2,1) both; }
.motion-odd .replay-flying-chip { animation: chip-to-pot-b 360ms cubic-bezier(.2,.8,.2,1) both; }
.flight-utg { left: 18%; top: 25%; transform: rotate(43deg); }
.flight-utgplus1 { left: 49%; top: 18%; transform: rotate(90deg); }
.flight-mp { left: 81%; top: 25%; transform: rotate(137deg); }
.flight-hj { left: 86%; top: 49%; transform: rotate(180deg); }
.flight-co { left: 81%; top: 73%; transform: rotate(223deg); }
.flight-btn { left: 49%; top: 82%; transform: rotate(270deg); }
.flight-sb { left: 18%; top: 73%; transform: rotate(317deg); }
.flight-bb { left: 14%; top: 49%; transform: rotate(0deg); }

.replay-action { display: none; }
.replay-action-kicker { color: #37e5ff; font-size: 16rpx; font-weight: 1000; letter-spacing: 4rpx; }
.replay-action-main { margin-top: 3rpx; overflow: hidden; color: #fff; font-size: 23rpx; font-weight: 1000; text-overflow: ellipsis; text-shadow: 0 7rpx 18rpx rgba(0, 0, 0, .8); white-space: nowrap; }
.motion-even .replay-action-main { animation: action-pop-a 260ms ease-out; }
.motion-odd .replay-action-main { animation: action-pop-b 260ms ease-out; }

.replay-center { position: absolute; z-index: 7; left: 50%; top: 48%; width: 380rpx; transform: translate(-50%, -50%); text-align: center; }
.replay-pot-label { color: rgba(255, 255, 255, .48); font-size: 16rpx; font-weight: 900; letter-spacing: 3rpx; }
.replay-pot { display: inline-flex; align-items: center; justify-content: center; min-width: 148rpx; height: 48rpx; margin-top: 5rpx; padding: 0 18rpx; border: 1rpx solid rgba(118, 232, 240, .35); border-radius: 9rpx; color: #fff; background: rgba(4, 18, 23, .78); font-size: 25rpx; font-weight: 1000; box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, .36); }
.replay-board { display: flex; align-items: center; justify-content: center; gap: 7rpx; min-height: 86rpx; margin-top: 18rpx; }
.replay-card, .replay-slot { width: 54rpx; height: 78rpx; border-radius: 8rpx; box-sizing: border-box; }
.replay-card { display: flex; flex-direction: column; justify-content: space-between; padding: 7rpx; border: 1rpx solid rgba(255, 255, 255, .48); color: #fff; box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .26), 0 10rpx 18rpx rgba(0, 0, 0, .34); }
.replay-board-card { animation: card-deal 320ms cubic-bezier(.2, .9, .2, 1) both; }
.replay-board-card:nth-child(2) { animation-delay: 45ms; }
.replay-board-card:nth-child(3) { animation-delay: 90ms; }
.replay-board-card:nth-child(4) { animation-delay: 135ms; }
.replay-board-card:nth-child(5) { animation-delay: 180ms; }
.replay-card-spade { background: linear-gradient(160deg, #68717f, #292f39); }
.replay-card-heart { background: linear-gradient(160deg, #ff3a45, #b60d24); }
.replay-card-diamond { background: linear-gradient(160deg, #4087ff, #203aa9); }
.replay-card-club { background: linear-gradient(160deg, #3de071, #0c8638); }
.replay-card-rank { font-size: 22rpx; font-weight: 1000; line-height: 1; }
.replay-card-suit { align-self: flex-end; font-size: 19rpx; font-weight: 1000; line-height: 1; }
.replay-slot { border: 1rpx dashed rgba(255, 255, 255, .22); background: rgba(255, 255, 255, .035); }

.replay-seat { position: absolute; z-index: 9; width: 132rpx; min-height: 82rpx; }
.replay-seat-panel { position: relative; z-index: 3; min-height: 72rpx; padding: 9rpx 10rpx 8rpx; border: 1rpx solid rgba(205, 220, 232, .28); border-radius: 18rpx; box-sizing: border-box; background: linear-gradient(160deg, rgba(45, 53, 65, .98), rgba(15, 19, 27, .98)); box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .12), 0 13rpx 25rpx rgba(0, 0, 0, .42); }
.replay-seat.hero .replay-seat-panel { border-color: rgba(255, 39, 56, .72); background: linear-gradient(155deg, rgba(91, 20, 30, .98), rgba(20, 20, 28, .98)); }
.replay-seat.active .replay-seat-panel { border-color: #3deaff; box-shadow: 0 0 0 4rpx rgba(0, 209, 255, .15), 0 0 28rpx rgba(0, 209, 255, .34), inset 0 1rpx 0 rgba(255, 255, 255, .18); animation: actor-pulse 900ms ease-in-out infinite alternate; }
.replay-seat.folded { opacity: .38; filter: grayscale(.72); }
.replay-seat-row { display: flex; align-items: center; justify-content: center; gap: 5rpx; }
.replay-seat-avatar { position: absolute; left: 7rpx; top: 8rpx; width: 46rpx; height: 46rpx; overflow: hidden; border: 2rpx solid rgba(255, 255, 255, .68); border-radius: 50%; box-sizing: border-box; }
.replay-seat-avatar-img { width: 100%; height: 100%; }
.replay-seat-position-badge { position: absolute; left: 50%; bottom: -1rpx; min-width: 30rpx; height: 15rpx; padding: 0 3rpx; border-radius: 999rpx; color: #fff; background: rgba(2, 5, 9, .86); font-size: 10rpx; font-weight: 1000; line-height: 15rpx; text-align: center; transform: translateX(-50%); }
.replay-seat-avatar + .replay-seat-name,
.replay-seat-avatar ~ .replay-seat-stack { max-width: 67rpx; margin-left: 52rpx; }
.replay-seat-pos { color: #53e9ff; font-size: 16rpx; font-weight: 1000; }
.replay-seat-name { margin-top: 2rpx; overflow: hidden; color: #fff; font-size: 20rpx; font-weight: 1000; line-height: 1.1; text-align: center; text-overflow: ellipsis; white-space: nowrap; }
.replay-seat-stack { margin-top: 4rpx; overflow: hidden; color: rgba(255, 255, 255, .67); font-size: 15rpx; font-weight: 800; line-height: 1; text-align: center; text-overflow: ellipsis; white-space: nowrap; }
.replay-dealer { display: inline-flex; align-items: center; justify-content: center; width: 22rpx; height: 22rpx; border-radius: 50%; color: #101218; background: #fff; font-size: 13rpx; font-weight: 1000; }

.replay-hole-cards { position: absolute; z-index: 2; left: 50%; top: -35rpx; display: flex; transform: translateX(-50%); }
.replay-hole-card { position: relative; width: 35rpx; height: 48rpx; margin: 0 -3rpx; padding: 4rpx; border-radius: 6rpx; box-sizing: border-box; transform-origin: 50% 100%; }
.replay-hole-card:first-child { transform: rotate(-8deg); }
.replay-hole-card:last-child { transform: rotate(8deg); }
.replay-hole-card.replay-card { display: flex; }
.card-back { overflow: hidden; border: 1rpx solid rgba(238, 245, 250, .72); background: repeating-linear-gradient(135deg, #3b111a 0, #3b111a 5rpx, #a11020 5rpx, #a11020 9rpx); box-shadow: 0 8rpx 15rpx rgba(0, 0, 0, .42); }
.card-back::after { content: ''; position: absolute; inset: 4rpx; border: 1rpx solid rgba(255, 255, 255, .38); border-radius: 3rpx; }
.card-back-mark { position: relative; z-index: 2; margin-top: 14rpx; color: rgba(255, 255, 255, .88); font-size: 11rpx; font-weight: 1000; text-align: center; transform: skewX(-8deg); }
.motion-even .replay-hole-card { animation: hole-deal-a 300ms cubic-bezier(.2, .9, .2, 1); }
.motion-odd .replay-hole-card { animation: hole-deal-b 300ms cubic-bezier(.2, .9, .2, 1); }

.replay-action-chip { position: absolute; z-index: 14; left: 50%; bottom: -43rpx; display: flex; align-items: center; justify-content: center; gap: 6rpx; min-width: 92rpx; max-width: 178rpx; height: 34rpx; padding: 0 11rpx; border: 1rpx solid rgba(255, 255, 255, .54); border-radius: 999rpx; box-sizing: border-box; color: #061014; background: #54eaff; font-size: 15rpx; font-weight: 1000; transform: translateX(-50%); box-shadow: 0 9rpx 18rpx rgba(0, 0, 0, .4); animation: chip-flight 320ms cubic-bezier(.2, .9, .2, 1); }
.chip-dot { width: 16rpx; height: 16rpx; border: 3rpx dotted currentColor; border-radius: 50%; box-sizing: border-box; }
.action-bet, .action-raise, .action-open, .action-allin { color: #fff; background: #e60012; }
.action-call { background: #54eaff; }
.action-check { color: #101218; background: #d8e0e8; }
.action-fold { color: #fff; background: #5d6470; }

.seat-utg { left: 15%; top: 20%; transform: translate(-50%, -50%); }
.seat-utgplus1 { left: 50%; top: 10%; transform: translate(-50%, -50%); }
.seat-mp { left: 85%; top: 20%; transform: translate(-50%, -50%); }
.seat-hj { right: -2%; top: 48%; transform: translateY(-50%); }
.seat-co { left: 84%; bottom: 19%; transform: translate(-50%, 50%); }
.seat-btn { left: 50%; bottom: 9%; transform: translate(-50%, 50%); }
.seat-sb { left: 16%; bottom: 19%; transform: translate(-50%, 50%); }
.seat-bb { left: -2%; top: 48%; transform: translateY(-50%); }

.replay-now { display: flex; align-items: center; min-height: 62rpx; margin: -8rpx 32rpx 8rpx; padding: 0 20rpx; border-left: 7rpx solid #e60012; background: linear-gradient(90deg, rgba(230, 0, 18, .2), rgba(255, 255, 255, .03)); }
.replay-now-actor { color: #43eaff; font-size: 22rpx; font-weight: 1000; }
.replay-now-action { flex: 1; margin-left: 12rpx; color: #fff; font-size: 22rpx; font-weight: 1000; }
.replay-now-count { color: rgba(255, 255, 255, .44); font-size: 17rpx; }

.replay-timeline { width: 100%; height: 108rpx; white-space: nowrap; }
.replay-timeline-track { position: relative; display: inline-flex; min-width: 100%; height: 100%; align-items: flex-start; justify-content: center; padding: 12rpx 24rpx 0; box-sizing: border-box; }
.replay-timeline-track::before { content: ''; position: absolute; left: 52rpx; right: 52rpx; top: 28rpx; height: 3rpx; background: rgba(255, 255, 255, .16); }
.timeline-node { position: relative; z-index: 2; width: 112rpx; text-align: center; opacity: .48; }
.timeline-node.is-past { opacity: .72; }
.timeline-node.is-current { opacity: 1; }
.timeline-dot { width: 19rpx; height: 19rpx; margin: 6rpx auto 7rpx; border: 4rpx solid #151921; border-radius: 50%; background: #6d7480; box-shadow: 0 0 0 2rpx rgba(255, 255, 255, .24); }
.is-past .timeline-dot { background: #e60012; }
.is-current .timeline-dot { background: #3eeaff; box-shadow: 0 0 0 5rpx rgba(0, 209, 255, .15), 0 0 20rpx rgba(0, 209, 255, .55); transform: scale(1.18); }
.timeline-street { color: rgba(255, 255, 255, .46); font-size: 13rpx; font-weight: 900; text-transform: uppercase; }
.timeline-action { margin-top: 3rpx; color: #fff; font-size: 15rpx; font-weight: 1000; }
.timeline-amount { margin-top: 2rpx; color: #45e9ff; font-size: 13rpx; font-weight: 900; }

.replay-controls { display: grid; justify-items: center; gap: 15rpx; margin-top: 6rpx; }
.replay-progress { width: calc(100% - 64rpx); height: 8rpx; overflow: visible; border-radius: 999rpx; background: rgba(255, 255, 255, .14); }
.replay-progress-fill { position: relative; height: 100%; border-radius: inherit; background: linear-gradient(90deg, #e60012, #ff3445); transition: width 220ms ease-out; }
.replay-progress-fill::after { content: ''; position: absolute; right: -7rpx; top: -5rpx; width: 16rpx; height: 16rpx; border: 3rpx solid #fff; border-radius: 50%; background: #e60012; box-shadow: 0 0 18rpx rgba(230, 0, 18, .8); }
.replay-buttons { position: relative; display: flex; align-items: center; justify-content: space-between; width: 320rpx; height: 66rpx; padding: 0 24rpx; border: 1rpx solid rgba(255, 255, 255, .14); border-radius: 14rpx; box-sizing: border-box; background: rgba(5, 7, 11, .88); }
.replay-control { display: flex; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; }
.replay-control.primary { position: absolute; left: 50%; top: 50%; width: 82rpx; height: 82rpx; border: 3rpx solid rgba(255, 255, 255, .24); border-radius: 50%; background: linear-gradient(145deg, #ff283c, #c60012); transform: translate(-50%, -50%); box-shadow: 0 0 0 4rpx rgba(230, 0, 18, .22), 0 12rpx 26rpx rgba(230, 0, 18, .34); }
.control-glyph { display: block; box-sizing: border-box; }
.glyph-prev, .glyph-next { position: relative; width: 28rpx; height: 34rpx; }
.glyph-prev view, .glyph-next view { position: absolute; left: 1rpx; top: 50%; width: 26rpx; height: 7rpx; border-radius: 999rpx; background: #fff; transform-origin: 50% 50%; }
.glyph-prev view:first-child { transform: translateY(-7rpx) rotate(-45deg); }
.glyph-prev view:last-child { transform: translateY(7rpx) rotate(45deg); }
.glyph-next view:first-child { transform: translateY(-7rpx) rotate(45deg); }
.glyph-next view:last-child { transform: translateY(7rpx) rotate(-45deg); }
.glyph-play { width: 0; height: 0; margin-left: 6rpx; border-top: 20rpx solid transparent; border-bottom: 20rpx solid transparent; border-left: 27rpx solid #fff; }
.glyph-pause { display: flex; align-items: center; justify-content: center; gap: 9rpx; }
.glyph-pause view { width: 9rpx; height: 34rpx; border-radius: 5rpx; background: #fff; }

.is-compact { padding-bottom: 20rpx; }
.is-compact .replay-table { height: 770rpx; transform: scale(.96); transform-origin: 50% 0; margin-bottom: -20rpx; }
.is-compact .replay-timeline { height: 98rpx; }

@keyframes actor-pulse { from { transform: translateY(0); } to { transform: translateY(-3rpx); } }
@keyframes chip-flight { from { opacity: 0; transform: translate(-50%, -24rpx) scale(.7); } to { opacity: 1; transform: translate(-50%, 0) scale(1); } }
@keyframes card-deal { from { opacity: 0; transform: translateY(-28rpx) rotateY(75deg) scale(.72); } to { opacity: 1; transform: translateY(0) rotateY(0) scale(1); } }
@keyframes hole-deal-a { from { opacity: .25; margin-top: -18rpx; } to { opacity: 1; margin-top: 0; } }
@keyframes hole-deal-b { from { opacity: .25; margin-top: -17rpx; } to { opacity: 1; margin-top: 0; } }
@keyframes action-pop-a { from { opacity: .3; transform: translateY(6rpx) scale(.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes action-pop-b { from { opacity: .3; transform: translateY(5rpx) scale(.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes street-wipe { 0% { left: -48%; opacity: 0; } 20% { opacity: .95; } 100% { left: 112%; opacity: 0; } }
@keyframes chip-to-pot-a { 0% { left: 0; opacity: 0; transform: scale(.7); } 16% { opacity: 1; } 100% { left: calc(100% - 24rpx); opacity: 0; transform: scale(.86); } }
@keyframes chip-to-pot-b { 0% { left: 0; opacity: 0; transform: scale(.72); } 16% { opacity: 1; } 100% { left: calc(100% - 24rpx); opacity: 0; transform: scale(.86); } }

@media (prefers-reduced-motion: reduce) {
  .replay-seat.active .replay-seat-panel, .replay-action-main, .replay-hole-card, .replay-board-card, .replay-action-chip, .replay-street-wipe, .replay-flying-chip { animation: none !important; }
  .replay-progress-fill { transition: none; }
}
