<view class="replay-shell" catchtap="noop">
  <view class="replay-head">
    <view>
      <view class="replay-title">HAND REPLAY</view>
      <view class="replay-sub">{{currentStep ? currentStep.actionText : 'No action'}}</view>
    </view>
    <view class="replay-close" bindtap="close" aria-label="close">X</view>
  </view>

  <view class="replay-table">
    <view class="replay-felt"></view>
    <view class="replay-action">
      <view class="replay-action-main">{{currentStep ? currentStep.displayActionText : 'Ready'}}</view>
    </view>

    <view class="replay-center">
      <view class="replay-pot">Pot {{currentStep && currentStep.potText ? currentStep.potText : '-'}}</view>
      <view class="replay-board">
        <view wx:for="{{currentStep ? currentStep.boardCards : []}}" wx:key="index" class="replay-card replay-card-{{item.suitClass}}">
          <text class="replay-card-rank">{{item.rank}}</text>
          <text class="replay-card-suit">{{item.suitSymbol}}</text>
        </view>
        <view wx:for="{{currentStep ? currentStep.boardSlots : []}}" wx:key="id" class="replay-slot"></view>
      </view>
    </view>

    <view wx:for="{{displayPlayers}}" wx:key="id" class="replay-seat {{item.seatClass}} {{item.isHero ? 'hero' : ''}} {{item.activeClass}}">
      <view wx:if="{{item.actionChipText}}" class="replay-action-chip action-{{item.actionType}}">{{item.actionChipText}}</view>
      <view wx:if="{{item.hasAvatar}}" class="replay-seat-avatar">
        <image class="replay-seat-avatar-img" src="{{item.avatarDisplayUrl || item.avatarUrl}}" mode="aspectFill"></image>
        <view class="replay-seat-position-badge">{{item.position}}</view>
      </view>
      <view wx:else class="replay-seat-row">
        <text class="replay-seat-pos">{{item.position}}</text>
      </view>
      <view class="replay-seat-stack">{{item.stackText || '-'}}</view>
      <view class="replay-seat-name">{{item.name}}</view>
      <view wx:if="{{item.isHero}}" class="replay-hero-cards">
        <view wx:for="{{replay.heroCards}}" wx:key="index" class="replay-card replay-hero-card replay-card-{{item.suitClass}}">
          <text class="replay-card-rank">{{item.rank}}</text>
          <text class="replay-card-suit">{{item.suitSymbol}}</text>
        </view>
      </view>
      <view wx:if="{{item.isDealer}}" class="replay-dealer">D</view>
    </view>
  </view>

  <view class="replay-controls">
    <view class="replay-progress">
      <view class="replay-progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
    <view class="replay-buttons">
      <view class="replay-control side prev" bindtap="prevStep" aria-label="prev">
        <view class="control-glyph glyph-prev">
          <view></view>
          <view></view>
        </view>
      </view>
      <view class="replay-control primary icon" bindtap="togglePlay" aria-label="play">
        <view wx:if="{{playing}}" class="control-glyph glyph-pause">
          <view></view>
          <view></view>
        </view>
        <view wx:else class="control-glyph glyph-play"></view>
      </view>
      <view class="replay-control side next" bindtap="nextStep" aria-label="next">
        <view class="control-glyph glyph-next">
          <view></view>
          <view></view>
        </view>
      </view>
    </view>
  </view>
</view>
