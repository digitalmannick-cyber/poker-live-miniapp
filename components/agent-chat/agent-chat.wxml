<view class="agent-chat-root">
  <view wx:if="{{!displayVisible}}" class="agent-chat-fab" bindtap="openChat">
    <image
      class="agent-chat-fab-icon"
      src="/components/agent-chat/poker-agent-fab-96.png"
      mode="aspectFill"
    />
  </view>

  <view wx:if="{{displayVisible}}" class="agent-chat-mask {{visible ? 'open' : 'closing'}}" bindtap="closeChat"></view>
  <view wx:if="{{displayVisible}}" class="agent-chat-panel {{visible ? 'open' : 'closing'}}" catchtap="noop">
    <view class="agent-chat-head">
      <view>
        <view class="agent-chat-title">EV脑</view>
        <view class="agent-chat-subtitle">范围、复盘、训练和状态检查</view>
      </view>
      <view class="agent-chat-close" bindtap="closeChat" aria-label="收起 EV脑">
        <view class="agent-chat-collapse-icon"></view>
      </view>
    </view>

    <scroll-view class="agent-chat-messages" scroll-y scroll-into-view="{{scrollAnchor}}">
      <view class="agent-chat-quick">
        <view
          wx:for="{{quickActions}}"
          wx:key="key"
          class="agent-chat-chip"
          data-intent="{{item.key}}"
          data-prompt="{{item.prompt}}"
          bindtap="useQuickAction"
        >{{item.title}}</view>
      </view>

      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="{{item.id}}"
        class="agent-chat-message {{item.role === 'user' ? 'user' : 'assistant'}} {{item.reminder ? 'reminder' : ''}}"
      >
        <view wx:if="{{!item.reminderCard}}" class="agent-chat-message-role">{{item.role === 'user' ? '你' : 'EV脑'}}</view>
        <view wx:if="{{item.reminder && !item.reminderCard}}" class="agent-chat-reminder-badge">EV脑提醒</view>
        <view
          wx:if="{{item.reminderCard}}"
          class="agent-chat-reminder-card {{item.reminderCard.variant === 'warning' ? 'warning' : 'strong'}} {{item.reminderCard.acknowledged ? 'acknowledged' : ''}}"
          data-text="{{item.text}}"
          bindlongpress="copyMessageText"
        >
          <view class="agent-chat-reminder-card-label">{{item.reminderCard.label}} · {{item.reminderCard.title}}</view>
          <view class="agent-chat-reminder-card-headline">{{item.reminderCard.headline}}</view>
          <view wx:if="{{item.reminderCard.metrics.length}}" class="agent-chat-reminder-metrics">
            <view wx:for="{{item.reminderCard.metrics}}" wx:for-item="metric" wx:key="label" class="agent-chat-reminder-metric">
              <view class="agent-chat-reminder-metric-label">{{metric.label}}</view>
              <view class="agent-chat-reminder-metric-value">{{metric.value}}</view>
            </view>
          </view>
          <view wx:if="{{item.reminderCard.advice}}" class="agent-chat-reminder-advice">{{item.reminderCard.advice}}</view>
          <view class="agent-chat-reminder-actions">
            <view
              class="agent-chat-reminder-ack {{item.reminderCard.acknowledged ? 'done' : ''}}"
              data-id="{{item.id}}"
              catchtap="acknowledgeReminderCard"
            >{{item.reminderCard.acknowledged ? '已知晓' : item.reminderCard.actionLabel}}</view>
          </view>
        </view>
        <view
          wx:if="{{!item.reminderCard}}"
          class="agent-chat-message-text"
          data-text="{{item.text}}"
          bindlongpress="copyMessageText"
        >{{item.text}}</view>
        <image
          wx:if="{{item.imageUrl && !item.imageError}}"
          class="agent-chat-message-image"
          src="{{item.imageUrl}}"
          mode="widthFix"
          bindtap="previewMessageImage"
          binderror="onMessageImageError"
          data-id="{{item.id}}"
          data-url="{{item.imageUrl}}"
        />
        <view wx:if="{{item.imageError}}" class="agent-chat-message-image-error">范围图加载失败，请稍后重新查询。</view>
      </view>

      <view wx:if="{{busy}}" class="agent-chat-message assistant">
        <view class="agent-chat-message-role">EV脑</view>
        <view class="agent-chat-thinking">
          <view class="agent-chat-dot"></view>
          <view class="agent-chat-dot"></view>
          <view class="agent-chat-dot"></view>
        </view>
      </view>
    </scroll-view>

    <view class="agent-chat-input-wrap">
      <textarea
        class="agent-chat-input"
        value="{{inputText}}"
        bindinput="onInput"
        auto-height
        maxlength="-1"
        cursor-spacing="120"
        placeholder="点这里用手机语音输入法说牌谱、问范围或做状态检查"
        placeholder-class="agent-chat-placeholder"
      ></textarea>
      <view class="agent-chat-send {{busy || !inputText ? 'disabled' : ''}}" bindtap="sendMessage">发送</view>
    </view>
  </view>
</view>
