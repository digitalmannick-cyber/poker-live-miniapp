.release-notes-mask {
  position: fixed;
  inset: 0;
  z-index: 2200;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(2, 4, 9, 0.88);
  backdrop-filter: blur(14rpx);
}

.release-notes-poster {
  position: relative;
  width: 100%;
  max-width: 670rpx;
  max-height: 86vh;
  overflow: hidden;
  box-sizing: border-box;
  padding: 48rpx 36rpx 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 8rpx;
  background:
    linear-gradient(145deg, rgba(92, 0, 15, 0.72) 0, rgba(12, 14, 22, 0.96) 34%, rgba(5, 22, 30, 0.98) 100%);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.58);
}

.release-notes-slash {
  position: absolute;
  top: -36rpx;
  right: -88rpx;
  width: 330rpx;
  height: 122rpx;
  transform: rotate(-15deg);
  background: #e60012;
  opacity: 0.9;
}

.release-notes-head {
  position: relative;
  z-index: 1;
}

.release-notes-eyebrow,
.release-notes-version {
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: 0;
}

.release-notes-eyebrow {
  color: #22d8ff;
}

.release-notes-version {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.6);
}

.release-notes-title {
  margin-top: 18rpx;
  color: #fff;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: 0;
}

.release-notes-summary {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.55;
}

.release-notes-image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 220rpx;
  margin-top: 26rpx;
  border-radius: 6rpx;
}

.release-notes-scroll {
  position: relative;
  z-index: 1;
  max-height: 470rpx;
  margin-top: 30rpx;
}

.release-notes-scroll.with-image {
  max-height: 310rpx;
}

.release-notes-item {
  display: grid;
  grid-template-columns: 54rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: start;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.release-notes-index {
  width: 46rpx;
  height: 46rpx;
  border: 2rpx solid #e60012;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 46rpx;
  text-align: center;
  transform: skew(-7deg);
}

.release-notes-copy {
  min-width: 0;
}

.release-notes-item-title {
  color: #fff;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.release-notes-item-description {
  margin-top: 5rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 23rpx;
  line-height: 1.45;
}

.release-notes-acknowledge {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 92rpx;
  margin-top: 24rpx;
  border: 2rpx solid #ff1a2d;
  border-radius: 6rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
  text-align: center;
  background: linear-gradient(105deg, #74000d, #d40014 68%, #ff1529);
  box-shadow: 8rpx 8rpx 0 rgba(0, 0, 0, 0.42);
}

.release-notes-acknowledge:active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 3rpx 3rpx 0 rgba(0, 0, 0, 0.42);
}
