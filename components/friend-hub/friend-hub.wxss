.friend-hub { min-height: 420rpx; }

.friend-subnav {
  display: flex;
  gap: 14rpx;
  margin: 8rpx 0 22rpx;
}

.friend-subnav-item {
  flex: 1;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: rgba(255,255,255,0.56);
  font-size: 25rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.11);
}

.friend-subnav-item.active {
  color: #ffffff;
  background: rgba(230,0,18,0.76);
  border-color: rgba(255,255,255,0.2);
}

.friend-list { display: grid; gap: 14rpx; }

.friend-card {
  position: relative;
  display: grid;
  grid-template-columns: 8rpx 134rpx minmax(0, 1fr);
  gap: 16rpx;
  min-height: 230rpx;
  padding: 18rpx 18rpx 18rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 22rpx;
  background: linear-gradient(105deg, var(--player-card-color), rgba(23,26,34,0.94) 42%, #171a22 76%);
  border: 2rpx solid rgba(255,255,255,0.18);
}

.friend-card-color { width: 8rpx; height: 100%; border-radius: 999rpx; }
.friend-avatar { width: 134rpx; height: 134rpx; align-self: center; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 22rpx; color: #ffffff; font-size: 48rpx; font-weight: 1000; background: rgba(255,255,255,0.09); border: 2rpx solid rgba(255,255,255,0.16); }
.friend-avatar-img { width: 100%; height: 100%; }
.friend-main { min-width: 0; align-self: center; }
.friend-name-row { display: flex; align-items: center; gap: 10rpx; min-width: 0; }
.friend-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #ffffff; font-size: 36rpx; font-weight: 1000; }
.friend-title { flex: none; padding: 5rpx 11rpx; border-radius: 999rpx; color: #ffd447; font-size: 20rpx; font-weight: 950; background: rgba(255,212,71,0.14); border: 1rpx solid rgba(255,212,71,0.26); }
.friend-type { display: inline-flex; max-width: 270rpx; margin-top: 8rpx; padding: 6rpx 12rpx; border-radius: 999rpx; color: #ffffff; font-size: 20rpx; font-weight: 900; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.friend-private-line { margin-top: 8rpx; overflow: hidden; color: rgba(255,255,255,0.63); font-size: 22rpx; text-overflow: ellipsis; white-space: nowrap; }
.friend-bottom { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; color: rgba(255,255,255,0.76); font-size: 21rpx; font-weight: 850; }
.friend-hub-state { margin-top: 70rpx; padding: 48rpx 30rpx; text-align: center; border-radius: 22rpx; color: rgba(255,255,255,0.60); font-size: 26rpx; line-height: 1.5; background: rgba(255,255,255,0.055); border: 1rpx solid rgba(255,255,255,0.1); }
.friend-hub-error { color: #ff8b97; }
.friend-retry { display: inline-flex; margin-top: 18rpx; padding: 8rpx 24rpx; border-radius: 999rpx; color: #ffffff; background: #e60012; font-weight: 950; }
.friend-load-more { display: flex; align-items: center; justify-content: center; min-height: 70rpx; border-radius: 16rpx; color: rgba(255,255,255,0.82); font-size: 24rpx; font-weight: 950; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); }
.friend-load-more.is-loading { opacity: 0.62; }

.ranking-panel { padding-bottom: 32rpx; }
.ranking-range-tabs { display: flex; width: 420rpx; max-width: 100%; margin: 6rpx auto 30rpx; padding: 6rpx; border-radius: 999rpx; background: rgba(255,255,255,0.055); border: 1rpx solid rgba(255,255,255,0.12); }
.ranking-range-tab { flex: 1; display: flex; align-items: center; justify-content: center; min-height: 58rpx; border-radius: 999rpx; color: rgba(255,255,255,0.58); font-size: 23rpx; font-weight: 950; transition: color .2s ease, background .2s ease; }
.ranking-range-tab.active { color: #101116; background: #f2f3f7; box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.25); }
.ranking-state { margin-top: 24rpx; }
.ranking-board { position: relative; padding: 22rpx 16rpx 12rpx; overflow: hidden; border-radius: 30rpx; background: radial-gradient(circle at 50% 0, rgba(255,212,71,0.11), transparent 38%), linear-gradient(160deg, #171922, #0d0f15 72%); border: 1rpx solid rgba(255,255,255,0.13); }
.ranking-board::before { content: ''; position: absolute; top: 0; left: 8%; right: 8%; height: 2rpx; background: linear-gradient(90deg, transparent, rgba(255,212,71,0.85), transparent); }
.ranking-kicker { text-align: center; color: rgba(255,212,71,0.72); font-size: 18rpx; font-weight: 1000; letter-spacing: 5rpx; }
.ranking-podium { display: flex; align-items: flex-end; justify-content: center; gap: 10rpx; min-height: 370rpx; padding: 26rpx 0 8rpx; }
.podium-card { --medal: #bf7650; position: relative; width: 31%; padding-top: 25rpx; text-align: center; animation: podium-enter .5s cubic-bezier(.2,.8,.2,1) both; }
.podium-card:nth-child(2) { animation-delay: .08s; }
.podium-card:nth-child(3) { animation-delay: .16s; }
.podium-gold { --medal: #ffd447; order: 2; transform: translateY(-28rpx); }
.podium-silver { --medal: #d9e2ef; order: 1; }
.podium-bronze { --medal: #d98558; order: 3; }
.podium-avatar-wrap { position: relative; width: 116rpx; height: 116rpx; margin: auto; padding: 5rpx; border-radius: 32rpx; background: linear-gradient(145deg, var(--medal), rgba(255,255,255,0.2)); box-shadow: 0 14rpx 34rpx rgba(0,0,0,0.38); animation: podium-breathe 3.6s ease-in-out infinite; }
.podium-gold .podium-avatar-wrap { width: 138rpx; height: 138rpx; }
.podium-avatar { width: 100%; height: 100%; box-sizing: border-box; overflow: hidden; border-radius: 28rpx; background: #262a35; }
.podium-avatar-text { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 42rpx; font-weight: 1000; }
.podium-medal { position: absolute; z-index: 2; top: 8rpx; left: 50%; width: 45rpx; height: 45rpx; display: flex; align-items: center; justify-content: center; transform: translate(-50%, -50%); border-radius: 50%; color: #111319; background: var(--medal); border: 5rpx solid #111319; font-size: 23rpx; font-weight: 1000; }
.podium-name { margin-top: 13rpx; overflow: hidden; color: #fff; font-size: 27rpx; font-weight: 1000; text-overflow: ellipsis; white-space: nowrap; }
.podium-title { margin-top: 3rpx; overflow: hidden; color: rgba(255,255,255,0.47); font-size: 18rpx; text-overflow: ellipsis; white-space: nowrap; }
.podium-duration { margin-top: 7rpx; color: var(--medal); font-size: 28rpx; font-weight: 1000; }
.podium-hands { margin-top: 2rpx; color: rgba(255,255,255,0.42); font-size: 18rpx; }
.podium-plinth { height: 52rpx; margin-top: 12rpx; display: flex; align-items: center; justify-content: center; border-radius: 14rpx 14rpx 5rpx 5rpx; color: var(--medal); background: linear-gradient(180deg, rgba(255,255,255,0.09), rgba(255,255,255,0.025)); border: 1rpx solid rgba(255,255,255,0.11); font-size: 23rpx; font-weight: 1000; letter-spacing: 2rpx; }
.podium-gold .podium-plinth { height: 68rpx; }
.ranking-list { display: grid; gap: 11rpx; margin-top: 18rpx; }
.ranking-row, .ranking-my-card { position: relative; display: grid; grid-template-columns: 7rpx 58rpx 76rpx minmax(0,1fr) auto; gap: 12rpx; align-items: center; min-height: 104rpx; padding: 12rpx 18rpx 12rpx 0; overflow: hidden; border-radius: 19rpx; background: linear-gradient(100deg, rgba(255,255,255,0.085), rgba(255,255,255,0.035)); border: 1rpx solid rgba(255,255,255,0.105); }
.ranking-row-accent { width: 7rpx; height: 62%; border-radius: 0 999rpx 999rpx 0; background: linear-gradient(180deg, #be44ff, #26d9ff); box-shadow: 0 0 18rpx rgba(74,183,255,0.48); }
.ranking-row:nth-child(2n) .ranking-row-accent { background: linear-gradient(180deg, #496dff, #59f0ff); }
.ranking-number { color: rgba(255,255,255,0.64); font-size: 25rpx; font-weight: 1000; text-align: center; }
.ranking-avatar-wrap { width: 68rpx; height: 68rpx; padding: 3rpx; border-radius: 20rpx; background: rgba(255,255,255,0.14); }
.ranking-avatar { width: 100%; height: 100%; overflow: hidden; border-radius: 17rpx; background: #252936; }
.ranking-avatar-text { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 25rpx; font-weight: 1000; }
.ranking-copy { min-width: 0; }
.ranking-name { overflow: hidden; color: #fff; font-size: 26rpx; font-weight: 1000; text-overflow: ellipsis; white-space: nowrap; }
.ranking-title { margin-top: 5rpx; overflow: hidden; color: rgba(255,255,255,0.45); font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.ranking-duration { color: #39dcf4; font-size: 27rpx; font-weight: 1000; }
.ranking-my-card { position: sticky; bottom: 14rpx; grid-template-columns: 8rpx 58rpx 68rpx minmax(0,1fr) auto; margin-top: 20rpx; padding-left: 13rpx; border-color: rgba(255,212,71,0.42); background: linear-gradient(100deg, rgba(255,212,71,0.19), rgba(26,28,36,0.96)); box-shadow: 0 16rpx 38rpx rgba(0,0,0,0.38); }
.ranking-my-label { position: absolute; top: -15rpx; left: 18rpx; padding: 4rpx 13rpx; border-radius: 999rpx; color: #111319; background: #ffd447; font-size: 17rpx; font-weight: 1000; }
@keyframes podium-enter { from { opacity: 0; transform: translateY(22rpx); } to { opacity: 1; } }
@keyframes podium-breathe { 0%,100% { box-shadow: 0 14rpx 34rpx rgba(0,0,0,0.38); } 50% { box-shadow: 0 14rpx 38rpx rgba(0,0,0,0.38), 0 0 20rpx rgba(255,212,71,0.13); } }
@media (prefers-reduced-motion: reduce) {
  .podium-card, .podium-avatar-wrap { animation: none; transition: none; }
}
