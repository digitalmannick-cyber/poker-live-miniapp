.friend-hub { min-height: 420rpx; }

.friend-subnav {
  display: flex;
  gap: 14rpx;
  margin: 8rpx 0 22rpx;
}

.friend-subnav-item {
  flex: 1;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: rgba(255,255,255,0.56);
  font-size: 25rpx;
  font-weight: 950;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.11);
}

.friend-subnav-item.active {
  color: #ffffff;
  background: rgba(230,0,18,0.76);
  border-color: rgba(255,255,255,0.2);
}

.friend-list { display: grid; gap: 14rpx; }

.friend-card {
  position: relative;
  display: grid;
  grid-template-columns: 8rpx 134rpx minmax(0, 1fr);
  gap: 16rpx;
  min-height: 230rpx;
  padding: 18rpx 18rpx 18rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 22rpx;
  background: linear-gradient(105deg, var(--player-card-color), rgba(23,26,34,0.94) 42%, #171a22 76%);
  border: 2rpx solid rgba(255,255,255,0.18);
}

.friend-card-color { width: 8rpx; height: 100%; border-radius: 999rpx; }
.friend-avatar { width: 134rpx; height: 134rpx; align-self: center; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 22rpx; color: #ffffff; font-size: 48rpx; font-weight: 1000; background: rgba(255,255,255,0.09); border: 2rpx solid rgba(255,255,255,0.16); }
.friend-avatar-img { width: 100%; height: 100%; }
.friend-main { min-width: 0; align-self: center; }
.friend-name-row { display: flex; align-items: center; gap: 10rpx; min-width: 0; }
.friend-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #ffffff; font-size: 36rpx; font-weight: 1000; }
.friend-title { flex: none; padding: 5rpx 11rpx; border-radius: 999rpx; color: #ffd447; font-size: 20rpx; font-weight: 950; background: rgba(255,212,71,0.14); border: 1rpx solid rgba(255,212,71,0.26); }
.friend-type { display: inline-flex; max-width: 270rpx; margin-top: 8rpx; padding: 6rpx 12rpx; border-radius: 999rpx; color: #ffffff; font-size: 20rpx; font-weight: 900; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.friend-private-line { margin-top: 8rpx; overflow: hidden; color: rgba(255,255,255,0.63); font-size: 22rpx; text-overflow: ellipsis; white-space: nowrap; }
.friend-bottom { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; color: rgba(255,255,255,0.76); font-size: 21rpx; font-weight: 850; }
.friend-hub-state { margin-top: 70rpx; padding: 48rpx 30rpx; text-align: center; border-radius: 22rpx; color: rgba(255,255,255,0.60); font-size: 26rpx; line-height: 1.5; background: rgba(255,255,255,0.055); border: 1rpx solid rgba(255,255,255,0.1); }
.friend-hub-error { color: #ff8b97; }
.friend-retry { display: inline-flex; margin-top: 18rpx; padding: 8rpx 24rpx; border-radius: 999rpx; color: #ffffff; background: #e60012; font-weight: 950; }
.friend-load-more { display: flex; align-items: center; justify-content: center; min-height: 70rpx; border-radius: 16rpx; color: rgba(255,255,255,0.82); font-size: 24rpx; font-weight: 950; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); }
.friend-load-more.is-loading { opacity: 0.62; }
